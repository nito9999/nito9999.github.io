)]}'
{"Bat Fact":"\u092e\u093e\u091d\u094d\u092f\u093e\u0938\u093e\u0930\u0916\u0940 \u0935\u094d\u0939\u0945\u092e\u094d\u092a\u093e\u092f\u0930 \u0935\u091f\u0935\u093e\u0918\u0933\u0902 \u092b\u0915\u094d\u0924 \u0909\u0921\u0924 \u0928\u093e\u0939\u0940\u0924 \u0924\u0930 \u091a\u093e\u0932\u0924\u093e\u0924, \u0909\u0921\u094d\u092f\u093e \u092e\u093e\u0930\u0924\u093e\u0924 \u0906\u0923\u093f \u091c\u092e\u093f\u0928\u0940\u0935\u0930 \u0927\u093e\u0935\u0924\u093e\u0924\u0926\u0947\u0916\u0940\u0932.","Black Cat Fact":"\u092e\u093e\u0902\u091c\u0930 \u092a\u094d\u0930\u091c\u093e\u0924\u0940\u092e\u0927\u0940\u0932 \u0907\u0924\u0930 \u092a\u094d\u0930\u093e\u0923\u094d\u092f\u093e\u0902\u0928\u093e \u0906\u0935\u0921\u0924 \u0928\u0938\u0932\u0947 \u0924\u0930\u0940 \u0906\u092e\u094d\u0939\u0940 \u091c\u0917\u094d\u0935\u093e\u0930 \u0916\u0942\u092a \u0906\u0935\u0921\u0940\u0928\u0947 \u092a\u094b\u0939\u094b\u0924\u094b \u0906\u0923\u093f \u092a\u093e\u0923\u094d\u092f\u093e\u092e\u0927\u094d\u092f\u0947 \u0921\u0941\u0902\u092c\u0924\u094b.","End Screen":"\u0939\u0945\u0932\u094b\u0935\u093f\u0928\u091a\u094d\u092f\u093e \u0936\u0941\u092d\u0947\u091a\u094d\u091b\u093e! (\u0906\u0923\u093f \u0926\u093e\u0924 \u0918\u093e\u0938\u093e\u092f\u0932\u093e \u0935\u093f\u0938\u0930\u0942 \u0928\u0915\u093e!)","Happy Halloween!":"\u0939\u0945\u0932\u094b\u0935\u093f\u0928\u091a\u094d\u092f\u093e \u0936\u0941\u092d\u0947\u091a\u094d\u091b\u093e!","Octopus Fact":"\u092e\u0932\u093e \u0924\u0940\u0928 \u0939\u0943\u0926\u092f\u0947 \u0906\u0939\u0947\u0924! \u092e\u0940 \u092a\u094b\u0939\u0924 \u0905\u0938\u0924\u093e\u0928\u093e \u092b\u0915\u094d\u0924 \u0926\u094b\u0928 \u0939\u0943\u0926\u092f\u0947 \u0915\u093e\u092e \u0915\u0930\u0924\u093e\u0924 \u092e\u094d\u0939\u0923\u0942\u0928 \u092e\u0932\u093e \u0938\u0930\u092a\u091f\u0923\u0947 \u091c\u093e\u0938\u094d\u0924 \u0938\u094b\u092f\u0940\u0938\u094d\u0915\u0930 \u0935\u093e\u091f\u0924\u0947.","Option":"\u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0939\u0935\u0947 \u0924\u0947 \u0928\u093f\u0935\u0921\u093e!","Owl Fact":"\u092e\u093e\u091d\u094d\u092f\u093e \u092a\u093e\u0935\u0932\u093e\u0902\u0935\u0930\u0940\u0932 \u092a\u093f\u0938\u0902 \u092e\u0932\u093e \u092b\u091d\u0940 \u091a\u092a\u0932\u093e\u0902\u092a\u094d\u0930\u092e\u093e\u0923\u0947 \u090a\u092c \u0926\u0947\u0923\u094d\u092f\u093e\u0924 \u092e\u0926\u0924 \u0915\u0930\u0924\u093e\u0924.","Spider Fact":"\u0907\u0924\u0930 \u0915\u094b\u0933\u094d\u092f\u093e\u0902\u092a\u094d\u0930\u092e\u093e\u0923\u0947 \u0906\u092e\u094d\u0939\u0940 \u0935\u093f\u0937\u093e\u0930\u0940 \u0915\u094b\u0933\u0940 \u0935\u093e\u0922 \u0939\u094b\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0906\u092e\u091a\u0947 \u092c\u093e\u0939\u094d\u092f \u0938\u093e\u0902\u0917\u093e\u0921\u0947 \u091f\u093e\u0915\u0924\u094b.","Treat":"\u092d\u0947\u091f\u0935\u0938\u094d\u0924\u0942","Trick":"\u0916\u094b\u0921\u0940","Trick or Treat?":"\u0916\u094b\u0921\u0940 \u0915\u0940 \u092d\u0947\u091f\u0935\u0938\u094d\u0924\u0942?","Wolf Fact":"\u0915\u094b\u0932\u093e\u0939\u0932 \u0915\u0930\u0923\u0947 \u0939\u093e \u0906\u092e\u094d\u0939\u093e \u0915\u094b\u0932\u094d\u0939\u094d\u092f\u093e\u0902\u091a\u093e \u0938\u0902\u092a\u0930\u094d\u0915 \u0938\u093e\u0927\u0923\u094d\u092f\u093e\u091a\u094d\u092f\u093e \u0905\u0928\u0947\u0915 \u092e\u093e\u0930\u094d\u0917\u093e\u0902\u092a\u0948\u0915\u0940 \u090f\u0915 \u092e\u093e\u0930\u094d\u0917 \u0906\u0939\u0947. \u0926\u0947\u0939\u092c\u094b\u0932\u0940 \u0906\u0923\u093f \u091a\u0947\u0939\u0930\u094d\u200d\u092f\u093e\u0935\u0930\u0940\u0932 \u0939\u093e\u0935\u092d\u093e\u0935\u093e\u0902\u0935\u0930 \u0906\u092e\u091a\u093e \u0939\u093e\u0924\u0916\u0902\u0921\u093e \u0906\u0939\u0947."}