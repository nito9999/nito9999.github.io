)]}'
{"Bat Fact":"\u092e\u0947\u0930\u0947 \u091c\u0948\u0938\u0947 \u0935\u0948\u092e\u094d\u092a\u093e\u092f\u0930 \u091a\u092e\u0917\u093e\u0926\u0921\u093c \u0938\u093f\u0930\u094d\u092b\u093c \u0909\u0921\u093c\u0924\u0947 \u0939\u0940 \u0928\u0939\u0940\u0902 - \u091c\u093c\u092e\u0940\u0928 \u092a\u0930 \u091a\u0932\u0924\u0947, \u091b\u0932\u093e\u0902\u0917 \u0932\u0917\u093e\u0924\u0947, \u0914\u0930 \u0926\u094c\u0921\u093c\u0924\u0947 \u092d\u0940 \u0939\u0948\u0902","Black Cat Fact":"\u0926\u0942\u0938\u0930\u0940 \u092c\u0921\u093c\u0940 \u092c\u093f\u0932\u094d\u0932\u093f\u092f\u094b\u0902 \u0915\u094b \u0924\u0948\u0930\u0928\u093e \u092a\u0938\u0902\u0926 \u0928\u0939\u0940\u0902 \u0939\u094b\u0924\u093e, \u0932\u0947\u0915\u093f\u0928 \u0939\u092e \u091c\u0917\u0941\u0906\u0930 \u0915\u094b \u092a\u093e\u0928\u0940 \u092e\u0947\u0902 \u0938\u092e\u092f \u092c\u093f\u0924\u093e\u0928\u093e \u0905\u091a\u094d\u091b\u093e \u0932\u0917\u0924\u093e \u0939\u0948.","End Screen":"\u0939\u0948\u0932\u094b\u0935\u0940\u0928 \u0915\u0940 \u0936\u0941\u092d\u0915\u093e\u092e\u0928\u093e\u090f\u0902! (\u0914\u0930 \u0905\u092a\u0928\u0947 \u0928\u0941\u0915\u0940\u0932\u0947 \u0926\u093e\u0902\u0924 \u0926\u093f\u0916\u093e\u0928\u093e \u0928 \u092d\u0942\u0932\u0947\u0902!)","Happy Halloween!":"\u0939\u0948\u0932\u094b\u0935\u0940\u0928 \u0915\u0940 \u0936\u0941\u092d\u0915\u093e\u092e\u0928\u093e\u090f\u0902!","Octopus Fact":"\u092e\u0947\u0930\u0947 \u092a\u093e\u0938 \u0924\u0940\u0928 \u0926\u093f\u0932 \u0939\u0948\u0902! \u0924\u0948\u0930\u0924\u0947 \u0938\u092e\u092f \u0938\u093f\u0930\u094d\u092b\u093c \u0926\u094b \u0926\u093f\u0932 \u0927\u0921\u093c\u0915\u0924\u0947 \u0939\u0948\u0902, \u0907\u0938\u0932\u093f\u090f \u092e\u0941\u091d\u0947 \u0930\u0947\u0902\u0917\u0928\u093e \u092a\u0938\u0902\u0926 \u0939\u0948.","Option":"\u091c\u094b \u092a\u0938\u0902\u0926 \u0939\u094b \u0935\u0939 \u091a\u0941\u0928\u0947\u0902!","Owl Fact":"\u092e\u0947\u0930\u0947 \u092a\u0948\u0930\u094b\u0902 \u092e\u0947\u0902 \u0932\u0917\u0947 \u092a\u0902\u0916 \u092e\u0947\u0930\u0947 \u092a\u093e\u0902\u0935\u094b\u0902 \u0915\u094b \u0917\u0930\u094d\u092e \u0930\u0916\u0924\u0947 \u0939\u0948\u0902, \u0928\u0930\u094d\u092e \u091a\u092a\u094d\u092a\u0932\u094b\u0902 \u0915\u0940 \u0924\u0930\u0939.","Spider Fact":"\u0939\u092e \u092c\u0921\u093c\u0940 \u092e\u0915\u0921\u093c\u093f\u092f\u093e\u0902, \u092c\u093e\u0932\u094b\u0902 \u0938\u0947 \u092d\u0930\u093e \u0939\u0941\u0906 \u0936\u0930\u0940\u0930 \u0915\u093e \u092c\u093e\u0939\u0930\u0940 \u0939\u093f\u0938\u094d\u0938\u093e \u091b\u094b\u0921\u093c \u0926\u0947\u0924\u0940 \u0939\u0948\u0902. \u0910\u0938\u093e \u0915\u0930\u0928\u0947 \u0938\u0947 \u0926\u0942\u0938\u0930\u0940 \u0906\u092e \u092e\u0915\u0921\u093c\u093f\u092f\u094b\u0902 \u0915\u0940 \u0924\u0930\u0939 \u0939\u092e\u093e\u0930\u0947 \u0936\u0930\u0940\u0930 \u0915\u093e \u0935\u093f\u0915\u093e\u0938 \u0939\u094b\u0924\u093e \u0939\u0948.","Treat":"\u091f\u094d\u0930\u0940\u091f","Trick":"\u091f\u094d\u0930\u093f\u0915","Trick or Treat?":"\u091f\u094d\u0930\u093f\u0915 \u092f\u093e \u091f\u094d\u0930\u0940\u091f?","Wolf Fact":"\u0939\u092e \u092d\u0947\u0921\u093c\u093f\u090f \u0938\u093f\u0930\u094d\u092b\u093c \u0917\u0941\u0930\u094d\u0930\u093e\u0915\u0930 \u092c\u093e\u0924 \u0928\u0939\u0940\u0902 \u0915\u0930\u0924\u0947. \u0936\u0930\u0940\u0930 \u0914\u0930 \u091a\u0947\u0939\u0930\u0947 \u0915\u0947 \u0939\u093e\u0935-\u092d\u093e\u0935 \u0915\u0947 \u091c\u093c\u0930\u093f\u090f \u092c\u093e\u0924 \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u092d\u0940 \u0939\u092e \u092e\u093e\u0939\u093f\u0930 \u0939\u0948\u0902."}