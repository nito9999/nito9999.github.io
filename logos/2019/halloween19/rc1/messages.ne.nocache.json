{"Bat Fact":"\u092e \u091c\u0938\u094d\u0924\u093e \u091a\u092e\u0947\u0930\u094b \u0909\u0921\u094d\u0928\u0947 \u092e\u093e\u0924\u094d\u0930 \u0928\u092d\u0908 \u0939\u093e\u092e\u0940 \u091c\u092e\u093f\u0928\u092e\u093e \u0939\u093f\u0921\u094d\u0928\u0947, \u0909\u092b\u094d\u0930\u093f\u0928\u0947 \u0930 \u0926\u094c\u0921\u094d\u0928\u0947 \u0915\u092e \u0917\u0930\u094d\u091b\u094c\u0901\u0964","Black Cat Fact":"\u0905\u0928\u094d\u092f \u0920\u0941\u0932\u093e \u092c\u093f\u0930\u093e\u0932\u094b\u0915\u094b \u0935\u093f\u092a\u0930\u093f\u0924 \u0939\u093e\u092e\u0940 \u091c\u0917\u0941\u0906\u0930\u0939\u0930\u0942 \u092a\u094c\u0901\u0921\u0940 \u0916\u0947\u0932\u094d\u0928 \u0930 \u092a\u093e\u0928\u0940\u092e\u093e \u0938\u092e\u092f \u092c\u093f\u0924\u093e\u0909\u0928 \u0930\u0942\u091a\u093e\u0909\u091b\u094c\u0901\u0964","End Screen":"\u0939\u0932\u094b\u0935\u093f\u0928\u0915\u094b \u0936\u0941\u092d\u0915\u093e\u092e\u0928\u093e!(\u0930 \u092b\u094d\u0932\u094d\u0938 \u0917\u0930\u094d\u0928 \u0928\u092c\u093f\u0930\u094d\u0938\u0928\u0941\u0939\u094b\u0932\u093e!)","Happy Halloween!":"\u0939\u0932\u094b\u0935\u093f\u0928\u0915\u094b \u0936\u0941\u092d\u0915\u093e\u092e\u0928\u093e!","Octopus Fact":"\u092e\u0938\u0901\u0917 \u0924\u0940\u0928 \u0935\u091f\u093e \u092e\u0941\u091f\u0941 \u091b\u0928\u094d!\u092e \u092a\u094c\u0921\u0940 \u0916\u0947\u0932\u094d\u0926\u093e \u0926\u0941\u0908 \u0935\u091f\u093e \u092e\u0941\u091f\u0941\u0932\u0947 \u092e\u093e\u0924\u094d\u0930 \u0938\u093e\u091e\u094d\u091a\u093e\u0930 \u0917\u0930\u094d\u0928\u0947 \u092d\u090f\u0915\u093e\u0932\u0947 \u092e \u0918\u093f\u0930\u094d\u0938\u0928 \u0930\u0941\u091a\u093e\u0909\u0901\u091b\u0941\u0901\u0964","Option":"\u091b\u0928\u094c\u091f \u0917\u0930\u094d\u0928\u0941\u0939\u094b\u0938\u094d!","Owl Fact":"\u092e\u0947\u0930\u094b \u0916\u0941\u091f\u094d\u091f\u093e\u0915\u093e \u092d\u0941\u0935\u093e\u0932\u0947 \u092e\u0932\u093e\u0908 \u092c\u093e\u0915\u