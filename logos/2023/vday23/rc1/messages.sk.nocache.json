)]}'
{"btn_about":"Sviatočné logo na Googli","btn_back":"Späť","btn_close":"Zavrieť","btn_combine":"Skombinovať!","btn_complete":"Vybrať ďalší prvok","btn_gallery":"Moje väzby","btn_got_it":"Dobre.","btn_home":"Domov","btn_info":"Zobraziť úplný profil","btn_keep_swiping":"Ďalej poťahovať","btn_like":"Páči sa","btn_more":"Viac sviatočných log","btn_more_query":"Sviatočné logá na Googli","btn_pass":"Preskočiť","btn_q1_a":"Slobodná duša","btn_q1_b":"Nechám sa unášať prúdom","btn_q1_c":"Robustný/-á a uzemnený/-á","btn_q2_a":"Som všade, nemôžete sa ma zbaviť","btn_q2_b":"Nie je ťažké ma nájsť","btn_q2_c":"Nedá sa ku mne dostať","btn_q3_a":"Nikdy v živote som sa nedotkol/-la činky","btn_q3_b":"Občas zdvíham železo ([Fe])","btn_q3_c":"Milujem SVALY","btn_q4_a":"Útulná chata","btn_q4_b":"Priestranný dom","btn_q4_c":"Veľkolepé sídlo","btn_q5_a":"Nikto mi neodolá","btn_q5_b":"Som ozdobou večierka","btn_q5_c":"Mám úzky okruh priateľov","btn_quiz":"Vyplniť kvíz","btn_search":"Hľadať","btn_select":"Vybrať prvok","btn_share":"Zdieľať","btn_start":"Začať vytvárať väzby","chip_about_01":"Plyn","chip_about_02":"Najzastúpenejší","chip_about_03":"Najľahší","chip_about_04":"Bezfarebný","chip_about_05":"Siedmy najzastúpenejší","chip_about_06":"Pentel","chip_about_07":"Tretí najzastúpenejší","chip_about_08":"Chalkogén","chip_about_09":"Halogén","chip_about_10":"Bledožltý","chip_about_11":"Žltozelený","chip_about_12":"Kvapalina","chip_about_13":"Červenohnedý","chip_about_14":"Pevná látka","chip_about_15":"Alkalický kov","chip_about_16":"Striebro","chip_about_17":"Vzácny plyn","chip_about_18":"Čierny","chip_interest_01":"Hvezdárstvo","chip_interest_02":"Rakety","chip_interest_03":"Lety balónom","chip_interest_04":"Záhradkárstvo","chip_interest_05":"Potravinárske obaly","chip_interest_06":"Kryogenika","chip_interest_07":"Cvičenie","chip_interest_08":"Ozónová vrstva","chip_interest_09":"Mrazené pochúťky","chip_interest_10":"Zubné lekárstvo","chip_interest_11":"Klimatizácia","chip_interest_12":"Bazény","chip_interest_13":"Jedlo","chip_interest_14":"Čistenie","chip_interest_15":"Slané pochúťky","chip_interest_16":"Fotografovanie","chip_interest_17":"Požiarna ochrana","chip_interest_18":"Farmárstvo","chip_interest_19":"Výživa","chip_interest_20":"Medicína","chip_interest_21":"Potlač","chip_interest_22":"Teplé osvetlenie","chip_interest_23":"Kulturistika","chip_interest_24":"Zváranie","chip_interest_25":"Laserové svetelné šou","chip_interest_26":"Technológie","header_about":"O mne","header_bond":"Vytvorili ste väzbu!","header_bond_arf":"Fluorid argónu","header_bond_br2":"Diatomický bróm","header_bond_cl2":"Plynný chlór","header_bond_f2":"Plynný fluór","header_bond_h2":"Plynný vodík","header_bond_hcl":"Chlorovodík","header_bond_hf":"Fluorovodík","header_bond_hi":"Jodovodík","header_bond_i2":"Diatomický jód","header_bond_ibr":"Bromid jódny","header_bond_n2":"Plynný dusík","header_bond_nabr":"Bromid sodný","header_bond_nacl":"Chlorid sodný","header_bond_naf":"Fluorid sodný","header_bond_nai":"Jodid sodný","header_bond_nf":"Fluorid dusný","header_bond_no":"Oxid dusnatý","header_bond_o2":"Plynný kyslík","header_complete":"Skvelá práca!","header_diatomic":"Vytváranie diatomických väzieb na Valentína","header_gallery_complete":"Gratulujeme, získali ste všetkých 18!","header_gallery_incomplete":"Získajte všetkých 18, aby ste odhalili obrázok","header_interests":"Záujmy","header_loader":"Načítava sa","header_mystery":"Tajomná väzba","header_pick":"Vyberte kompatibilný prvok","header_q1":"Ako by ste sa opísali?","header_q2":"Je možné si vás ľahko získať?","header_q3":"Zdvíhate činky?","header_q4":"Aký je váš vysnívaný domov?","header_q5":"Priťahujete ostatných?","header_quiz":"Osobnostný kvíz prvkov","header_select":"Vyberte si prvok","header_splash":"Spojte sa s ostatnými prvkami","header_tap":"Pridržaním skombinujete","label_ar":"Argón","label_bond_arf":"Postavičky argónu a fluóru tráviace čas v kaviarni s mačkami. Argón sa hrá s laserovým ukazovátkom, zatiaľ čo fluór sedí s mačkou v lone a mačky sú roztrúsené po celej kaviarni.","label_bond_br2":"Ide o bankovú lúpež, pri ktorej dve postavičky brómu kradnú zlaté tehličky z bankového trezoru.","label_bond_cl2":"Chvíľa medzi dvoma postavičkami chlóru, pričom jedna sa červená, keď jej tá druhá pomáha s papiermi, ktoré jej spadli na zem.","label_bond_f2":"Dve postavičky fluóru na zmrzline, pričom jednej vypadla zmrzlina, ale nebojte sa, druhá sa chce podeliť.","label_bond_h2":"Dve postavičky vodíka držiace sa za ruky a sledujúce pár padajúcich hviezd na oblohe.","label_bond_hcl":"Postavičky vodíka a chlóru spolu romanticky stolujú v reštaurácii.","label_bond_hf":"Postavičky vodíka a fluóru umiestnené vedľa seba na doske plošných spojov ako počítačové čipy, pričom obvody medzi nimi tvoria srdce.","label_bond_hi":"Postavička vodíka v bejzbalovej čiapke s kyticou kvetov na návšteve v nemocnici u postavičky jódu s obväzom na hlave.","label_bond_i2":"Dve postavičky jódu pri chytaní rýb na móle, pričom jedna pomáha druhej obviazať poranenú nohu a pritom im uniká ryba.","label_bond_ibr":"Červenajúca sa postavička jódu, keď jej postavička brómu v bejzbalovej čiapke podáva kvetinu z kytice.","label_bond_n2":"Záber zhora na dve postavičky dusíka, ktoré spolu púšťajú šarkanov v tvare srdca na trávnatom poli.","label_bond_nabr":"Postavičky sodíka a bromidu relaxujúce vo vírivke na zimnej chate, zatiaľ čo ich pes behá na pozadí.","label_bond_nacl":"Postavičky sodíka a chlóru, ktoré doma pozerajú film, delia sa o pukance a sú obklopené ďalším občerstvením.","label_bond_naf":"Postavičky sodíka a fluóru, ktoré spolu pijú nápoj, každá s ohnutou slamkou v tvare srdca.","label_bond_nai":"Postavičky sodíka a jódu na spoločnom pikniku na trávnatom poli pri vodnej nádrži, pričom jód sa chystá nakŕmiť sodík čipsom.","label_bond_nf":"Scéna pri táboráku s postavičkami dusíka a fluóru, ktoré spolu sedia na polenách pri ohni.","label_bond_no":"Postavička dusíka zdieľajúca dáždnik s postavičkou kyslíka počas búrky pri prechádzaní cez ulicu.","label_bond_o2":"Dve postavičky kyslíka na turistickom výlete pózujúce s rukami okolo pliec pred horou v diaľke. Jedna postavička má vychádzkovú palicu a slnečné okuliare, druhá čiapku beanie, obe majú šatku.","label_br":"Bróm","label_carousel_indicator":"[X]. obrázok z 3","label_cl":"Chlór","label_f":"Fluór","label_h":"Vodík","label_header_logo":"Logo Googlu","label_i":"Jód","label_logo_big":"Logo chémie [CuPd]","label_mystery":"Tajomný prvok","label_n":"Dusík","label_na":"Sodík","label_o":"Kyslík","label_pic_ar_1":"Profilová fotka zvárajúcej postavičky argónu so zváračskou maskou na hlave. Pritom lietajú iskry z kovovej sochy mozaiky srdca.","label_pic_ar_2":"Profilová fotka postavičky argónu s telefónom a mačkou schúlenou v lone.","label_pic_ar_3":"Profilová fotka postavičky argónu so slúchadlami hrajúcej online hry pomocou myši a klávesnice s mačkou sediacou v jej lone.","label_pic_br_1":"Profilová fotka postavičky brómu sediacej na prednom nárazníku hasičského auta v hasičskej prilbe.","label_pic_br_2":"Veľmi emotívny pochmúrny čiernobiely detailný záber kvetu s rosou.","label_pic_br_3":"Profilová fotka postavičky brómu, ktorá si robí selfie a jej pes pchá hlavu do popredia.","label_pic_cl_1":"Profilová fotka postavičky chlóru ležiacej na boku na lehátku pri bazéne so slnečnými okuliarmi na hlave.","label_pic_cl_2":"Profilová fotka postavičky chlóru hrdo ukazujúcej misu s údeninami.","label_pic_cl_3":"Profilová fotka postavičky chlóru, ktorá si robí selfie pred trblietajúcimi sa policami plnými čistiacich prostriedkov.","label_pic_f_1":"Profilový obrázok postavičky fluóru v zubárskom plášti sediacej za stolom s vyloženými nohami pred stenou plnou diplomov.","label_pic_f_2":"Profilová fotka postavičky fluóru v pánskom obleku sediacej za stolom s vyloženými nohami pred stenou plnou diplomov.","label_pic_f_3":"Profilová fotka postavičky fluóru sediacej pred klimatizáciou spolu so psom užívajúcim si chladný vánok.","label_pic_h_1":"Profilová fotka postavičky vodíka mávajúcej pri lete teplovzdušným balónom.","label_pic_h_2":"Profilová fotka postavičky vodíka, ktorá v diaľke pozoruje štart rakety a drží ruku tak, ako keby ju chcela trocha postrčiť.","label_pic_h_3":"Profilová fotka postavičky vodíka, ktorá pozoruje hviezdy teleskopom.","label_pic_i_1":"Profilová fotka postavičky jódu stojacej na móle, ktorá hrdo drží práve ulovenú veľkú rybu.","label_pic_i_2":"Profilová fotka pečiatkujúcej postavičky jódu, ktorá práve nanáša atrament na pečiatku.","label_pic_i_3":"Záber zhora na misku s chutnou polievkou ramen.","label_pic_n_1":"Profilová fotka postavičky dusíka v skleníku obklopenom rastlinami.","label_pic_n_2":"Profilová fotka postavičky dusíka so šálom, ktorá robí v snehu anjelikov.","label_pic_n_3":"Profilová fotka postavičky dusíka ukazujúca krabičku s obedom, ktorý úhľadne a s láskou zabalila.","label_pic_na_1":"Profilová fotka postavičky sodíka, ktorá si robí selfie v posilňovni a ukazuje svoje brušné svaly pri cvičení s činkou","label_pic_na_2":"Skupinový záber postavičky sodíka s priateľmi.","label_pic_na_3":"Profilový fotka útulnej zimnej scény z pohľadu postavičky sodíka so snehom za oknom, sviečkou a horúcim hrnčekom. Sodík má preložené nohy a knihu v lone.","label_pic_o_1":"Profilová fotka postavičky kyslíka s bejzbalovou čiapkou na hlave, ktorá beží na pretekoch.","label_pic_o_2":"Profilová fotka postavičky kyslíka s trblietajúcou sa ružičkou v ústach a prstami naznačujúcimi pištole.","label_pic_o_3":"Profilová fotka postavičky kyslíka kľačiacej pri práci v záhrade.","label_progress_quiz":"[X]. otázka z 5","label_swipe":"Potiahnutie rukou doprava k tlačidlu so srdiečkom na označenie páči sa a doľava k tlačidlu X na preskočenie","label_unknown":"Neznáma väzba","share_modal_button_close":"Zavrieť","share_modal_button_copied":"Odkaz bol skopírovaný","share_modal_button_facebook":"Zdieľať cez Facebook","share_modal_button_twitter":"Zdieľať cez X","share_modal_click_link":"Skopírovať odkaz","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"Zdieľať","share_text":"Máte dobrú chémiu? Potiahnite doprava a spojte sa s ostatnými prvkami v dnešnom valentínskom #GoogleDoodle s periodickou tabuľkou.","span_bond":"S prvkom [%s] máte dobrú chémiu","span_bond_arf":"Pri dostatočnej energii a tlaku je táto väzba laserová. Lasery s prvkom [ArF] sa používajú v očnej chirurgii, aby ste mali ostrý zrak.","span_bond_br2":"Našli ste [Au] (zlato)! [Br<2>] sa používa pri ťažbe zlata ako alternatívna metóda rozpúšťania zlata v rude, označovaná aj ako brómové lúhovanie.","span_bond_cl2":"[Cl<2>] dokáže rozložiť lignín v drevovine, čo je zlúčenina, ktorá dáva drevu hnedú farbu. Potom nám to umožní použiť bielu drevovinu na výrobu papiera.","span_bond_f2":"[F<2>] sa používa pri výrobe fluórovaných uhľovodíkov, čo sú chladivá, ktoré je možné používať na chladenie potravín. Ideálne na vytváranie väzieb pri zmrzline.","span_bond_h2":"Tieto atómy sú veľmi šťastné. [H2] je ľahší ako vzduch, takže nech vás neprekvapí, keď vás zmietne z nôh.","span_bond_hcl":"Táto molekula je pikantná! [HCl] je silná kyselina, ktorá nám pomáha tráviť potravu. Ideálne na zblíženie sa pri večeri.","span_bond_hf":"Toto duo leptá sklo a vyrezáva vzory do kremíkových doštičiek používaných v počítačových čipoch.","span_bond_hi":"Pozdravte [HI]! Čistota je kľúčová najmä v nemocniciach, kde táto molekula pomáha dezinfikovať lekárske nástroje.","span_bond_i2":"[I<2>] je skvelé antiseptikum a spolu s ďalšou chemikáliou nazývanou povidón pomáha udržiavať rany a škrabance bez baktérií.","span_bond_ibr":"[IBr] je priateľom analytického chemika. Používa sa v reakciách meniacich farbu na určenie koncentrácie určitej chemikálie v procese nazývanom jódometrická titrácia.","span_bond_n2":"Poďme púšťať šarkanov! [N<2>] tvorí 78 % zemskej atmosféry. Pokiaľ ide o vzťahy, táto molekula s trojitou väzbou má bezkonkurenčné spojenie. To sú teda ciele sebalásky!","span_bond_nabr":"Je tu horúco alebo len v tejto vírivke? [NaBr] radi udržiavajú vodu peknú a čistú, aby mohli kvalitne relaxovať.","span_bond_nacl":"Protiklady sa priťahujú. Ióny prvkov [Na+] a [Cl-] sa spájajú, aby splnili všetky naše sny o slanom občerstvení.","span_bond_naf":"Vďaka prvku [NaF] sa môžete blysnúť perleťovým chrupom. Táto molekula sa pridáva do pitnej vody a zubnej pasty na udržanie zdravých zubov.","span_bond_nai":"Pozor na nedostatok jódu. [NaI] je tu, aby bola vaša štítna žľaza spokojná. Spolu so všetkými potravinami bohatými na jód podporujú doplnky NaI zdravý metabolizmus.","span_bond_nf":"Niektoré väzby netrvajú večne. Za vhodných podmienok sa formuje [NF] a vydáva charakteristickú žiaru, ale po skončení vzrušenia sa rýchlo oddelí.","span_bond_no":"Tieto dva prvky prichádzajú spolu v blesku! [NO] sa tvorí pri rýchlom zahrievaní a ochladzovaní plynov v blesku. Síce to neprospieva kvalite ovzdušia, ale je to dosť vzrušujúce.","span_bond_o2":"Táto molekula je potrebná na dosiahnutie maximálneho výkonu. Horolezci dosahujú najvyššie nadmorské výšky pomocou nádob s prvkom [O<2>].","span_complete":"Získali ste všetky dostupné väzby pre [%s].","span_diatomic":"Diatomické molekuly sú tvorené väzbou medzi dvoma atómami. Niekedy je to väzba medzi tým istým prvkom, napríklad [H<2>] (plynný vodík), a niekedy sú to dva rôzne prvky, napríklad [HCl] (chlorovodík).","span_missed_notification":"Ojoj, mali ste dobrú chémiu.","span_no_match_notification":"Ľutujeme, nie je to zhoda","span_profile_ar":"Stabilita je moja silný stránka a teším sa z času osamote. Keď hovorím, že hľadám svoj náprotivok, myslím to naozaj vážne. Potrebujem veľa elektriny, aby to so mnou zaiskrilo, ale aj tak hľadám len chvíľkové pobavenie, nie dlhodobý vzťah.","span_profile_br":"Mám veľa tvárí! Často sa prejavujem nestálosťou, ale osamote sa nechám unášať prúdom. Mám vášeň pre fotografovanie a som aj hasič. To je celkom super, nie?","span_profile_cl":"Ak si potrpíte na čistotu, potiahnite doprava. Mám veľmi reaktívnu povahu, takže je pravdepodobné, že si určite nájdeme niečo, čo nás spojí, ale pozor: dobrého môže byť priveľa (najlepšie je si ma užívať v malých dávkach).","span_profile_f":"Vynikám mimoriadnou príťažlivosťou. Keď už hovoríme o príťažlivosti, fandím zdravému úsmevu. Moja energia a asertivita mi pomáhajú vyniknúť a nadväzovať nové spojenia s ostatnými.","span_profile_h":"Chcem byť vašou jednotkou. Nič nekomplikujem, ale som nevyhnutný pre život. Vlastne mi povedali, že som ten najvšestrannejší atóm, aký existuje. Môžete ma nájsť v skupine (alkalických) metalistov alebo takmer kdekoľvek vo vesmíre.","span_profile_i":"Som pevnosť, spoľahlivosť a uzemnenie. Mám talent na zvýrazňovanie dôležitých vecí, pretože všetko vidím vo vysokom kontraste, a som veľký fanúšik poriadku.","span_profile_n":"Tvorím 78 % vetra pod vašimi krídlami. Ak hľadáte spriazenú osobu, ktorá by sa s vami starala o rastliny, ste na správnom mieste. Môžete mi veriť, že si zachovám pokoj a rozvahu, ale nebojte sa, nikdy sa na vás nevykašlem.","span_profile_na":"Nadväzujem sériové väzby. Neznášam samotu, ale to nevadí, pretože vy nemôžete žiť bezo mňa (úprimne, ani nikto iný). Veľa cvičím a posilujem. Napriek reaktivite mám záľubu aj v budovaní zmysluplných vzťahov.","span_profile_notification":"Dobrý deň, [%s]. Začnite vytvárať väzby a nájdite si partnera.","span_profile_o":"Priznajte si, že ma potrebujete. Som vzduch, ktorý dýchate. Prinášam svojmu okoliu závan čerstvého vzduchu. Mám pozoruhodnú schopnosť prispôsobovať sa a podporovať rast, čím zabezpečujem rozkvet prostredia, v ktorom sa nachádzam.","span_q1":"Pri štandardnej teplote a tlaku existujú tri skupenstvá látok: plyny, kvapaliny a pevné látky.","span_q2":"Niektoré prvky, napríklad tie, ktoré sa nachádzajú vo hviezdach, sú vo vesmíre hojne zastúpené, zatiaľ čo iné sú veľmi vzácne a ťažko dostupné.","span_q3":"Atómová hmotnosť sa určuje sčítaním hmotností protónov, neutrónov a elektrónov atómu.","span_q4":"Pomyselná guľa priestoru, ktorú zaberá atóm, sa opisuje hodnotou nazývanou Van der Waalsov polomer.","span_q5":"Elektronegativita je tendencia atómu priťahovať zdieľané elektróny pri vytváraní chemickej väzby.","span_swipe":"Potiahnite doprava cez prvky, s ktorými by ste sa mohli zblížiť, a doľava, ak vás nezaujali."}