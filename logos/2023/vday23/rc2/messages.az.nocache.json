)]}'
{"btn_about":"Google Doodle haqqında","btn_back":"Geri","btn_close":"Bağlayın","btn_combine":"Gəlin birləşdirək!","btn_complete":"Başqa element seçin","btn_gallery":"Əlaqələrim","btn_got_it":"Anladım!","btn_home":"Əsas səhifə","btn_info":"Tam profilə baxın","btn_keep_swiping":"Sürüşdürməyə davam edin","btn_like":"Bəyənin","btn_more":"Digər Doodle'lar","btn_more_query":"Google Doodle'lar","btn_pass":"Giriş talonu","btn_q1_a":"Azad ruh","btn_q1_b":"Axınla gedin","btn_q1_c":"Möhkəm və əsaslı","btn_q2_a":"Mən hər yerdəyəm, məndən qurtula bilməzsiniz","btn_q2_b":"Məni tapmaq çox çətin deyil","btn_q2_c":"Mənə çatmaq mümkün deyil","btn_q3_a":"Həyatımda heç vaxt ağırlıq qaldırmamışam","btn_q3_b":"Hərdən dəmiri vururam ([Fe])","btn_q3_c":"Bütün ƏZƏLƏLƏR haqqındayam","btn_q4_a":"Rahat kottec","btn_q4_b":"Geniş ev","btn_q4_c":"Böyük malikanə","btn_q5_a":"Heç kim mənə müqavimət göstərə bilməz","btn_q5_b":"Parti adamıyam","btn_q5_c":"Sıx daxili çevrəm var","btn_quiz":"Kvizdə iştirak edin","btn_search":"Axtarın","btn_select":"Element seçin","btn_share":"Paylaşın","btn_start":"Əlaqə saxlamağa başlayın","chip_about_01":"Yanacaq","chip_about_02":"Ən çox yayılmış","chip_about_03":"Ən yüngül","chip_about_04":"Rəngsiz","chip_about_05":"7-ci ən çox yayılmış","chip_about_06":"Pnictogen","chip_about_07":"3-cü ən çox yayılmış","chip_about_08":"Kalkogen","chip_about_09":"Halogen","chip_about_10":"Solğun sarı","chip_about_11":"Sarımtıl yaşıl","chip_about_12":"Maye","chip_about_13":"Qırmızı qəhvəyi","chip_about_14":"Bərk","chip_about_15":"Qələvi metal","chip_about_16":"Gümüşü","chip_about_17":"Nəcib qazlar","chip_about_18":"Qara","chip_interest_01":"Ulduzları izləmə","chip_interest_02":"Raketlər","chip_interest_03":"Balon gəzintiləri","chip_interest_04":"Bağçılıq","chip_interest_05":"Qida qablaşdırması","chip_interest_06":"Kriogenlər","chip_interest_07":"Məşq","chip_interest_08":"Ozon təbəqəsi","chip_interest_09":"Dondurulmuş yeməklər","chip_interest_10":"Stomatologiya","chip_interest_11":"Kondisioner","chip_interest_12":"Üzgüçülük hovuzları","chip_interest_13":"Yemək","chip_interest_14":"Təmizləmə","chip_interest_15":"Duzlu qəlyanaltılar","chip_interest_16":"Fotoqrafiya","chip_interest_17":"Yanğın təhlükəsizliyi","chip_interest_18":"Ferma","chip_interest_19":"Qidalanma","chip_interest_20":"Tibb","chip_interest_21":"Çap istehsalı","chip_interest_22":"İsti işıqlandırma","chip_interest_23":"Bədən məşqi","chip_interest_24":"Qaynaq işləri","chip_interest_25":"Lazer işıq şouları","chip_interest_26":"Texnologiya","header_about":"Haqqımda","header_bond":"Bu əlaqədir!","header_bond_arf":"Arqon florid","header_bond_br2":"İki atomlu brom","header_bond_cl2":"Xlor qazı","header_bond_f2":"Flüor qazı","header_bond_h2":"Hidrogen qazı","header_bond_hcl":"Hidrogen xlorid","header_bond_hf":"Hidrogen flüorid","header_bond_hi":"Hidrogen yodid","header_bond_i2":"İki atomlu yod","header_bond_ibr":"Yod monobromid","header_bond_n2":"Azot qazı","header_bond_nabr":"Natrium bromid","header_bond_nacl":"Natrium xlor","header_bond_naf":"Natrium florid","header_bond_nai":"Natrium yodid","header_bond_nf":"Azot monoflorid","header_bond_no":"Azot oksidi","header_bond_o2":"Oksigen qazı","header_complete":"Afərin!","header_diatomic":"Sevgililər Günü üçün iki atomlu əlaqələr yaradılır","header_gallery_complete":"Təbriklər, 18 şəklin hamısını topladınız!","header_gallery_incomplete":"Şəkli aşkarlamaq üçün 18 şəklin hamısını toplayın","header_interests":"Maraqlar","header_loader":"Yüklənir","header_mystery":"Sirli əlaqə","header_pick":"Uyğun element seçin","header_q1":"Özünüzü necə təsvir edərdiniz?","header_q2":"Sizi tutmaq asandır?","header_q3":"Ağırlıq qaldırırsınız?","header_q4":"Xəyal etdiyiniz ev necədir?","header_q5":"Başqaları sizi cəlb edir?","header_quiz":"Element üzrə şəxsiyyət testi","header_select":"Element seçin","header_splash":"Həmkar elementlərlə əlaqə saxlayın","header_tap":"Birləşdirmək üçün toxunub saxlayın","label_ar":"Arqon","label_bond_arf":"Arqon və Flüor simvolları pişik kafesində əylənir, Arqon lazer göstərici ilə oynayır, ətrafında pişiklər olan Flüor isə qucağında pişiklə oturub.","label_bond_br2":"İki Brom simvolunun bank seyfindən qızıl külçələri ələ keçirməsi bank soyğunudur.","label_bond_cl2":"İki xlor simvolu arasında birinin qızardığı, digərinin isə yerə düşən kağızlarla kömək etdiyi an.","label_bond_f2":"İki Flüor personajı dondurma almaq üçün çölə çıxır, birinin dondurması düşüb, amma narahat olmayın, digəri bölüşməyə hazırdır.","label_bond_h2":"İki Hidrogen simvolu səmada bir cüt ulduzun keçməsini seyr edərkən əl-ələ tutur.","label_bond_hcl":"Hidrogen və Xlor simvolları restoranda birlikdə romantik yemək yeyirlər.","label_bond_hf":"Hidrogen və Flüor simvolları kompüter çipləri kimi bir elektrik panelində yan-yana yerləşdirilir və aralarındakı çevrələr ürək əmələ gətirir.","label_bond_hi":"Beysbol papağı taxan Hidrogen simvolu gükl buketi ilə xəstəxanada başında sarğı olan Yod simvolunu ziyarət edir.","label_bond_i2":"İki Yod simvolu limanda balıq tutur, balıq qaçarkən biri digərinin yaralı ayağını sarımağa kömək edir.","label_bond_ibr":"Beysbol papağı taxan Brom simvolu buketindən çiçək uzatdığında Yod simvolu qızarır.","label_bond_n2":"Otlu sahədə ürək formalı çərpələnglər uçuran iki Azot simvolunun yuxarıdan görünüşü.","label_bond_nabr":"Natrium və Brom simvolları qış kabinəsində qaynar boruda dincələrkən itləri arxa fonda yaxınlaşır.","label_bond_nacl":"Natrium və Xlor simvolları evdə digər qəlyanaltıların əhatəsində birlikdə film izləyir, popkorn paylaşır.","label_bond_naf":"Natrium və Flüor simvolları hər biri ürək formalı əyilmiş plastik çöplərlə içki içir.","label_bond_nai":"Yod Natriumu çiplə qidalandırarkən Natrium və Yod simvolları su hövzəsinin yanında otlu sahədə birlikdə piknik edirlər.","label_bond_nf":"Azot və Flüor simvollarının odun yanında kötüklərdə oturduğu düşərgə tonqalı səhnəsi.","label_bond_no":"Azot simvolu birlikdə küçəni keçərkən yağış fırtınası zamanı Oksigen simvolu ilə çətirini paylaşır.","label_bond_o2":"İki Oksigen simvolu birlikdə gəzintiyə çıxır, uzaqda bir dağla bir-birinin çiyinlərini qucaqlayır, birinin başında günəş eynəyi əlində gəzinti çubuğu, digərinin isə balıqçı papağı var və hər ikisi şərf taxır.","label_br":"Brom","label_carousel_indicator":"[X]/3 şəkil","label_cl":"Xlor","label_f":"Flüor","label_h":"Hidrogen","label_header_logo":"Google loqosu","label_i":"Yod","label_logo_big":"[CuPd] kimya loqosu","label_mystery":"Sirli element","label_n":"Azot","label_na":"Natrium","label_o":"Oksigen","label_pic_ar_1":"Qaynaq işləri edərkən qıvılcımları yamaqlı metal ürək heykəli üzərinə uçan qaynaq maskalı Arqon simvolunun profil şəkli.","label_pic_ar_2":"Qucağında qıvrılmış şəkildə yatan pişiyi ilə telefonunda Arqon simvolunun profil şəkli.","label_pic_ar_3":"Pişiyi qucağında oturarkən maus və klaviatura ilə onlayn oyun oynayan qulaqlıq taxan Arqon simvolunun profil şəkli.","label_pic_br_1":"Yanğınsöndürən papağı taxmış yanğınsöndürən maşınının ön bamperində oturan Brom simvolunun profil şəkli.","label_pic_br_2":"Çox emosional olan şehli çiçəyin yaxından çəkilmiş qara və ağ tutqun fotosu.","label_pic_br_3":"İtinin başını ön plana çıxarmaqla selfi çəkdirən Bromun profil şəkli.","label_pic_cl_1":"Başında gün eynəyi ilə hovuz kənarında şezlongda yan üstə uzanan Xlor simvolunun profil şəkli.","label_pic_cl_2":"Qürurla ət kulinariyası lövhəsini göstərən Xlor simvolunun profil şəkli.","label_pic_cl_3":"Təmizləmə məhsulları ilə dolu parıldayan rəflərin qarşısında selfi çəkən Xlor simvolunun profil şəkli.","label_pic_f_1":"Stomatoloq paltosunda, ayaqlarını yuxarı qaldıraraq masa arxasında oturan, arxasındakı divar sertifikatlarla örtülmüş Flüor simvolunun profil şəkli.","label_pic_f_2":"İşgüzar kostyumda, ayaqlarını yuxarı qaldıraraq masa arxasında oturan, arxasındakı divar sertifikatlarla örtülmüş Flüor simvolunun profil şəkli.","label_pic_f_3":"Sərin mehdən zövq alan iti ilə kondisioner qurğusunun qarşısında oturan Flüor simvolunun profil şəkli.","label_pic_h_1":"İsti hava şarına minərkən yellənən Hidrogen simvolunun profil şəkli.","label_pic_h_2":"Uzaqdan raket buraxılışını izləyən və onu yüngülcə çimdikləmək üçün əlini qaldıran Hidrogen simvolunun profil şəkli.","label_pic_h_3":"Teleskopla ulduzlara baxan Hidrogen simvolunun profil şəkli.","label_pic_i_1":"Yenicə tutduqları balığı qürurla tutaraq dokda dayanan Yod simvolunun profil şəkli, bu, böyük şəkildir.","label_pic_i_2":"Möhürdə mürəkkəb yuvarlayarkən izlər yaradan Yod simvolunun profil şəkli.","label_pic_i_3":"Ramen qabının yuxarıdan fotosu, ləzzətli.","label_pic_n_1":"Bitkilərlə əhatə olunmuş istixanada Azot simvolunun profil şəkli.","label_pic_n_2":"Yerdə qardan mələklər düzəldərək şərf taxan Azot simvolunun profil şəkli.","label_pic_n_3":"Səliqəli və sevgi ilə qablaşdırdıqları nahar qutusunu göstərən Azot simvolunun profil şəkli.","label_pic_na_1":"Dambl hərəkətləri edərkən qarın əzələrini göstərməklə idman zalı selfisi çəkdirən Natrium simvolunun profil şəkli.","label_pic_na_2":"Natrium simvolunun dostları ilə qrup şəkli.","label_pic_na_3":"Natrium simvolunun nöqteyi-nəzərindən pəncərədən yağan qar, şam, buxarlanan fincan və ayaqları yuxarı qaldırılmış və qucağında kitab olan Natriumun rahat qış mənzərəsinin profil şəkli.","label_pic_o_1":"Beysbol papağı taxan və yarışda qaçan Oxygen simvolunun profil şəkli.","label_pic_o_2":"Ağzında parıldayan qızılgül tutan və barmaqları ilə atəş açan Oksigen simvolunun profil şəkli.","label_pic_o_3":"Bağçalarında işləyərkən diz çökən Oksigen simvolunun profil şəkli.","label_progress_quiz":"[X]/5 sual","label_swipe":"Bəyənmək üçün əllə sağa ürək düyməsinə, keçmək üçün isə X düyməsinə doğru sola sürüşdürün","label_unknown":"Naməlum əlaqə","share_modal_button_close":"Bağlayın","share_modal_button_copied":"Keçid kopyalandı","share_modal_button_facebook":"Facebook vasitəsilə paylaşın","share_modal_button_twitter":"X vasitəsilə paylaşın","share_modal_click_link":"Keçidi kopyalayın","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"Paylaşın","share_text":"Yaxşı kimyanız var? Bugünkü dövri cədvəllə dəstəklənən Sevgililər Günü üzrə #GoogleDoodle'dakı həmkarlarınızla əlaqə saxlamaq üçün sağa sürüşdürün.","span_bond":"Siz və [%s] yaxşı kimyaya sahibsiniz","span_bond_arf":"Kifayət qədər enerji və təzyiqlə bu əlaqə lazerə fokuslanır. 20/20 görmə qabiliyyətini saxlamaq məqsədilə göz əməliyyatı üçün [ArF] lazerlərdən istifadə edilə bilər.","span_bond_br2":"[Au] (qızıl) qazandınız! [Br<2>] qızıl mədənlərində filizdə olan qızılı həll etmək üçün alternativ metod kimi istifadə olunur, buna bromun yuyulması da deyilir.","span_bond_cl2":"[Cl<2>] ağaca qəhvəyi rəngi verən birləşmə ilə odun qabığındakı liqnini sındıra və kağız hazırlamaq üçün ağ qabıqdan istifadə etməyimizə imkan verə bilər.","span_bond_f2":"[F<2>] qidaları soyuq saxlamaq üçün istifadə edilə bilən soyuducu maddələr olan flüorokarbonların istehsalında istifadə olunur. Dondurmanın üzərinə yapışdırmaq üçün idealdır.","span_bond_h2":"Bu atomlar 9-cu buluddadır. [H2] havadan yüngüldür, ona görə də ayağınızın yerdən kəsilməsinə təəccüblənməyin.","span_bond_hcl":"Bu molekul ədviyyatlıdır! [HCl] qida həzmimizə kömək edən güclü turşudur. Nahar zamanı ünsiyyət üçün idealdır.","span_bond_hf":"Bu şüşə qravüra ikilisi kompüter çipləri üçün istifadə olunan silikon lövhələrə naxışlar oymaqla məşğuldur.","span_bond_hi":"[HI] simvoluna salam deyin! Xüsusilə bu molekulun tibbi alətləri dezinfeksiya etməyə kömək etdiyi xəstəxanalarda təmizlik çox vacibdir.","span_bond_i2":"[I<2>] əla antiseptikdir və povidon adlı başqa bir kimyəvi maddə ilə birlikdə kəsikləri və cızıqları mikrobsuz saxlamağa kömək edir.","span_bond_ibr":"[IBr] analitik kimyaçının dostudur. İodometrik titrləmə adlanan prosesdə müəyyən kimyəvi maddənin konsentrasiyasını müəyyən etmək üçün rəng dəyişmə reaksiyalarında istifadə olunur.","span_bond_n2":"Çərpələng uçuraq! [N<2>] Yer atmosferinin 78%-ni təşkil edir. Münasibətlərə gəldikdə, bu üçqat əlaqəli molekulun bənzərsiz bir əlaqəsi var. Özünü sevmə məqsədləri haqqında danışın!","span_bond_nabr":"Bura istidir, yoxsa sadəcə bu vannadır? Keyfiyyətli istirahət edə bilmələri üçün [NaBr] suyu gözəl və təmiz saxlamağı sevir.","span_bond_nacl":"Əks qütblər bir-birini cəzb edir. [Na+] və [Cl-] ionları bütün duzlu qəlyanaltı arzularımızı gerçəkləşdirmək üçün birləşir.","span_bond_naf":"[NaF] sayəsində mirvari ağlarını parlaq edə bilərsiniz Molekul dişlərinizi sağlam saxlamaq üçün içməli suya və diş pastasına əlavə edilir.","span_bond_nai":"Yod çatışmazlığına diqqət yetirin, [NaI] tiroidinizi xoşbəxt saxlamaq üçün var. Bütün yodla zəngin qidalarla yanaşı NaI əlavələri sağlam maddələr mübadiləsini dəstəkləyir.","span_bond_nf":"Bəzi əlaqələr əbədi qalmır. Düzgün şəraitdə [NF] xarakterik parıltı verərək əmələ gəlir, lakin həyəcan bitdikdən sonra tez ayrılır.","span_bond_no":"Bu ikisi bir ildırım çaxmasında bir araya gəlir! İldırımda qazlar sürətlə qızıb soyuduqca [NO] əmələ gəlir. Hava keyfiyyəti üçün əla deyil, lakin yenə də olduqca həyəcanlıdır.","span_bond_o2":"Bu molekul pik performans üçün lazımdır. Alpinistlər [O<2>] rezervuarlarının köməyi ilə ən yüksəkliklərə çatırlar.","span_complete":"[%s] üçün bütün mövcud əlaqələri topladınız.","span_diatomic":"İki atomlu molekullar iki atom arasındakı əlaqədən əmələ gəlir. Bəzən [H<2>] (hidrogen qazı) kimi eyni element arasında əlaqə, bəzən də [HCl] (hidrogen xlorid) kimi iki fərqli elementdir.","span_missed_notification":"Ups, yaxşı kimyanız var idi.","span_no_match_notification":"Təəssüf ki, uyğun deyil","span_profile_ar":"Çox stabiləm və təklikdə keçirdiyim vaxtdan zövq alıram. Birini axtarıram deyəndə, həqiqətən bunu nəzərdə tuturam. Qığılcımların uçduğunu hiss etmək mənim üçün çoxlu elektrik enerjisi tələb edir, amma buna baxmayaraq burada uzun müddət deyil, yaxşı vaxt keçirirəm.","span_profile_br":"Ətrafımda çoxlu sayda insan var! Olduqca dəyişkən ola bilərəm, amma tək olanda axınla getməyi xoşlayıram. Fotoqrafiyaya həvəsim var və həm də yanğınsöndürənəm. Bu olduqca gözəldir, elə deyil?","span_profile_cl":"Təmizliyə həvəsiniz varsa sağa sürüşdürün. Çox reaktiv xasiyyətim var, ona görə də çox güman ki, bir-birimizlə əlaqə saxlayacaq bir şey tapacağıq, ancaq diqqətli olun: çox yaxşı bir şeyə sahib ola bilərsiniz (ən çox aşağı dozalarda zövq alıram).","span_profile_f":"Hər kəs məni son dərəcə cəlbedici hesab edir. Cazibədarlıqdan söz düşmüşkən, sağlam təbəssümün tərəfdarıyam. Canlı enerjim və inadkarlığım məni fərqləndirir və başqaları ilə yeni əlaqələr qurmağa kömək edir.","span_profile_h":"Nömrə biriniz olmaq istəyirəm. Hər şeyi sadə saxlayıram, amma həyat üçün vacibəm. Əslində mövcud olan ən çox yönlü atom olduğumu dedilər. Məni bir qrup (qələvi) metal başçı ilə və ya kainatın demək olar ki, hər yerindən asılmış vəziyyətdə tapa bilərsiniz.","span_profile_i":"Möhkəm, etibarlı və əsaslıyam. Hər şeyi yüksək kontrastda gördüyüm üçün vacib olan şeyləri vurğulamaq istedadım var və böyük səliqə həvəskarıyam.","span_profile_n":"Qanadlarınızın altında küləyin 78%-i olmağıma icazə verin. Birlikdə əkmək üçün əsas bitki axtarırsınızsa, doğru yerə gəldiniz! Soyuqqanlı, sakit və təmkinli qalacağım barədə mənə etibar edə bilərsiniz, amma narahat olmayın, sizə heç vaxt soyuqqanlı davranmayacam.","span_profile_na":"Seriya bağlayıcısı burada. Tək olmağa nifrət edirəm, amma hər şey qaydasındadır, çünki mənsiz yaşaya bilməzsən (dürüstcə, heç nə ola bilməz). Məşq etməyi və bu əzələləri hərəkət etdirməyi sevirəm. Reaktiv olmağıma baxmayaraq mənalı münasibətlər qurmağa da meylim var.","span_profile_notification":"Salam, [%s]! Uyğunluğu tapmaq üçün əlaqə saxlamağa başlayın.","span_profile_o":"Etiraf edin, mənə ehtiyacınız var. Nəfəs aldığın havayam. Ətrafımdakılara təzə nəfəs gətirirəm. Olduğum mühitin çiçəklənməsini təmin edərək uyğunlaşmaq və böyüməyi təşviq etmək üçün çox gözəl qabiliyyətim var.","span_q1":"Standart temperatur və təzyiqdə maddənin üç vəziyyəti var: qaz, maye və bərk.","span_q2":"Bəzi elementlər, məsələn, ulduzlarda olanlar bütün kainatda geniş yayılıb, digərləri isə çox nadirdir və tapmaq çətindir.","span_q3":"Atom kütləsi atomun proton, neytron və elektron kütlələrinin toplanması ilə müəyyən edilir.","span_q4":"Atomun tutduğu xəyali fəza sferası Van der Waals radiusu adlanan dəyərlə təsvir edilir.","span_q5":"Elektroneqativlik atomun kimyəvi əlaqə meydana gətirərkən ortaq elektronları cəlb etmə meylidir.","span_swipe":"Əlaqə saxlaya biləcəyinizi düşündüyünüz elementlərin üzərinə sağa, maraqlanmırsınızsa sola sürüşdürün."}