)]}'
{"btn_about":"Dnešní Google Doodle","btn_back":"Zpět","btn_close":"Zavřít","btn_combine":"Pojďme se spojit!","btn_complete":"Vybrat další prvek","btn_gallery":"Mé vazby","btn_got_it":"Rozumím","btn_home":"Domů","btn_info":"Zobrazit celý profil","btn_keep_swiping":"Přejíždějte dál","btn_like":"Líbí se mi","btn_more":"Další Doodly","btn_more_query":"Google Doodly","btn_pass":"Nemám zájem","btn_q1_a":"Jsem volnomyšlenkář","btn_q1_b":"Jdu s proudem","btn_q1_c":"Nic moc se mnou nehne","btn_q2_a":"Jsem všude, nejde se mě zbavit","btn_q2_b":"Není moc těžké mě najít","btn_q2_c":"Je nemožné se ke mně dostat","btn_q3_a":"Nikdy jsem se žádné činky nedotkl(a)","btn_q3_b":"Občas nějaké to železo ([Fe]) zvednu","btn_q3_c":"Jde mi hlavně o SVALY","btn_q4_a":"Útulná chaloupka","btn_q4_b":"Prostorný dům","btn_q4_c":"Velkolepé sídlo","btn_q5_a":"Nikdo mi neodolá","btn_q5_b":"Jsem hvězdou večírků","btn_q5_c":"Mám úzký okruh blízkých","btn_quiz":"Vyplnit kvíz","btn_search":"Vyhledat","btn_select":"Vybrat prvek","btn_share":"Sdílet","btn_start":"Začít navazovat vazby","chip_about_01":"Plyn","chip_about_02":"Nejhojnější","chip_about_03":"Nejlehčí","chip_about_04":"Bezbarvý","chip_about_05":"Sedmý nejhojnější","chip_about_06":"Pniktogen","chip_about_07":"Třetí nejhojnější","chip_about_08":"Chalkogen","chip_about_09":"Halogen","chip_about_10":"Bledě žlutý","chip_about_11":"Žlutozelený","chip_about_12":"Kapalina","chip_about_13":"Červenohnědý","chip_about_14":"Pevná látka","chip_about_15":"Alkalický kov","chip_about_16":"Stříbrný","chip_about_17":"Vzácný plyn","chip_about_18":"Černý","chip_interest_01":"Hvězdářství","chip_interest_02":"Rakety","chip_interest_03":"Lety balonem","chip_interest_04":"Zahradničení","chip_interest_05":"Balení potravin","chip_interest_06":"Kryogenika","chip_interest_07":"Cvičení","chip_interest_08":"Ozonová vrstva","chip_interest_09":"Mražené pochoutky","chip_interest_10":"Stomatologie","chip_interest_11":"Klimatizace","chip_interest_12":"Bazény","chip_interest_13":"Jídlo","chip_interest_14":"Úklid","chip_interest_15":"Slané dobroty","chip_interest_16":"Fotografie","chip_interest_17":"Požární bezpečnost","chip_interest_18":"Zemědělství","chip_interest_19":"Výživa","chip_interest_20":"Lékařství","chip_interest_21":"Umělecký tisk","chip_interest_22":"Teplé osvětlení","chip_interest_23":"Kulturistika","chip_interest_24":"Sváření","chip_interest_25":"Laserové světelné show","chip_interest_26":"Technologie","header_about":"O mně","header_bond":"Navázali jste vazbu!","header_bond_arf":"Fluorid argonný","header_bond_br2":"Diatomický bróm","header_bond_cl2":"Plynný chlór","header_bond_f2":"Plynný fluor","header_bond_h2":"Plynný vodík","header_bond_hcl":"Chlorovodík","header_bond_hf":"Fluorovodík","header_bond_hi":"Jodovodík","header_bond_i2":"Diatomický jód","header_bond_ibr":"Bromid jodný","header_bond_n2":"Plynný dusík","header_bond_nabr":"Bromid sodný","header_bond_nacl":"Chlorid sodný","header_bond_naf":"Fluorid sodný","header_bond_nai":"Jodid sodný","header_bond_nf":"Fluorid dusný","header_bond_no":"Oxid dusnatý","header_bond_o2":"Plynný kyslík","header_complete":"Dobrá práce!","header_diatomic":"Vytváření diatomických vazeb na Valentýna","header_gallery_complete":"Gratulujeme, nasbírali jste všech 18!","header_gallery_incomplete":"Shromážděte všech 18 a odhalte obrázek","header_interests":"Zájmy","header_loader":"Načítání","header_mystery":"Tajemná vazba","header_pick":"Vyberte si kompatibilní prvek","header_q1":"Jak byste se popsali?","header_q2":"Je snadné vás získat?","header_q3":"Posilujete?","header_q4":"Jaký máte vysněný domov?","header_q5":"Přitahujete ostatní?","header_quiz":"Osobnostní kvíz prvků","header_select":"Vyberte prvek","header_splash":"Spojte se s jinými prvky","header_tap":"Klepnutím a podržením se spojíte","label_ar":"Argon","label_bond_arf":"Postavy Argon a Fluor v kočičí kavárně, Argon si hraje s laserovým ukazovátkem, zatímco Fluor sedí s kočkou na klíně, všude okolo jsou kočky.","label_bond_br2":"Dvě postavy Bróm kradou zlaté pruty z bankovního trezoru.","label_bond_cl2":"Láskyplný okamžik dvou postav Chlór. Jedna se červená, zatímco druhá jí pomáhá s papíry, které upustila na zem.","label_bond_f2":"Dvě postavy Fluor, které si vyrazily na zmrzlinu. Jedné zmrzlina spadla, ale druhá se s ní ráda podělí.","label_bond_h2":"Dvě postavy Vodík se drží za ruce a pozorují dvojici padajících hvězd na obloze.","label_bond_hcl":"Postavy vodíku a chlóru na romantické večeři v restauraci.","label_bond_hf":"Postavy Vodík a Fluor vyobrazené vedle sebe na desce plošných spojů jako počítačové čipy s obvody ve tvaru srdce mezi sebou.","label_bond_hi":"Postava Vodík v baseballové čepici s kyticí na návštěvě v nemocnici u postavy Jód, která má ovázanou hlavu.","label_bond_i2":"Dvě postavy Jód rybaří na molu. Jedna druhé ovazuje poraněnou nohu, zatímco ryba uniká.","label_bond_ibr":"Červenající se postava Jód, které postava Bróm v baseballové čepici podává květinu z kytice.","label_bond_n2":"Letecký snímek dvou postav Dusík, jak spolu na louce pouštějí draky ve tvaru srdce.","label_bond_nabr":"Postavy Sodík a Bróm relaxují v zimě ve vířivce u chaty zatímco v pozadí pobíhá jejich pes.","label_bond_nacl":"Postavy Sodík a Chlór se doma společně dívají na film, dělí se o popcorn a jsou obklopeny dalšími dobrotami.","label_bond_naf":"Postavy Sodík a Fluor, jak brčky ve tvaru srdce pijí ze společné sklenice.","label_bond_nai":"Postavy Sodík a Jód spolu piknikují na trávníku u vody. Jód zrovna postavě Sodík podává brambůrek.","label_bond_nf":"Scéna u táboráku s postavami Dusík a Fluor sedícími na polenech u ohně.","label_bond_no":"Postava Dusík se v dešti dělí o deštník s postavou Kyslík a společně přecházejí ulici.","label_bond_o2":"Dvě postavy Kyslík jdou společně na pěší výlet, pózují s rukama kolem ramen a horou v dálce. Jedna má vycházkovou hůl a sluneční brýle, druhá má čepici a obě mají šátek.","label_br":"Bróm","label_carousel_indicator":"Obrázek [X] ze 3","label_cl":"Chlór","label_f":"Fluor","label_h":"Vodík","label_header_logo":"Logo Google","label_i":"Jód","label_logo_big":"Logo [CuPd] chemie","label_mystery":"Záhadný prvek","label_n":"Dusík","label_na":"Sodík","label_o":"Kyslík","label_pic_ar_1":"Profilová fotka postavy Argon se svářečskou kuklou na hlavě, jak svařuje a jiskry létají na patchworkovou sochu kovového srdce.","label_pic_ar_2":"Profilová fotka postavy Argon na telefonu se spící kočkou stočenou do klubíčka v klíně.","label_pic_ar_3":"Profilová fotka postavy Argon se sluchátky na uších, jak s kočkou v klíně hraje pomocí myši a klávesnice online hry.","label_pic_br_1":"Profilová fotka postavy Bróm sedící na předním nárazníku hasičského vozu v hasičské čepici.","label_pic_br_2":"Náladová černobílá fotografie květiny s rosou, velmi emotivní.","label_pic_br_3":"Profilová fotka postavy Bróm, jak si dělá selfie se psem, který vystrkuje hlavu do popředí.","label_pic_cl_1":"Profilová fotka postavy Chlór ležící na boku na lehátku u bazénu se slunečními brýlemi na hlavě.","label_pic_cl_2":"Profilová fotka postavy Chlór hrdě ukazující své prkénko s uzeninami.","label_pic_cl_3":"Profilová fotka postavy Chlór, která si pořizuje selfie před nablýskanými regály plnými čisticích prostředků.","label_pic_f_1":"Profilová fotka postavy Fluor v zubařském plášti sedící u stolu s nohama nahoře. Stěna za ní je pokryta certifikáty.","label_pic_f_2":"Profilová fotka postavy Fluor v obleku sedící u stolu s nohama nahoře. Stěna za ní je pokryta certifikáty.","label_pic_f_3":"Profilová fotka postavy Fluor sedící před klimatizační jednotkou se psem, který si užívá chladivý vánek.","label_pic_h_1":"Profilová fotka postavy Vodík mávající při letu v horkovzdušném balonu.","label_pic_h_2":"Profilová fotka postavy Vodík pozorující start rakety v dálce a naznačující, že raketu drží prsty.","label_pic_h_3":"Profilová fotka postavy Vodík dívající se dalekohledem na hvězdy.","label_pic_i_1":"Profilová fotka postavy Jód stojící na molu a hrdě držící právě ulovenou velkou rybu.","label_pic_i_2":"Profilová fotka postavy Jód, jak nanáší inkoust na razítko a tiskne.","label_pic_i_3":"Shora vyfocená mísa s nudlovou polévkou, mňam.","label_pic_n_1":"Profilová fotka postavy Dusík obklopené rostlinami ve skleníku.","label_pic_n_2":"Profilová fotka postavy Dusík se šálou okolo krku, jak dělá na zemi sněhové andělíčky.","label_pic_n_3":"Profilová fotka postavy Dusík ukazující krabičku s obědem, který pečlivě a s láskou zabalila.","label_pic_na_1":"Profilová fotka postavy Sodík, jak si dělá selfie v posilovně a ukazuje své břišní svaly při cvičení s jednoručkou.","label_pic_na_2":"Skupinová fotka postavy Sodík s přáteli.","label_pic_na_3":"Profilová fotka útulné zimní scény z pohledu postavy Sodík se sněhem za oknem, svíčkou, hrnkem horkého nápoje a postavou Sodík s nohama nahoře a knihou na klíně.","label_pic_o_1":"Profilová fotka postavy Kyslík s baseballovou čepicí, jak běží závod.","label_pic_o_2":"Profilová fotka postavy Kyslík s jiskřivou růží v ústech, jak rukama předstírá střelbu z pistolí.","label_pic_o_3":"Profilová fotka klečící postavy Kyslík při práci na zahradě.","label_progress_quiz":"Otázka [X] z 5","label_swipe":"Ruka přejíždějící doprava směrem k tlačítku se srdíčkem pro lajk a doleva směrem k tlačítku X pro pokračování dál","label_unknown":"Neznámá vazba","share_modal_button_close":"Zavřít","share_modal_button_copied":"Odkaz zkopírován","share_modal_button_facebook":"Sdílet na Facebooku","share_modal_button_twitter":"Sdílet přes X","share_modal_click_link":"Kopírovat odkaz","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"Sdílet","share_text":"Máte dobrou chemii? V dnešním valentýnském #GoogleDoodle založeném na periodické tabulce prvků se můžete přejetím doprava párovat s jinými prvky.","span_bond":"[%s] a vy mezi sebou máte dobrou chemii.","span_bond_arf":"S dostatečnou energií a tlakem je tahle vazba ostrá jako laser. Lasery s [ArF] se používají při operacích očí, abyste měli dokonalý zrak.","span_bond_br2":"Narazili jste na [Au] (zlato)! [Br<2>] se používá k rozpouštění zlata obsaženého v rudě při těžbě alternativní metodou, která se nazývá bromové loužení.","span_bond_cl2":"[Cl<2>] dokáže rozložit lignin, hnědou látku v dřevní hmotě. Vznikne tak bílá buničina, kterou lze použít k výrobě papíru.","span_bond_f2":"[F<2>] se používá při výrobě fluorovaných uhlovodíků, což jsou chladiva, která lze použít k chlazení potravin. Ideální pro rande se zmrzlinou.","span_bond_h2":"Tyhle atomy jsou v sedmém nebi. [H2] je lehčí než vzduch, tak se nedivte, když s ním budete mít hlavu v oblacích.","span_bond_hcl":"Tahle molekula je pikantní! [HCl] je silná kyselina, která nám pomáhá trávit. Ideální pro sblížení u večeře.","span_bond_hf":"Tenhle pár, který dokáže leptat sklo, právě vyřezává vzory do křemíkových destiček na výrobu počítačových čipů.","span_bond_hi":"Pozdravte [HI]! Čistota je základ – hlavně v nemocnicích, kde tahle molekula pomáhá dezinfikovat lékařské nástroje.","span_bond_i2":"[I<2>] je skvělé antiseptikum a spolu s další chemickou látkou zvanou povidon pomáhá zajistit, aby se rány a škrábance nezanítily.","span_bond_ibr":"[IBr] je přítelem analytických chemiků. Používá se ke stanovení koncentrace některých chemických látek metodou zvanou jodometrická titrace, při které dochází ke změně barvy v závislosti na chemických reakcích.","span_bond_n2":"Pojďme pouštět draky! [N<2>] tvoří 78 % zemské atmosféry. Co se týká vztahů, je spojení v téhle molekule s trojnou vazbou nepřekonatelné. Ostatní si o takové sebelásce mohou jen nechat zdát.","span_bond_nabr":"Je tu horko, nebo je to jen tou vířivkou? [NaBr] rádi udržují vodu pěkně čistou, aby si mohli užít chvilku relaxace.","span_bond_nacl":"Protiklady se přitahují. [Na+] a [Cl-] ionty se spojily, aby splnily všechny naše sny o slaných dobrotách.","span_bond_naf":"Za perleťově bílý úsměv vděčíte [NaF]. Tahle molekula se přidává do pitné vody a zubní pasty, aby udržovala zuby zdravé.","span_bond_nai":"Pozor na nedostatek jódu, [NaI] je tu proto, aby vaše štítná žláza byla spokojená. Doplňky stravy s NaI spolu s potravinami bohatými na jód podporují zdravý metabolismus.","span_bond_nf":"Některé vazby netrvají věčně. Za správných podmínek vzniká [NF], který vydává charakteristickou záři, ale jakmile vzrušení opadne, oba atomy si jdou zase svojí cestou.","span_bond_no":"Tihle dva se dávají dohromady při bouřkách. Blesky rychle zahřívají a ochlazují plyny a vzniká [NO]. Kvalitě ovzduší to zrovna nepomáhá, ale i tak je to docela vzrušující.","span_bond_o2":"Tahle molekula je nezbytná pro špičkový výkon. Horolezci si při výstupech na nejvyšší hory pomáhají tlakovými lahvemi s [O<2>].","span_complete":"Nasbírali jste všechny vazby, které jsou pro [%s] dostupné.","span_diatomic":"Diatomické molekuly jsou tvořeny vazbou mezi dvěma atomy. Někdy se jedná o dva atomy stejného prvku, jako v případě plynného vodíku ([H<2>]), jindy jde o dva různé prvky, jako v případě chlorovodíku ([HCl]).","span_missed_notification":"Škoda, byla mezi vámi dobrá chemie.","span_no_match_notification":"Lituji, tohle není shoda","span_profile_ar":"Jsem velmi stabilní a jsem rád sám. Když říkám, že hledám ten pravý protějšek, myslím to vážně. Je potřeba hodně úsilí, aby to se mnou zajiskřilo, ale i tak hledám jen chvilkové pobavení, ne dlouhodobý vztah.","span_profile_br":"Umím být dost prchlivý, ale když jsem sám, rád se nechám unášet proudem. Mou vášní je fotografování a taky jsem hasič. To je docela fajn, ne?","span_profile_cl":"Pokud si potrpíte na čistotu, přejeďte doprava. Jsem velmi reaktivní, takže určitě najdeme něco, co nás spojí. Ale pozor – i dobrého může být příliš. Nejlépe si mě užijete v malých dávkách.","span_profile_f":"Pro všechny jsem nesmírně přitažlivý. Když už mluvíme o přitažlivosti – potrpím si na pěkný úsměv. Moje neodolatelná energie a asertivita mi pomáhají vyniknout a navazovat kontakty s ostatními.","span_profile_h":"Chci být vaše jednička. Nepotrpím si na žádné složitosti, ale život se beze mě neobejde. Říkají o mně, že jsem ze všech atomů nejvšestrannější. Najdete mě ve skupině alkalických kovů nebo v podstatě kdekoli ve vesmíru.","span_profile_i":"Jsem odolný, spolehlivý a pevný v kramflecích. Protože všechno vidím ve velkém kontrastu, dokážu zvýraznit, co je důležité. A taky hodně dbám na čistotu.","span_profile_n":"Budu 78 % větru do vašich plachet. Pokud hledáte někoho, s kým byste se společně mohli starat o zahrádku, jste na správném místě! Vždy zůstávám chladný, klidný a vyrovnaný – ale nebojte se, nikdy vás nebudu ignorovat.","span_profile_na":"Jsem sériový vazbič. Nesnáším být sám, ale to vůbec nevadí, protože beze mě nikdo nepřežije. Rád cvičím a udržuju si svaly v pohybu. Ačkoli jsem reaktivní, taky rád buduju smysluplné vztahy.","span_profile_notification":"Zdravím [%s]! Začněte navazovat vazby a najděte si partnera.","span_profile_o":"Přiznejte si, že se beze mě neobejdete. Jsem vzduch, který dýcháte. Přináším svému okolí závan čerstvého vzduchu. Mám pozoruhodnou schopnost přizpůsobit se a podporovat růst, aby mé okolí vzkvétalo.","span_q1":"Při standardní teplotě a tlaku existují tři skupenství: plynné, kapalné a pevné.","span_q2":"Některé prvky, například ty, co se nacházejí ve hvězdách, se ve vesmíru vyskytují hojně, zatímco jiné jsou velmi vzácné a hned tak je nenajdete.","span_q3":"Atomová hmotnost se určí sečtením hmotností protonů, neutronů a elektronů atomu.","span_q4":"Pomyslnou kouli, kterou atom zabírá v prostoru, popisuje hodnota zvaná van der Waalsův poloměr.","span_q5":"Elektronegativita je tendence atomu přitahovat sdílené elektrony při vytváření chemických vazeb.","span_swipe":"U prvků, se kterými byste se podle vás mohli sblížit, přejeďte doprava. U prvků, o které nemáte zájem, přejeďte doleva."}