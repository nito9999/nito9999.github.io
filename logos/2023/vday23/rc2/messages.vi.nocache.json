one","chip_interest_09":"Đồ ăn vặt đông lạnh","chip_interest_10":"Nha khoa","chip_interest_11":"Điều hoà không khí","chip_interest_12":"Bể bơi","chip_interest_13":"Ăn","chip_interest_14":"Dọn dẹp","chip_interest_15":"Đồ ăn vặt vị mặn","chip_interest_16":"Nhiếp ảnh","chip_interest_17":"An toàn cháy nổ","chip_interest_18":"Việc nông trại","chip_interest_19":"Dinh dưỡng","chip_interest_20":"Y học","chip_interest_21":"Kỹ thuật in ấn","chip_interest_22":"Ánh đèn ấm","chip_interest_23":"Thể hình","chip_interest_24":"Hàn","chip_interest_25":"Chương trình trình diễn đèn laser","chip_interest_26":"Công nghệ","header_about":"Giới thiệu về bản thân","header_bond":"Hai bạn là một cặp!","header_bond_arf":"Argon florua","header_bond_br2":"Hai nguyên tử brom","header_bond_cl2":"Khí clorua","header_bond_f2":"Khí fluor","header_bond_h2":"Khí Hydro","header_bond_hcl":"Hydro clorua","header_bond_hf":"Hydro fluorua","header_bond_hi":"Hydro iodide","header_bond_i2":"Hai nguyên tử iốt","header_bond_ibr":"Iốt bromua","header_bond_n2":"Khí nitơ","header_bond_nabr":"Natri bromua","header_bond_nacl":"Natri clorua","header_bond_naf":"Natri florua","header_bond_nai":"Natri iodide","header_bond_nf":"Nitơ monofluoride","header_bond_no":"Nitơ monoxit","header_bond_o2":"Khí oxy","header_complete":"Xuất sắc!","header_diatomic":"Liên kết hai nguyên tử cho Ngày lễ Tình nhân","header_gallery_complete":"Chúc mừng, bạn đã thu thập đủ 18 liên kết!","header_gallery_incomplete":"Thu thập toàn bộ 18 liên kết để hình ảnh hiện ra","header_interests":"Sở thích","header_loader":"Đang tải","header_mystery":"Liên kết bí ẩn","header_pick":"Chọn một nguyên tố phù hợp","header_q1":"Bạn mô tả bản thân mình như thế nào?","header_q2":"Người khác có dễ gặp được bạn không?","header_q3":"Bạn có tập tạ không?","header_q4":"Đâu là ngôi nhà mơ ước của bạn?","header_q5":"Bạn có dễ thu hút mọi người không?","header_quiz":"Bài trắc nghiệm tính cách theo nguyên tố","header_select":"Chọn nguyên tố của bạn","header_splash":"Kết nối với người cùng nguyên tố","header_tap":"Nhấn và giữ để kết hợp","label_ar":"Argon","label_bond_arf":"Hai nhân vật Argon và Fluor đang ngồi trong một quán cà phê mèo, Argon đang chơi trò trỏ đèn laser trong khi Fluor ngồi với một con mèo trong lòng, vô số con mèo dạo chơi khắp nơi trong quán.","label_bond_br2":"Hai nhân vật Brom đang lấy những thỏi vàng khỏi kho trữ trong một vụ cướp ngân hàng.","label_bond_cl2":"Một khoảnh khắc đáng yêu giữa hai nhân vật Chlor, một nhân vật đang đỏ mặt khi nhân vật còn lại nhặt giúp những tờ giấy bị rơi xuống đất.","label_bond_f2":"Hai nhân vật Fluor cùng đi ăn kem, nhưng một nhân vật làm rơi mất kem. Tuy nhiên, đừng lo vì nhân vật còn lại sẵn sàng chia sẻ cây kem của mình.","label_bond_h2":"Hai nhân vật Hydro nắm tay nhau cùng ngắm một cặp sao băng bay vụt qua bầu trời.","label_bond_hcl":"Hai nhân vật Hydro và Chlor trong một bữa tối lãng mạn tại một nhà hàng.","label_bond_hf":"Nhân vật Hydro và Fluor nằm cạnh nhau trên bảng mạch như hai con chip máy tính với mạch điện hình trái tim ở giữa.","label_bond_hi":"Nhân vật Hydro đội mũ bóng chày đang cầm một bó hoa vào viện thăm nhân vật Iốt đang bị băng trên đầu.","label_bond_i2":"Hai nhân vật Iốt đang ngồi câu cá trên một bến thuyền, một nhân vật Iốt đang giúp băng vết thương trên chân cho nhân vật còn lại, còn con cá thì bơi đi mất.","label_bond_ibr":"Nhân vật Iốt đỏ mặt khi được nhân vật Brom đội mũ bóng chày trao cho một bông hoa từ bó hoa của Brom.","label_bond_n2":"Ảnh chụp từ trên cao hai nhân vật Nitơ cùng nhau thả diều hình trái tim trên đồng cỏ.","label_bond_nabr":"Hai nhân vật Natri và Bromua đang thư giãn trong bồn nước nóng tại một căn nhà gỗ nghỉ đông nhỏ nhắn. Ở phía sau, chú chó của họ đang chạy nhảy.","label_bond_nacl":"Hai nhân vật Natri và Chlor cùng xem phim tại nhà, cùng ăn bỏng ngô và xung quanh là vô số đồ ăn vặt khác.","label_bond_naf":"Hay nhân vật Natri và Fluor uống chung một ly nước, mỗi nhân vật dùng một ống hút được uốn cong thành hình trái tim.","label_bond_nai":"Nhân vật Iốt đút cho nhân vật Natri một miếng khoai tây chiên khi cả hai cùng đi dã ngoại trên một đồng cỏ bên hồ nước.","label_bond_nf":"Khung cảnh lửa trại có hai nhân vật Nitơ và Fluor ngồi cùng nhau trên những khúc cây bên ngọn lửa.","label_bond_no":"Nhân vật Nitơ dùng chung ô với nhân vật Oxy dưới cơn mưa bão khi cả hai cùng nhau băng qua đường.","label_bond_o2":"Hai nhân vật Oxy đi bộ đường dài cùng nhau, họ quàng vai nhau trước khung cảnh một ngọn núi ở phía xa. Một nhân vật đeo kính mát và chống gậy đi bộ, nhân vật còn lại đội mũ trùm, cả hai đều đeo khăn quàng cổ.","label_br":"Brom","label_carousel_indicator":"Hình [X] trong số 3","label_cl":"Chlor","label_f":"Fluor","label_h":"Hydro","label_header_logo":"Biểu trưng Google","label_i":"Iốt","label_logo_big":"Biểu trưng Chemistry [CuPd]","label_mystery":"Nguyên tố bí ẩn","label_n":"Nitơ","label_na":"Natri","label_o":"Oxy","label_pic_ar_1":"Ảnh đại diện nhân vật Argon đeo mặt nạ khi đang hàn với những tia lửa bắn ra từ tác phẩm điêu khắc chắp kim loại hình trái tim.","label_pic_ar_2":"Ảnh đại diện nhân vật Argon chơi điện thoại với con mèo nằm cuộn tròn trong lòng.","label_pic_ar_3":"Ảnh đại diện nhân vật Argon đeo tai nghe và chơi trò chơi trực tuyến bằng chuột và bàn phím, trong khi đó một con mèo ngồi trong lòng Argon.","label_pic_br_1":"Ảnh đại diện nhân vật Brom đội mũ lính cứu hoả khi đang ngồi trên cản trước của một chiếc xe cứu hoả.","label_pic_br_2":"Ảnh trắng đen cận cảnh một bông hoa đọng giọt sương, tràn đầy cảm xúc.","label_pic_br_3":"Ảnh đại diện nhân vật Brom tự chụp ảnh chân dung với chú chó đang đưa mặt lên tiền cảnh.","label_pic_cl_1":"Ảnh đại diện nhân vật Chlor đeo kính mát trên đầu và nằm nghiêng người trên một chiếc ghế võng bên cạnh bể bơi.","label_pic_cl_2":"Ảnh đại diện nhân vật Chlor tự hào khoe khay thịt nguội.","label_pic_cl_3":"Ảnh đại diện nhân vật Chlor tự chụp ảnh trước chiếc giá sáng bỏng đựng đầy sản phẩm tẩy rửa.","label_pic_f_1":"Ảnh đại diện nhân vật Fluor mặc áo choàng nha sĩ ngồi gác chân lên bàn làm việc, bức tường phía sau có đầy bằng chứng nhận.","label_pic_f_2":"Ảnh đại diện nhân vật Fluor mặc trang phục công sở ngồi gác chân lên bàn làm việc, bức tường phía sau có đầy bằng chứng nhận.","label_pic_f_3":"Ảnh đại diện nhân vật Fluor ngồi trước máy điều hoà không khí cùng chú chó tận hưởng làn gió mát lạnh.","label_pic_h_1":"Ảnh đại diện nhân vật Hydro vẫy tay khi đang ở trên khinh khí cầu.","label_pic_h_2":"Ảnh đại diện nhân vật Hydro xem cảnh phóng tên lửa từ xa và đưa tay lên đo tên lửa.","label_pic_h_3":"Ảnh đại diện nhân vật Hydro nhìn lên các vì sao bằng kính viễn vọng.","label_pic_i_1":"Ảnh đại diện nhân vật Iốt đứng trên bến thuyền, tự hào giữ con cá mới bắt được, một con cá rất to.","label_pic_i_2":"Ảnh đại diện nhân vật Iốt đang lăn con dấu qua mực để tạo bản in.","label_pic_i_3":"Ảnh chụp một bát mì từ trên xuống, trông thật hấp dẫn.","label_pic_n_1":"Ảnh đại diện nhân vật Nitơ xung quanh cây cỏ trong nhà kính.","label_pic_n_2":"Ảnh đại diện nhân vật Nitơ đeo khăn quàng cổ khi tạo hình thiên thần trên mặt tuyết.","label_pic_n_3":"Ảnh đại diện nhân vật Nitơ cho bạn xem hộp đồ ăn trưa được sắp xếp gọn gàng và đong đầy yêu thương.","label_pic_na_1":"Ảnh đại diện nhân vật Natri tự chụp ảnh chân dung khoe cơ bụng khi đang nâng tạ tại phòng tập","label_pic_na_2":"Ảnh tập thể chụp nhân vật Natri cùng bạn bè.","label_pic_na_3":"Ảnh đại diện về khung cảnh mùa đông ấm áp qua góc nhìn của nhân vật Natri, trong đó có tuyết rơi ngoài cửa sổ, một ngọn nến, một cốc nước nóng và Natri ngồi gác chân lên cùng một cuốn sách đặt trên đùi.","label_pic_o_1":"Ảnh đại diện nhân vật Oxy đội mũ bóng chày và chạy trong một cuộc đua.","label_pic_o_2":"Ảnh đại diện nhân vật Oxy ngậm một cành hoa hồng lấp lánh thật gợi cảm khi đang chỉ ngón tay hình súng.","label_pic_o_3":"Ảnh đại diện nhân vật Oxy quỳ xuống khi đang làm vườn.","label_progress_quiz":"Câu hỏi [X] trên 5","label_swipe":"Vuốt sang phải về phía nút trái tim để thích và sang trái về phía nút X để bỏ qua","label_unknown":"Liên kết không xác định","share_modal_button_close":"Đóng","share_modal_button_copied":"Đã sao chép đường liên kết","share_modal_button_facebook":"Chia sẻ qua Facebook","share_modal_button_twitter":"Chia sẻ qua X","share_modal_click_link":"Sao chép đường liên kết","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"Chia sẻ","share_text":"Hai bạn có hợp nhau không? Vuốt sang phải để kết nối với các nguyên tố khác nhân Ngày lễ tình nhân hôm nay trên bảng tuần hoàn hoá học #GoogleDoodle.","span_bond":"Bạn và [%s] hợp nhau lắm","span_bond_arf":"Với đủ năng lượng và áp lực, liên kết này vô cùng rõ nét. Tia laser [ArF] có thể dùng để phẫu thuật mắt giúp bạn giữ thị lực 20/20.","span_bond_br2":"Bạn vừa trúng [Au] (vàng)! [Br<2>] được dùng làm một phương pháp thay thế để tinh luyện vàng từ quặng trong hoạt động khai thác vàng, còn được gọi là ngâm chiết bằng brom.","span_bond_cl2":"[Cl<2>] có thể phân huỷ chất lignin, một chất tạo nên màu nâu của gỗ trong bột giấy. Nhờ đó, chúng ta có bột giấy trắng để sản xuất giấy.","span_bond_f2":"[F<2>] được dùng để sản xuất fluorocarbon, một chất làm lạnh có thể dùng để giữ lạnh đồ ăn. Rất thích hợp để gắn kết khi ăn kem.","span_bond_h2":"Những nguyên tử này bay tận 9 tầng mây. [H2] nhẹ hơn không khí, nên đừng bất ngờ nếu như tình yêu khiến bạn cảm thấy lúc nào cũng như trên mây.","span_bond_hcl":"Phân tử này dữ lắm đấy! [HCl] là một axit mạnh giúp tiêu hoá thức ăn. Hoàn hảo để gắn kết trong bữa ăn tối.","span_bond_hf":"Bộ đôi khắc kính đang bận điêu khắc hoa văn lên đĩa bán dẫn silicon dùng để sản xuất chip máy tính.","span_bond_hi":"Hãy làm quen với [HI]! Sự sạch sẽ là vô cùng quan trọng, đặc biệt là trong bệnh viện, nơi mà phân tử này giúp sát khuẩn các dụng cụ y tế.","span_bond_i2":"[I<2>] là một chất khử trùng tuyệt vời. Cùng với một chất hoá học khác có tên là povidone, chất này giúp giữ cho những vết đứt và trầy xước không bị nhiễm trùng.","span_bond_ibr":"[IBr] là một người bạn mê phân tích của nhà hoá học. Chất này được dùng trong phản ứng đổi màu để xác định độ đậm đặc của một chất hoá học nhất định trong một quá trình gọi là chuẩn độ iốt.","span_bond_n2":"Đi thả diều nào! [N<2>] chiếm đến 78% bầu khí quyển Trái Đất. Khi nói đến các mối quan hệ thì phân tử liên kết ba này chắc chắn gắn bó chặt chẽ vô cùng. Đúng là hình mẫu về yêu thương bản thân!","span_bond_nabr":"Ở trong này nóng thật hay là tại ở trong bồn nước này mới nóng nhỉ? [NaBr] thích giữ cho nước sạch sẽ để có những phút giây thư giãn chất lượng.","span_bond_nacl":"Trái dấu thì hấp dẫn nhau. Ion [Na+] và [Cl-] kết hợp cùng nhau sẽ giúp tạo nên tất cả những đồ ăn vặt vị mặn ngon tuyệt.","span_bond_naf":"Bạn có thể khoe hàm răng trắng tinh nhờ [NaF]. Phân tử này được thêm vào nước uống và kem đánh răng để giúp giữ cho răng của bạn chắc khoẻ.","span_bond_nai":"Hãy cẩn thận đừng để thiếu iốt, [NaI] sẽ giúp tuyến giáp của bạn khoẻ mạnh. Bên cạnh thức ăn giàu iốt, chất bổ sung Nal cũng hỗ trợ một hệ tiêu hoá khoẻ mạnh.","span_bond_nf":"Một số liên kết không kéo dài mãi mãi. Dưới điều kiện phù hợp, [NF] được tạo nên sẽ có đặc điểm là phát ra ánh sáng, tuy nhiên, chúng sẽ nhanh chóng tách nhau ra một khi không còn sự phấn khích ban đầu nữa.","span_bond_no":"Hai phân tử này xuất hiện cùng nhau khi một tia chớp LOÉ SÁNG! Khi các khí trong tia chớp nhanh chóng nóng lên và lạnh xuống, [NO] được tạo nên. Không tốt lắm cho chất lượng không khí, nhưng vẫn khá thú vị.","span_bond_o2":"Cần có phân tử này để cơ thể được bền bỉ. Người leo núi chạm đến đỉnh núi cao nhất với sự trợ giúp của bình [O<2>].","span_complete":"Bạn đã thu thập được toàn bộ các liên kết cho [%s].","span_diatomic":"Khi hai nguyên tử liên kết với nhau, chúng tạo thành phân tử hai nguyên tử. Đôi khi đó là sự liên kết giữa hai nguyên tử thuộc cùng nguyên tố, như [H<2>] (khí hydro), nhưng cũng có khi đó là sự kết hợp giữa hai nguyên tố khác nhau, như [HCl] (khí hydro clorua).","span_missed_notification":"Ôi, đáng ra các bạn rất hợp nhau.","span_no_match_notification":"Rất tiếc, không thể ghép đôi được","span_profile_ar":"Tôi là người ổn định và thích thời gian riêng tư. Khi tôi nói rằng mình đang muốn tìm kiếm nửa kia, tôi thật sự muốn thế. Không dễ để ngọn lửa tình yêu trong tôi bùng cháy, nhưng kể cả thế thì tôi cũng chỉ muốn tìm sự thú vị chứ không phải một mối quan hệ lâu dài.","span_profile_br":"Tôi là một người dễ hoà nhập! Tôi là người dễ dàng thay đổi nhưng khi một mình thì tôi lại thích thuận theo tự nhiên. Tôi đam mê nhiếp ảnh và tôi cũng là một người lính cứu hoả. Nghe ngầu đấy chứ?","span_profile_cl":"Vuốt sang phải nếu như bạn mê sự sạch sẽ. Tôi là người dễ thích nghi với hoàn cảnh, vì thế nên chắc chắn chúng ta sẽ tìm được sở thích chung, nhưng hãy cẩn thận: bạn sẽ bị choáng ngợp bởi sự tuyệt vời của tôi (từ từ tìm hiểu từng chút một thôi nhé).","span_profile_f":"Mọi người đều thấy tôi vô cùng cuốn hút. Nhắc đến sự cuốn hút, xin tiết lộ rằng tôi rất thích một nụ cười rạng rỡ. Năng lượng tích cực cùng sự quyết đoán là những yếu tố khiến tôi nổi bật và giúp tôi gắn kết với những người mới.","span_profile_h":"Tôi muốn ở vị trí số một trong lòng bạn. Tôi là người đơn giản nhưng không thể thiếu trong cuộc sống. Thực ra thì mọi người nói tôi là nguyên tử linh hoạt nhất. Bạn có thể thấy tôi chơi với một nhóm người hâm mộ nhạc rock metal (kim loại kiềm) hoặc ở bất kỳ đâu trong vũ trụ.","span_profile_i":"Tôi cứng rắn, đáng tin cậy và vững vàng. Tôi giỏi chỉ ra những thứ quan trọng vì tôi có thể phân biệt mọi thứ thật rõ ràng. Ngoài ra tôi cực kỳ ngăn nắp.","span_profile_n":"Hãy để tôi chiếm lấy 78% ngọn gió nâng đôi cánh bạn. Nếu muốn tìm một người cũng thích chăm cây cảnh thì bạn tới đúng nơi rồi đấy! Tôi luôn lạnh lùng, bình tĩnh và mọi thứ đều nằm trong tầm kiểm soát của tôi, nhưng đừng lo, tôi sẽ không bao giờ lạnh nhạt với bạn.","span_profile_na":"Tôi là người thích giao du kết bạn. Tôi không thích ở một mình, nhưng chẳng sao cả vì bạn sẽ không thể sống thiếu tôi (chẳng ai có thể, thật đấy). Tôi mê tập thể dục và hoạt động cơ thể. Mặc dù tôi là người thích giao du, nhưng tôi cũng muốn xây dựng những mối quan hệ ý nghĩa.","span_profile_notification":"Chào [%s]! Hãy bắt đầu ghép đôi và tìm nửa kia của bạn.","span_profile_o":"Chấp nhận sự thật đi, bạn cần tôi mà. Tôi chính là không khí bạn hít thở. Tôi mang đến một bầu không khí trong lành cho mọi người xung quanh tôi. Tôi có khả năng thích nghi và phát triển đáng kinh ngạc, chắc chắn rằng môi trường xung quanh tôi sẽ luôn thăng hoa.","span_q1":"Có ba trạng thái vật chất ở nhiệt độ và áp suất tiêu chuẩn: rắn, lỏng và khí.","span_q2":"Một số nguyên tố, như những nguyên tố tìm thấy trong các ngôi sao, có thể tìm được dễ dàng ở khắp vũ trụ này. Trong khi đó, một số nguyên tố khác lại rất hiếm có khó tìm.","span_q3":"Nguyên tử khối bằng tổng khối lượng của proton, neutron và electron trong nguyên tử đó.","span_q4":"Bán kính Van der Waals là bán kính của một hình cầu tưởng tượng dùng để mô hình hoá một nguyên tử.","span_q5":"Độ âm điện của một nguyên tử là khả năng hút electron của nguyên tử đó khi tạo thành một liên kết hoá học.","span_swipe":"Vuốt sang phải trên những nguyên tố bạn nghĩ là bạn có thể ghép đôi được và sang trái nếu như bạn cảm thấy không phù hợp."}