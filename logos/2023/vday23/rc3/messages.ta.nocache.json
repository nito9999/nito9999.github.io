்கள் கனவு இல்லம் எது?","header_q5":"நீங்கள் பிறரை வசீகரிக்கும் குணமுள்ளவாரா?","header_quiz":"உங்கள் தனிமத்தன்மை - வினாடி வினா","header_select":"தனிமத்தைத் தேர்ந்தெடுங்கள்","header_splash":"உங்கள் சகத் தனிமங்களுடன் பிணைப்பை ஏற்படுத்துங்கள்","header_tap":"இணைக்க, தட்டிப் பிடியுங்கள்","label_ar":"ஆர்கான்","label_bond_arf":"ஆர்கான் மற்றும் ஃபுளோரின் கதாபாத்திரங்கள் பூனை கஃபேயில் நேரம் செலவிடுகின்றனர். பூனையை ஃபுளோரின் தன் மடியில் வைத்துக்கொண்டு அமர்ந்திருக்கையில் லேசர் பாயிண்டருடன் ஆர்கான் விளையாடுகிறார், அந்த இடத்தைச் சுற்றிலும் பூனைகள் இருக்கின்றன.","label_bond_br2":"இரண்டு புரோமின் கதாபாத்திரங்கள் பேங்க் வால்ட்லிருந்து தங்கக் கட்டிகளைக் களவாடும் ஒரு வங்கிக் கொள்ளையாகும்.","label_bond_cl2":"இரண்டு குளோரின் கதாபாத்திரங்களுக்கு இடையிலான தருணம் இது, ஒருவரின் முகம் வெட்கத்தில் சிவக்க, மற்றொருவர் தரையில் விழுந்த தாள்களை எடுத்துத் கொடுத்து அவருக்கு உதவுகிறார்.","label_bond_f2":"இரண்டு ஃபுளோரின் கதாபாத்திரங்கள் ஐஸ்கிரீம் சாப்பிட வெளியே செல்கின்றனர். அப்போது அவர்களில் ஒருவர் தனது ஐஸ்கிரீமைக் கீழே தவறவிடுகிறார். ஆனால் கவலை வேண்டாம், மற்றொருவர் பகிர்ந்துகொள்ளத் தயாராக உள்ளார்.","label_bond_h2":"இரண்டு எரிநட்சத்திரங்கள் வானில் கடந்து செல்வதைக் கைகளைக் கோர்த்துப் பார்த்துக் கொண்டிருக்கும் இரண்டு ஹைட்ரஜன் கதாபாத்திரங்கள்.","label_bond_hcl":"உணவகத்தில் தங்கள் காதல் உணர்வை வெளிப்படுத்தி உணவைப் பகிர்த்துகொள்ளும் ஹைட்ரஜன் மற்றும் குளோரின் கதாபாத்திரங்கள்.","label_bond_hf":"கம்ப்யூட்டர் சிப்களுக்கு இடையே உள்ள சர்க்யூட்டுகள் இதய வடிவத்தை உருவாக்குவது போன்று சர்க்யூட் போர்டில் அருகருகே வைக்கப்பட்டிருக்கும் ஹைட்ரஜன் மற்றும் ஃபுளோரின் கதாபாத்திரங்கள்.","label_bond_hi":"தலையில் கட்டுடன் மருத்துவமனையில் இருக்கும் அயோடின் கதாபாத்திரத்தை, பூங்கொத்துடன் பேஸ்பால் தொப்பியை அணிந்துகொண்டு சந்திக்கும் ஹைட்ரஜன் கதாபாத்திரம்.","label_bond_i2":"இரண்டு அயோடின் கதாபாத்திரங்கள் கரையில் அமர்ந்து மீன்பிடித்துக் கொண்டிருக்கின்றனர். அப்போது ஒருவர் இன்னொருவரின் காயமடைந்த காலுக்குக் கட்டுப் போடுகையில் மீன் தப்பிச் செல்கிறது.","label_bond_ibr":"பேஸ்பால் தொப்பியை அணிந்து, தனது கையில் உள்ள பூங்கொத்தில் இருந்து ஒரு பூவை புரோமின் கதாபாத்திரம் எடுத்துக் கொடுக்கும்போது, அயோடின் கதாபாத்திரத்திற்கு வெட்கத்தில் கன்னங்கள் சிவக்கின்றன.","label_bond_n2":"புல்வெளியில் ஒன்றாகச் சேர்ந்து இதய வடிவிலான காத்தாடிகளைப் பறக்கவிடும் இரண்டு நைட்ரஜன் கதாபாத்திரங்களை மேலிருந்து எடுத்த காட்சி.","label_bond_nabr":"குளிர்காலத்திற்கு ஏற்ற வீட்டில் வெந்நீர் குளியல் தொட்டியில் ஓய்வெடுக்கும் சோடியம் மற்றும் புரோமைடு கதாபாத்திரங்கள். பின்னணியில் அவர்களின் நாய் துள்ளிக்குதித்து விளையாடிக்கொண்டிருக்கிறது.","label_bond_nacl":"சோடியம் மற்றும் குளோரின் கதாபாத்திரங்கள் வீட்டில் ஒன்றாகப் பாப்கார்ன் பகிர்ந்துகொண்டு, சுற்றிலும் மற்ற ஸ்னாக்ஸை வைத்துக்கொண்டு திரைப்படம் பார்க்கின்றனர்.","label_bond_naf":"இதய வடிவிலான வளைந்த ஸ்ட்ராக்களைப் பயன்படுத்தி பானத்தை ஒன்றாகப் பகிர்ந்துகொள்ளும் சோடியம் மற்றும் ஃபுளோரின் கதாபாத்திரங்கள்.","label_bond_nai":"அயோடின் மற்றும் சோடியம் கதாபாத்திரங்கள் நீர்நிலை அருகில் உள்ள புல்வெளிக்கு ஒன்றாகப் பிக்னிக் சென்றன. அங்கு சோடியத்திற்கு அயோடின், சிப்ஸை ஊட்டிவிட செல்கிறது.","label_bond_nf":"நைட்ரஜன் மற்றும் ஃபுளோரின் கதாபாத்திரங்கள் ஒன்றாகக் கட்டை மீது அமர்ந்து குளிர்காயும் கேம்ப்ஃபயர் காட்சி.","label_bond_no":"புயல்மழையில் ஆக்ஸிஜன் கதாபாத்திரத்துடன் தன் குடையைப் பகிர்ந்துகொண்டு சாலையை ஒன்றாகக் கடக்கும் நைட்ரஜன் கதாபாத்திரம்.","label_bond_o2":"இரண்டு ஆக்ஸிஜன் கதாபாத்திரங்கள் ஒன்றாக ஹைக்கிங் பயணம் செல்கின்றனர். அவர்கள் தூரத்தில் தெரியும் ஒரு மலைக்கு முன்பாக நின்று ஒருவருக்கொருவர் தோள்களின் மீது கைகளைப் போட்டுக்கொண்டு படங்களை எடுக்கின்றனர். ஒருவர் தலையில் சன்கிளாஸுடன் வாக்கிங் ஸ்டிக்கை வைத்துள்ளார், மற்றவர் பீனி தொப்பி அணிந்துள்ளார், இருவரும் ஸ்கார்ஃப் அணிந்துள்ளனர்.","label_br":"புரோமின்","label_carousel_indicator":"3ல் [X]வது படம்","label_cl":"குளோரின்","label_f":"ஃபுளோரின்","label_h":"ஹைட்ரஜன்","label_header_logo":"Google லோகோ","label_i":"அயோடின்","label_logo_big":"Chemistry [CuPd] லோகோ","label_mystery":"மர்மமான தனிமம்","label_n":"நைட்ரஜன்","label_na":"சோடியம்","label_o":"ஆக்ஸிஜன்","label_pic_ar_1":"வெல்டிங் மாஸ்க் அணிந்து இதய வடிவச் சிற்பத்தைத் தீப்பொறிகள் பறக்க வெல்டிங் செய்யும் ஆர்கான் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_ar_2":"பூனை சுருண்டு மடியில் படுத்திருக்கும்போது தனது மொபைலைப் பயன்படுத்தும் ஆர்கான் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_ar_3":"தனது பூனையை மடியில் உட்கார வைத்துக்கொண்டு, ஹெட்ஃபோன்களை அணிந்து மவுஸையும் கீபோர்டையும் பயன்படுத்தி ஆன்லைனில் கேம்களை விளையாடும் ஆர்கான் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_br_1":"தீயணைப்பு வீரர் தொப்பியை அணிந்துகொண்டு தீயணைப்பு வாகனத்தின் முன்புற பம்பரில் அமர்ந்திருக்கும் புரோமின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_br_2":"பனி படர்ந்த மலரின் கருமேக கருப்பு மற்றும் வெள்ளை குளோஸ்-அப் படம், மிகவும் உணர்ச்சிப்பூர்வமானது.","label_pic_br_3":"முன்புலத்தில் நாயுடன் தலையை ஒட்டி வைத்துகொண்டு செல்ஃபி எடுக்கும் புரோமினின் சுயவிவரப் படம்.","label_pic_cl_1":"தலையில் சன்கிளாசஸ் அணிந்துகொண்டு நீச்சல்குளத்தின் அருகே உள்ள சாய்வு நாற்காலியில் ஓய்வெடுக்கும் குளோரின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_cl_2":"மாமிசத்துடன் உணவுப்பொருட்கள் உள்ள பலகையைப் பெருமையுடன் காட்டும் குளோரின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_cl_3":"சுத்தம் செய்வதற்குப் பயன்படுத்தப்படும் தயாரிப்புகள் நிறைந்த பளபளக்கும் அலமாரிகளுக்கு முன்னால் நின்று செல்ஃபி எடுக்கும் குளோரின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_f_1":"பின்புறச் சுவற்றில் பல சான்றிதழ்கள் வைக்கப்பட்டிருக்கும் அறையில், பல் மருத்துவரின் கோட் அணிந்து தன் கால்களை டெஸ்க்கின் மீது வைத்துகொண்டு அமர்ந்திருக்கும் ஃபுளோரின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_f_2":"பின்புறச் சுவற்றில் பல சான்றிதழ்கள் வைக்கப்பட்டிருக்கும் அறையில், அலுவல் ஆடை அணிந்து தன் கால்களை டெஸ்க்கின் மீது வைத்துகொண்டு அமர்ந்திருக்கும் ஃபுளோரின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_f_3":"தன் நாயுடன் ஏசிக்கு முன்பாக அமர்ந்து குளிர்ந்த காற்றை அனுபவிக்கும் ஃபுளோரின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_h_1":"சூடான காற்று நிரம்பிய பலூனில் பயணிக்கும்போது கையசைக்கும் ஹைட்ரஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_h_2":"தன் கைகளை உயர்த்திப் பிடிப்பதைப் போன்று, ராக்கெட் ஏவப்படுவதைத் தூரத்தில் இருந்து பார்க்கும் ஹைட்ரஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_h_3":"தனது தொலைநோக்கி மூலம் வானத்திலுள்ள நட்சத்திரங்களைப் பார்க்கும் ஹைட்ரஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_i_1":"சற்றுமுன் பிடிக்கப்பட்ட பெரிய மீனைப் பெருமையுடன் கையில் பிடித்துக் கொண்டு கரையில் நிற்கும் அயோடின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_i_2":"ஸ்டாம்ப்பில் மையைத் தடவி பிரிண்ட்டுகளை எடுக்கும் அயோடின் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_i_3":"மேலிருந்து எடுக்கப்பட்ட, சுவை மிகுந்த ராமென் நூடுல்ஸ் உள்ள கிண்ணத்தின் படம்.","label_pic_n_1":"தாவரங்களால் சூழப்பட்ட கிரீன்ஹவுசில் இருக்கும் நைட்ரஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_n_2":"ஸ்கார்ஃப் அணிந்து தரையில் பனி தேவதைகளை உருவாக்கும் நைட்ரஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_n_3":"நேர்த்தியாகவும் அன்பாகவும் பேக் செய்யப்பட்ட லஞ்ச் பாக்ஸைக் காட்டும் நைட்ரஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_na_1":"டம்பெல் வைத்து உடற்பயிற்சி செய்துகொண்டே தனது கட்டான உடம்பைக் காட்டி ஜிம்மில் செல்ஃபி எடுக்கும் சோடியம் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_na_2":"சோடியம் கதாபாத்திரம் தனது நண்பர்களுடன் சேர்ந்து எடுத்துக்கொண்ட படம்.","label_pic_na_3":"ஜன்னலுக்கு வெளியே பனிப்பொழிவு, ஒரு மெழுகுவர்த்தி, ஆவிபறக்கும் கப், தனது கால்களைச் சுவர் மீது தூக்கி வைத்திருக்கும் சோடியம், அதன் மடியில் ஒரு புத்தகம் ஆகியவற்றுடன் சோடியம் கதாபாத்திரத்தின் கண்ணோட்டத்தில் இருந்து எடுக்கப்பட்ட வசதியான குளிர்காலக் காட்சியின் சுயவிவரப் படம்.","label_pic_o_1":"பேஸ்பால் தொப்பி அணிந்து பந்தயத்தில் ஓடும் ஆக்ஸிஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_o_2":"விரல்களைத் துப்பாக்கி சுடுவதுபோல் வைத்துக்கொண்டு ஜொலிக்கும் ரோஜாவை குறும்பாகப் பிடித்திருக்கும் ஆக்ஸிஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_pic_o_3":"மண்டியிட்டுக் கொண்டு தோட்டத்தில் வேலை செய்யும் ஆக்ஸிஜன் கதாபாத்திரத்தின் சுயவிவரப் படம்.","label_progress_quiz":"கேள்வி: [X]/5","label_swipe":"விருப்பம் தெரிவிக்க இதய பட்டனை நோக்கி வலதுபுறமாக ஸ்வைப் செய்யுங்கள், அடுத்ததற்குச் செல்ல X பட்டனை நோக்கி இடதுபுறமாக ஸ்வைப் செய்யுங்கள்","label_unknown":"அறியப்படாத பிணைப்பு","share_modal_button_close":"மூடு","share_modal_button_copied":"இணைப்பு நகலெடுக்கப்பட்டது","share_modal_button_facebook":"Facebook மூலம் பகிர்","share_modal_button_twitter":"X மூலம் பகிர்","share_modal_click_link":"இணைப்பை நகலெடு","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"பகிரலாம்","share_text":"உங்களுக்கு நல்ல கெமிஸ்ட்ரி உள்ளதா? இன்றைய தனிம வரிசை அட்டவணை அடிப்படையிலான காதலர் தினத்தில் உங்கள் சக தனிமங்களுடன் பிணைப்பை ஏற்படுத்த வலதுபுறமாக ஸ்வைப் செய்யுங்கள் #GoogleDoodle.","span_bond":"உங்களுக்கும் [%s]க்கும் நல்ல கெமிஸ்ட்ரி உள்ளது","span_bond_arf":"போதிய ஆற்றலும் அழுத்தமும் இருந்தால், இந்தப் பிணைப்பு தீவிர கவனம் செலுத்துவதாக இருக்கும். கண் அறுவை சிகிச்சைக்கு [ArF] லேசர்களைப் பயன்படுத்தி உங்கள் கண்களை இயல்பாகப் பார்க்க வைக்க முடியும்.","span_bond_br2":"நீங்கள் [Au] (தங்கத்தை) வென்றுள்ளீர்கள்! தாதுவில் காணப்படும் தங்கத்தைக் கரைப்பதற்கான மாற்று வழியாக, தங்கச் சுரங்கத்தில் [Br<2>] பயன்படுத்தப்படுகிறது. இது புரோமின் லீச்சிங் என்றும் குறிப்பிடப்படுகிறது.","span_bond_cl2":"மரத்திற்குப் பழுப்பு நிறத்தைக் கொடுக்கும் லிக்னின் கலவையை மரக் கூழில் இருந்து [Cl<2>] மூலம் பிரிக்க முடியும், அதன் பின் வெள்ளை நிறக் கூழைப் பயன்படுத்திக் காகிதம் செய்யலாம்.","span_bond_f2":"ஃபுளோரோகார்பன்களின் உற்பத்தியில் [F<2>] பயன்படுத்தப்படுகிறது, இவை உணவைக் குளிர்விக்கப் பயன்படும் குளிர்ப் பதனூட்டிகள். ஐஸ்கிரீமில் பிணைப்பை ஏற்படுத்த ஏற்றது.","span_bond_h2":"இந்த அணுக்கள் வானத்தில் மிதக்கின்றன. [H2] காற்றை விட இலகுவானவர், எனவே அவர் மீது காதல் வயப்படுவதில் ஆச்சரியமில்லை.","span_bond_hcl":"இந்த மூலக்கூறு காரமானது! [HCl] என்பது ஒரு வீரியமிக்க அமிலமாகும், இது உணவை ஜீரணிக்க உதவுகிறது. இரவோடு உறவாடச் சிறந்தது.","span_bond_hf":"கண்ணாடியில் அமைந்த இந்த இரட்டையர் கம்ப்யூட்டர் சிப்களுக்குப் பயன்படுத்தப்படும் சிலிக்கான் தகடுகளில் வடிவங்களை மும்முரமாக உருவாக்குகின்றனர்.","span_bond_hi":"[HI]க்கு ஹாய் சொல்லுங்கள்! தூய்மை முக்கியமானது, குறிப்பாக மருத்துவமனைகளில் இந்த மூலக்கூறு மருத்துவச் சாதனங்களைச் சுத்திகரிக்க உதவுகிறது.","span_bond_i2":"[I<2>] என்பது சிறந்த கிருமி நாசினியாகும். போவிடோன் என்று அழைக்கப்படும் மற்றொரு இரசாயனத்துடன் சேர்ந்து வெட்டுக்காயங்களையும் கீறல்களையும் கிருமிகள் அண்டாமல் வைத்திருக்க உதவுகிறது.","span_bond_ibr":"[IBr] என்பது பகுப்பாய்வு வேதியியலாளரின் நண்பராகும். அயோடோமெட்ரிக் டைட்ரேஷன் என்று அழைக்கப்படும் செயல்முறையில் ஒரு குறிப்பிட்ட இரசாயனத்தின் செறிவைத் தீர்மானிக்க, நிறத்தை மாற்றும் வேதிவினையில் இது பயன்படுத்தப்படுகிறது.","span_bond_n2":"காத்தாடி பறக்க விடலாம் வாருங்கள்! [N<2>] பூமியின் வளிமண்டலத்தில் 78% உள்ளது. உறவுகள் என்று வரும்போது, தனக்குத்தானே 3 பிணைப்புகள் கொண்ட மூலக்கூறுகள் சிறந்த இணைப்பைக் கொண்டுள்ளன. எப்பேர்ப்பட்ட சுய அன்பு!","span_bond_nabr":"இந்த இடம் சூடாக உள்ளதா அல்லது இந்தக் குளியல் தொட்டி மட்டும் சூடாக உள்ளதா? அந்தத் தண்ணீரை நன்றாகவும் சுத்தமாகவும் வைத்திருக்க [NaBr] விரும்புகிறது, இதன் மூலம் அவர்கள் கவனம் சிதறாமல் நேரத்தை நிம்மதியாக அனுபவிக்கலாம்.","span_bond_nacl":"எதிரெதிர்கள் ஈர்க்கும். [Na+] மற்றும் [Cl-] அயனிகள் ஒன்றிணைந்து நமக்கு உப்புப் பலகாரங்கள் செய்ய உதவுகின்றன.","span_bond_naf":"[NaF] உதவியால் உங்கள் முத்து போன்ற பற்களைக் காட்டி சிரிக்கலாம். உங்கள் பற்களை ஆரோக்கியமாக வைத்திருக்க, குடிநீரிலும் பற்பசையிலும் இந்த மூலக்கூறு சேர்க்கப்படுகிறது.","span_bond_nai":"அயோடின் குறைபாடுகளுக்கு எச்சரிக்கையாக இருங்கள், உங்கள் தைராய்டை ஆரோக்கியமாக வைத்திருக்க [NaI] உதவுகிறது. அயோடின் நிறைந்த உணவுகளுடன், NaI ஊட்டச்சத்து பொருட்களும் ஆரோக்கியமான வளர்சிதை மாற்றத்திற்கு உதவுகின்றன.","span_bond_nf":"சில பிணைப்புகள் நீடிப்பதில்லை. சரியான சூழலில், [NF] உருவாகி, அதற்கான பொலிவைக் கொடுத்துவிட்டு உற்சாகம் குறைந்ததும் விரைவாகப் பிரிந்துவிடும்.","span_bond_no":"மின்னல் ஒளியில் இந்த இரண்டும் ஒன்றாக வருகின்றன! மின்னலில் உள்ள வாயுக்கள் விரைவாக வெப்பமடைந்து குளிர்ச்சியடையும்போது, [NO] உருவாகிறது. காற்றின் தரத்திற்குச் சிறந்ததல்ல என்றாலும் மிகவும் உற்சாகமூட்டக்கூடியது.","span_bond_o2":"அதிகபட்சச் செயல்திறனுக்கு இந்த மூலக்கூறு அவசியம். மலை ஏறுபவர்கள் [O<2>] டேங்குகளின் உதவியுடன் மிக உயரமான இடங்களுக்குச் செல்கின்றனர்.","span_complete":"[%s]க்கான அனைத்து பிணைப்புகளையும் சேகரித்துவிட்டீர்கள்.","span_diatomic":"இரண்டு அணுக்களுக்கு இடையிலான பிணைப்பிலிருந்து ஈரணு மூலக்கூறுகள் உருவாக்கப்படுகின்றன. சில நேரங்களில் இது [H<2>] (ஹைட்ரஜன் வாயு) போன்ற ஒரே தனிமங்களுக்கு இடையிலான பிணைப்பாக இருக்கும், சில நேரங்களில் இது [HCl] (ஹைட்ரஜன் குளோரைடு) போன்ற இரண்டு வெவ்வேறு தனிமங்களுக்கு இடையிலான பிணைப்பாக இருக்கும்.","span_missed_notification":"அச்சச்சோ, உங்களுக்குள் நல்ல கெமிஸ்ட்ரி இருந்தது.","span_no_match_notification":"மன்னிக்கவும், பொருந்தவில்லை","span_profile_ar":"நான் மிகவும் நிலையானவர், தனிமையை நேசிப்பவர். நான் ஒருவருடன் பழக ஆரம்பித்தால் கடைசி வரையிலும் அவருக்கு உண்மையாக இருப்பேன். என் வயிற்றில் பட்டாம்பூச்சி பறப்பது போன்ற உணர்வை ஏற்படுத்துவது அவ்வளவு எளிதல்ல. ஆனால் அதைச் செய்ய நீண்ட நேரம் தேவையில்லை, சிறப்பான சிறிது நல்ல நேரமே போதும்.","span_profile_br":"என்னிடம் பலதரப்பட்ட குணங்கள் உள்ளன! நான் மாறிக்கொண்டே இருப்பேன், ஆனால் நான் தனியாக இருக்கும்போது நதிபோலச் செல்வேன். எனக்குப் புகைப் படம் எடுப்பதில் ஆர்வம் உண்டு, தீ அணைப்பதில் திறனும் உண்டு. அருமையாக உள்ளது, இல்லையா?","span_profile_cl":"தூய்மையின் மேல் ஆர்வம் இருந்தால் வலதுபுறமாக ஸ்வைப் செய்யுங்கள். நான் நன்கு ரியாக்ட் செய்யக்கூடிய நபர், நிச்சயம் ஏதோ ஒன்றில் நமக்குப் பிணைப்பு ஏற்படும், என் இனிமை திகட்டிவிடக்கூடும், பொறுமையாகவே பழகுவோம்.","span_profile_f":"அனைவரும் என்னிடம் மிக அதிகமாக ஈர்க்கப்படுகின்றனர். ஈர்ப்புத் தன்மைப் பற்றிப் பேசுகையில், ஆரோக்கியமான புன்னகையை நான் ரசிக்கிறேன். எனது துடிப்பான ஆற்றலும் உறுதியும் என்னைத் தனித்துக் காட்டுவதுடன் புதிய பிணைப்புகளை உருவாக்கிக் கொள்ளவும் உதவுகிறது.","span_profile_h":"உங்கள் வாழ்வின் மிக முக்கியமான நபராக இருக்க விரும்புகிறேன். நான் அனைத்தையும் எளிதாக எடுத்துக்கொண்டாலும், உங்கள் வாழ்வில் தவிர்க்க முடியாதவராக இருப்பேன். உண்மையில், இருப்பதிலேயே அதிகத் திறன்கள் வாய்ந்த அணு நான்தான் என்று சொல்வார்கள். உலோக இசையை விரும்பும் (கார உலோகங்கள்) குழுக்களுடனும், பிரபஞ்சத்தில் ஏறக்குறைய அனைத்து இடங்களிலும் என்னை நீங்கள் கண்டறியலாம்.","span_profile_i":"நான் உறுதியும், நம்பகத்தன்மையும், சமநிலையும் உள்ளவர் நான் அனைத்தையும் எளிதில் வேறுபடுத்தி அறிந்துகொள்வதால் முக்கியமான விஷயங்களைத் தனிப்படுத்திக் காட்டும் திறமை எனக்கு உள்ளது. அத்துடன் நான் அதிகச் சுத்தத்தை விரும்புபவர்.","span_profile_n":"நீங்கள் பறக்க நினைத்தால் காற்றில் 78% நான் இருப்பேன். நீங்கள் தனியாகச் செடி வளர்த்தால், துணையாக நான் வருவேன். உங்களை எப்போதும் சில்லென்றும், சமாதானத்தோடும் சமநிலையோடும் வைத்திருப்பேன், உங்களை உறையவிட்டுச் சென்றுவிடமாட்டேன்.","span_profile_na":"நான் பிறருடன் தொடர்ச்சியாகப் பிணைப்பை ஏற்படுத்துபவர். நான் தனியாக இருப்பதை விரும்புவதில்லை. ஆனால் அது நல்லதுதான், ஏனெனில் நான் இல்லாமல் உங்களால் வாழ முடியாது (உண்மையாகவே யாராலும் முடியாது). உடற்பயிற்சி செய்து உடலைக் கட்டுக்கோப்பாக வைத்திருக்க எனக்குப் பிடிக்கும். நான் உணர்வுகளை வெளிப்படுத்தக்கூடியவராக இருந்தாலும், அர்த்தமுள்ள உறவுகளை வளர்த்துக் கொள்வதிலும் விருப்பம் கொண்டவர்.","span_profile_notification":"வணக்கம், [%s]! உங்கள் பொருத்தத்தைக் கண்டறிய பிணைப்பை ஏற்படுத்துங்கள்.","span_profile_o":"நம்புங்கள், நான் உங்களுக்கு அவசியம். நீங்கள் சுவாசிக்கும் காற்று நான்தான். என்னைச் சுற்றியுள்ளவர்களுக்கு உற்சாகத்தை அளிப்பேன். நான் இருக்கும் சூழல்கள் செழிப்பாக இருப்பதை உறுதிசெய்து அதற்கு ஏற்ப மாற்றியமைக்கவும், வளர்ச்சியை அதிகரிக்கவும் என்னிடம் குறிப்பிடத்தக்க திறன் உள்ளது.","span_q1":"நிலையான வெப்பநிலை மற்றும் அழுத்தத்தில் ஒரு பொருள் மூன்று நிலைகளில் இருக்கும். அவை: வாயு, திரவம் மற்றும் திட நிலைகள்.","span_q2":"நட்சத்திரங்களில் காணப்படும் சில தனிமங்கள் பிரபஞ்சம் முழுவதும் அதிக அளவில் இருக்கும், ஆனால் வேறு சில தனிமங்கள் மிக அரிதாகவும் கண்டுபிடிக்கக் கடினமானதாகவும் இருக்கும்.","span_q3":"ஓர் அணுவின் புரோட்டான்கள், நியூட்ரான்கள், எலக்ட்ரான்கள் ஆகியவற்றின் நிறைகளைச் சேர்ப்பதன் மூலம் அணு நிறை தீர்மானிக்கப்படுகிறது.","span_q4":"ஓர் அணு எடுத்துக்கொள்ளும் காலியிடத்தின் கோள அளவானது வான் டெர் வால்ஸ் ஆரம் எனப்படும் மதிப்பால் விவரிக்கப்படுகிறது.","span_q5":"எலக்ட்ரான் கவர்திறன் என்பது ஒரு வேதியியல் பிணைப்பை உருவாக்கும்போது பகிரப்பட்ட எலக்ட்ரான்களை ஈர்க்கும் அணுவின் திறனாகும்.","span_swipe":"பிணைப்பை ஏற்படுத்த முடியும் என்று நீங்கள் நினைக்கும் தனிமங்களில் வலதுபுறமாக ஸ்வைப் செய்யுங்கள், உங்களுக்கு விருப்பமில்லை என்றால் இடதுபுறமாக ஸ்வைப் செய்யுங்கள்."}