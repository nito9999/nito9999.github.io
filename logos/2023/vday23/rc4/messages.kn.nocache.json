ು ನಿಮ್ಮತ್ತ ಆಕರ್ಷಿತರಾಗುತ್ತಾರೆಯೇ?","header_quiz":"ಮೂಲಧಾತುವಿನ ವ್ಯಕ್ತಿತ್ವದ ರಸಪ್ರಶ್ನೆ","header_select":"ನಿಮ್ಮ ಮೂಲಧಾತುವನ್ನು ಆಯ್ಕೆಮಾಡಿ","header_splash":"ನಿಮ್ಮ ಸಹವರ್ತಿ ಮೂಲಧಾತುಗಳ ಜೊತೆ ಬೆರೆಯಿರಿ","header_tap":"ಒಂದುಗೂಡಲು ಟ್ಯಾಪ್ ಮಾಡಿ ಮತ್ತು ಹೋಲ್ಡ್ ಮಾಡಿ","label_ar":"ಆರ್ಗಾನ್","label_bond_arf":"ಆರ್ಗಾನ್ ಮತ್ತು ಫ್ಲೋರೀನ್ ಪಾತ್ರಗಳು ಕ್ಯಾಟ್ ಕೆಫೆಯೊಂದರಲ್ಲಿ ಭೇಟಿಯಾಗಿವೆ, ಆರ್ಗಾನ್ ಲೇಸರ್ ಪಾಯಿಂಟರ್‌ನೊಂದಿಗೆ ಆಟವಾಡುತ್ತಿದ್ದರೆ, ಫ್ಲೋರೀನ್ ತನ್ನ ಮಡಿಲಲ್ಲಿ ಬೆಕ್ಕನ್ನು ಮಲಗಿಸಿಕೊಂಡು ಕುಳಿತಿದೆ, ಎಲ್ಲೆಡೆ ಬೆಕ್ಕುಗಳಿವೆ.","label_bond_br2":"ಬ್ಯಾಂಕ್ ದರೋಡೆಯಾಗುತ್ತಿದೆ, ಎರಡು ಬ್ರೋಮೀನ್ ಪಾತ್ರಗಳು ಬ್ಯಾಂಕ್‌ನ ತಿಜೋರಿಯಿಂದ ಬಂಗಾರದ ಬಾರ್‌ಗಳನ್ನು ಕದಿಯುತ್ತಿವೆ.","label_bond_cl2":"ಎರಡು ಕ್ಲೋರೀನ್ ಪಾತ್ರಗಳ ನಡುವಿನ ಒಂದು ಸುಮಧುರ ಕ್ಷಣ, ಒಂದು ಪಾತ್ರ ನಾಚಿಕೊಳ್ಳುತ್ತಿದ್ದರೆ ಮತ್ತೊಂದು ಪಾತ್ರವು ಅದು ನೆಲದ ಮೇಲೆ ಬೀಳಿಸಿರುವ ಕಾಗದಪತ್ರಗಳನ್ನು ಎತ್ತಿಕೊಳ್ಳಲು ಸಹಾಯ ಮಾಡುತ್ತಿದೆ.","label_bond_f2":"ಎರಡು ಫ್ಲೋರೀನ್ ಪಾತ್ರಗಳು ಐಸ್ ಕ್ರೀಂ ತಿನ್ನಲು ಹೊರಬಂದಿವೆ, ಒಂದು ಪಾತ್ರ ತನ್ನ ಐಸ್ ಕ್ರೀಂ ಬೀಳಿಸಿಕೊಂಡಿದೆ, ಆದರೆ ಚಿಂತೆ ಬೇಡ, ಮತ್ತೊಂದು ಪಾತ್ರ ತನ್ನದನ್ನು ಹಂಚಿಕೊಳ್ಳಲು ತಯಾರಿದೆ.","label_bond_h2":"ಕೈಹಿಡಿದುಕೊಂಡು, ಆಕಾಶದಲ್ಲಿ ಸಾಗುತ್ತಿರುವ ಶೂಟಿಂಗ್ ಸ್ಟಾರ್‌ಗಳ ಜೋಡಿಯನ್ನು ನೋಡುತ್ತಿರುವ ಎರಡು ಜಲಜನಕದ ಪಾತ್ರಗಳು.","label_bond_hcl":"ಜಲಜನಕ ಮತ್ತು ಕ್ಲೋರೀನ್ ಪಾತ್ರಗಳು ರೆಸ್ಟೋರೆಂಟ್ ಒಂದರಲ್ಲಿ ಜೊತೆಯಾಗಿ ರೊಮ್ಯಾಂಟಿಕ್ ಭೋಜನ ಸವಿಯುತ್ತಿವೆ.","label_bond_hf":"ಸರ್ಕಿಟ್ ಬೋರ್ಡ್ ಒಂದರಲ್ಲಿ ಜಲಜನಕ ಮತ್ತು ಫ್ಲೋರೀನ್ ಪಾತ್ರಗಳನ್ನು ಕಂಪ್ಯೂಟರ್ ಚಿಪ್‌ಗಳಂತೆ ಅಕ್ಕಪಕ್ಕ ಇರಿಸಲಾಗಿದೆ ಮತ್ತು ಅವುಗಳ ನಡುವಿನ ಸರ್ಕಿಟ್‌ಗಳು ಹೃದಯದ ಆಕಾರವನ್ನು ಮೂಡಿಸಿವೆ.","label_bond_hi":"ಬೇಸ್‌ಬಾಲ್ ಟೋಪಿ ಧರಿಸಿ ಹೂಗುಚ್ಛವನ್ನು ಹಿಡಿದಿರುವ ಜಲಜನಕದ ಪಾತ್ರವು ತಲೆಗೆ ಬ್ಯಾಂಡೇಜ್ ಕಟ್ಟಿಕೊಂಡು ಆಸ್ಪತ್ರೆಯಲ್ಲಿರುವ ಐಯೋಡೀನ್ ಪಾತ್ರವನ್ನು ಕಾಣಲು ಬಂದಿದೆ.","label_bond_i2":"ಎರಡು ಐಯೋಡೀನ್ ಪಾತ್ರಗಳು ಡಾಕ್‌ನಲ್ಲಿ ಮೀನು ಹಿಡಿಯುತ್ತಿವೆ, ಒಂದು ಪಾತ್ರ ಮತ್ತೊಂದು ಪಾತ್ರದ ಗಾಯಗೊಂಡ ಕಾಲಿಗೆ ಬ್ಯಾಂಡೇಜ್ ಹಾಕಲು ನೆರವಾಗುತ್ತಿದ್ದರೆ, ಮೀನು ತಪ್ಪಿಸಿಕೊಂಡು ಹೋಗುತ್ತಿದೆ.","label_bond_ibr":"ಬೇಸ್‌ಬಾಲ್ ಟೋಪಿ ಧರಿಸಿದ ಬ್ರೋಮೀನ್ ಪಾತ್ರವು ಹೂಗುಚ್ಛದಿಂದ ಹೂವೊಂದನ್ನು ತನಗೆ ತೆಗೆದುಕೊಡುತ್ತಿದ್ದರೆ, ಅದನ್ನು ಕಂಡು ಐಯೋಡೀನ್ ಪಾತ್ರ ನಾಚಿಕೊಳ್ಳುತ್ತಿದೆ.","label_bond_n2":"ಹುಲ್ಲು ಬೆಳೆದಿರುವ ಮೈದಾನದಲ್ಲಿ ಜೊತೆಯಾಗಿ ಹೃದಯದ ಆಕಾರದ ಗಾಳಿಪಟಗಳನ್ನು ಹಾರಿಸುತ್ತಿರುವ ಸಾರಜನಕದ ಪಾತ್ರಗಳ ಓವರ್‌ಹೆಡ್ ದೃಶ್ಯ.","label_bond_nabr":"ಚಳಿಗಾಲದಲ್ಲಿ ಸೋಡಿಯಂ ಮತ್ತು ಬ್ರೋಮೈಡ್ ತಮ್ಮ ಮನೆಯ ಹಾಟ್ ಟ್ಯೂಬ್ ಒಂದರಲ್ಲಿ ವಿರಮಿಸುತ್ತಿವೆ, ಹಿನ್ನೆಲೆಯಲ್ಲಿ ಅವುಗಳ ಸಾಕುನಾಯಿ ಅತ್ತಿಂದಿತ್ತ ಓಡುತ್ತಿದೆ.","label_bond_nacl":"ಸೋಡಿಯಂ ಮತ್ತು ಕ್ಲೋರೀನ್ ಪಾತ್ರಗಳು ಮನೆಯಲ್ಲಿ ಒಟ್ಟಿಗೆ ಚಲನಚಿತ್ರ ವೀಕ್ಷಿಸುತ್ತಿವೆ, ಪಾಪ್‌ಕಾರ್ನ್ ಹಂಚಿಕೊಂಡು ತಿನ್ನುತ್ತಿವೆ, ಸುತ್ತಲೂ ಇತರ ತಿಂಡಿಗಳಿವೆ.","label_bond_naf":"ಸೋಡಿಯಂ ಮತ್ತು ಫ್ಲೋರೀನ್ ಪಾತ್ರಗಳು ಒಂದು ಡ್ರಿಂಕ್ ಹಂಚಿಕೊಳ್ಳುತ್ತಿವೆ, ಪ್ರತಿ ಪಾತ್ರದ ಬಳಿಯೂ ಹೃದಯದ ಆಕಾರದಲ್ಲಿ ಬಾಗಿರುವ ಸ್ಟ್ರಾಗಳಿವೆ.","label_bond_nai":"ಸೋಡಿಯಂ ಮತ್ತು ಐಯೋಡೀನ್ ಪಾತ್ರಗಳು ಹುಲ್ಲು ಬೆಳೆದ ಮೈದಾನದಲ್ಲಿರುವ ಕೊಳದ ಪಕ್ಕ ಒಟ್ಟಿಗೆ ಪಿಕ್ನಿಕ್ ಮಾಡುತ್ತಿವೆ, ಐಯೋಡೀನ್ ಸೋಡಿಯಂಗೆ ಚಿಪ್ಸ್ ತಿನ್ನಿಸುತ್ತಿದೆ.","label_bond_nf":"ಸಾರಜನಕ ಮತ್ತು ಫ್ಲೋರೀನ್ ಪಾತ್ರಗಳು ಮರದ ದಿಮ್ಮಿಗಳ ಮೇಲೆ ಕುಳಿತು ಬೆಂಕಿಗೆ ಮೈಕಾಯಿಸಿಕೊಳ್ಳುತ್ತಿರುವ ಕ್ಯಾಂಪ್‌ಫೈರ್‌ನ ದೃಶ್ಯ.","label_bond_no":"ಬಿರುಗಾಳಿ ಸಹಿತ ಮಳೆ ಸುರಿಯುತ್ತಿರುವಾಗ ಸಾರಜನಕದ ಪಾತ್ರ ಮತ್ತು ಆಮ್ಲಜನಕದ ಪಾತ್ರ ಒಂದೇ ಛತ್ರಿಯಡಿ ಜೊತೆಯಾಗಿ ರಸ್ತೆ ದಾಟುತ್ತಿವೆ.","label_bond_o2":"ಎರಡು ಆಮ್ಲಜನಕದ ಪಾತ್ರಗಳು ಜೊತೆಯಾಗಿ ಹೈಕಿಂಗ್ ಪ್ರವಾಸಕ್ಕೆ ತೆರಳಿವೆ, ದೂರದ ಪರ್ವತದ ಹಿನ್ನೆಲೆಯಲ್ಲಿ ಪರಸ್ಪರರ ಹೆಗಲ ಮೇಲೆ ಕೈಹಾಕಿಕೊಂಡು ಪೋಸ್ ಕೊಡುತ್ತಿವೆ, ಒಂದು ಪಾತ್ರ ವಾಕಿಂಗ್ ಸ್ಟಿಕ್ ಹಿಡಿದು, ತಲೆಗೆ ಸನ್‌ಗ್ಲಾಸ್ ಸಿಕ್ಕಿಸಿಕೊಂಡಿದೆ, ಮತ್ತೊಂದು ಪಾತ್ರ ಬೀನೀ ಧರಿಸಿದೆ ಮತ್ತು ಎರಡೂ ಪಾತ್ರಗಳು ಸ್ಕಾರ್ಫ್ ತೊಟ್ಟಿವೆ.","label_br":"ಬ್ರೋಮೀನ್","label_carousel_indicator":"3 ರಲ್ಲಿ [X] ನೇ ಚಿತ್ರ","label_cl":"ಕ್ಲೋರೀನ್","label_f":"ಫ್ಲೋರೀನ್","label_h":"ಜಲಜನಕ","label_header_logo":"Google ಲೋಗೋ","label_i":"ಐಯೋಡೀನ್","label_logo_big":"ಕೆಮಿಸ್ಟ್ರಿ [CuPd] ಲೋಗೋ","label_mystery":"ನಿಗೂಢ ಮೂಲಧಾತು","label_n":"ಸಾರಜನಕ","label_na":"ಸೋಡಿಯಂ","label_o":"ಆಮ್ಲಜನಕ","label_pic_ar_1":"ಪ್ಯಾಚ್‌ವರ್ಕ್ ಲೋಹದ ಹೃದಯದ ಕಲಾಕೃತಿಯೆದುರು ಹಾರುತ್ತಿರುವ ಕಿಡಿಗಳ ನಡುವೆ ವೆಲ್ಡಿಂಗ್ ಮಾಸ್ಕ್ ಧರಿಸಿ ಏನನ್ನೋ ವೆಲ್ಡ್ ಮಾಡುತ್ತಿರುವ ಆರ್ಗಾನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_ar_2":"ಬೆಕ್ಕೊಂದನ್ನು ತನ್ನ ಮಡಿಲಿನಲ್ಲಿ ಬೆಚ್ಚಗೆ ಮಲಗಿಸಿಕೊಂಡು ತನ್ನ ಫೋನ್‌ ಬಳಸುತ್ತಿರುವ ಆರ್ಗಾನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_ar_3":"ತನ್ನ ಬೆಕ್ಕನ್ನು ಮಡಿಲಿನಲ್ಲಿ ಕೂರಿಸಿಕೊಂಡು ಹೆಡ್‌ಫೋನ್‌ಗಳನ್ನು ಧರಿಸಿ ತನ್ನ ಮೌಸ್ ಮತ್ತು ಕೀಬೋರ್ಡ್‌ನಲ್ಲಿ ಆನ್‌ಲೈನ್ ಗೇಮ್‌ಗಳನ್ನು ಆಡುತ್ತಿರುವ ಆರ್ಗಾನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_br_1":"ಫೈರ್ ಎಂಜಿನ್‌ನ ಮುಂದಿನ ಬಂಪರ್‌ನ ಮೇಲೆ ತನ್ನ ಫೈರ್‌ಫೈಟರ್ ಟೋಪಿ ಧರಿಸಿ ಕುಳಿತಿರುವ ಬ್ರೋಮೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_br_2":"ಇಬ್ಬನಿಯ ಹನಿಯಿರುವ ಹೂವೊಂದರ ಮೂಡಿ ಕಪ್ಪು-ಬಿಳುಪು ಕ್ಲೋಸ್-ಅಪ್ ಫೋಟೋಗ್ರಾಫ್, ಬಹಳ ಭಾವನಾತ್ಮಕವಾಗಿದೆ.","label_pic_br_3":"ಸೆಲ್ಫೀ ತೆಗೆದುಕೊಳ್ಳುತ್ತಿರುವ ಬ್ರೋಮೀನ್‌ನ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ, ಮುನ್ನೆಲೆಯಲ್ಲಿ ಬ್ರೋಮೀನ್‌ನ ಸಾಕುನಾಯಿ ತನ್ನ ತಲೆಯನ್ನು ಚಾಚಿದೆ.","label_pic_cl_1":"ತಲೆಗೆ ಸನ್‌ಗ್ಲಾಸ್ ಸಿಕ್ಕಿಸಿಕೊಂಡು ಪೂಲ್ ಬಳಿಯ ಡೆಕ್ ಚೇರ್‌ನಲ್ಲಿ ಒಂದು ಬದಿಗೆ ಹೊರಳಿ ಹಾಯಾಗಿ ಮಲಗಿರುವ ಕ್ಲೋರೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_cl_2":"ತನ್ನ ಚಾರ್ಕುಟೇರಿ ಬೋರ್ಡ್ ಅನ್ನು ಹೆಮ್ಮೆಯಿಂದ ತೋರಿಸುತ್ತಿರುವ ಕ್ಲೋರೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_cl_3":"ಸ್ವಚ್ಛತಾ ಉತ್ಪನ್ನಗಳಿಂದ ತುಂಬಿರುವ ಹೊಳೆಯುವ ಶೆಲ್ಫ್‌ಗಳ ಎದುರು ಸೆಲ್ಫೀ ತೆಗೆದುಕೊಳ್ಳುತ್ತಿರುವ ಕ್ಲೋರೀನ್‌ನ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_f_1":"ಡೆಂಟಿಸ್ಟ್ ಕೋಟ್ ಧರಿಸಿ ತನ್ನ ಡೆಸ್ಕ್‌ನ ಮೇಲೆ ಕಾಲಿಟ್ಟುಕೊಂಡು ಪ್ರಮಾಣಪತ್ರಗಳಿಂದ ಮುಚ್ಚಿಹೋಗಿರುವ ಗೋಡೆಯ ಮುಂದೆ ಕುಳಿತ ಫ್ಲೋರೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_f_2":"ಬಿಸಿನೆಸ್ ಸೂಟ್ ಧರಿಸಿ ತನ್ನ ಡೆಸ್ಕ್‌ನ ಮೇಲೆ ಕಾಲಿಟ್ಟುಕೊಂಡು ಪ್ರಮಾಣಪತ್ರಗಳಿಂದ ಮುಚ್ಚಿಹೋಗಿರುವ ಗೋಡೆಯ ಮುಂದೆ ಕುಳಿತ ಫ್ಲೋರೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_f_3":"ತನ್ನ ಸಾಕುನಾಯಿಯ ಜೊತೆ ತನ್ನ AC ಯೂನಿಟ್‌ನ ಎದುರು ತಂಪಾದ ಗಾಳಿಯನ್ನು ಆನಂದಿಸುತ್ತ ಕುಳಿತ ಫ್ಲೋರೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_h_1":"ಹಾಟ್ ಏರ್ ಬಲೂನ್ ಸವಾರಿ ಮಾಡುತ್ತಾ ಕೈಬೀಸುತ್ತಿರುವ ಜಲಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_h_2":"ದೂರದಲ್ಲಿ ಒಂದು ರಾಕೆಟ್ ಉಡಾವಣೆಯಾಗುತ್ತಿರುವುದನ್ನು ವೀಕ್ಷಿಸುತ್ತಾ, ಅದಕ್ಕೆ ಸಣ್ಣದಾಗಿ ಚಿವುಟಲು ತನ್ನ ಕೈ ಎತ್ತಿಹಿಡಿದಿರುವ ಜಲಜನಕದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_h_3":"ತನ್ನ ಟೆಲಿಸ್ಕೋಪ್ ಮೇಲೆತ್ತಿ ನಕ್ಷತ್ರಗಳತ್ತ ನೋಡುತ್ತಿರುವ ಜಲಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_i_1":"ತಾನು ಈಗಷ್ಟೇ ಹಿಡಿದ ಮೀನನ್ನು ಹೆಮ್ಮೆಯಿಂದ ತೋರಿಸುತ್ತಾ ಡಾಕ್ ಮೇಲೆ ನಿಂತಿರುವ ಐಯೋಡೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ, ಮೀನು ಬಹಳ ದೊಡ್ಡದಿದೆ.","label_pic_i_2":"ಸ್ಟ್ಯಾಂಪ್ ಒಂದರ ಮೇಲೆ ಶಾಯಿಯನ್ನು ರೋಲ್ ಮಾಡುತ್ತಾ ಮುದ್ರಣ ಮಾಡುತ್ತಿರುವ ಐಯೋಡೀನ್ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_i_3":"ರುಚಿಕರ ರಾಮೆನ್‌ನ ಬಟ್ಟಲಿನ ಓವರ್‌ಹೆಡ್ ಫೋಟೋ.","label_pic_n_1":"ಗ್ರೀನ್‌ಹೌಸ್ ಒಂದರಲ್ಲಿ ಸಸ್ಯಗಳಿಂದ ಆವೃತವಾಗಿರುವ ಸಾರಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_n_2":"ಸ್ಕಾರ್ಫ್ ಧರಿಸಿ ನೆಲದ ಮೇಲೆ ಸ್ನೋ ಏಂಜೆಲ್‌ಗಳನ್ನು ನಿರ್ಮಿಸುತ್ತಿರುವ ಸಾರಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_n_3":"ತಾನು ಒಪ್ಪವಾಗಿ ಮತ್ತು ಪ್ರೀತಿಯಿಂದ ಪ್ಯಾಕ್ ಮಾಡಿರುವ ಲಂಚ್‌ಬಾಕ್ಸ್ ನಿಮಗೆ ತೋರಿಸುತ್ತಿರುವ ಸಾರಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_na_1":"ಡಂಬ್‌ಬೆಲ್‌ನೊಂದಿಗೆ ಕರ್ಲ್‌ಗಳನ್ನು ಮಾಡುತ್ತಾ ತನ್ನ ಆ್ಯಬ್ಸ್ ಪ್ರದರ್ಶಿಸುತ್ತಾ ಜಿಮ್ ಸೆಲ್ಫೀ ತೆಗೆದುಕೊಳ್ಳುತ್ತಿರುವ ಸೋಡಿಯಂ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ","label_pic_na_2":"ತನ್ನ ಸ್ನೇಹಿತರ ಜೊತೆಗಿರುವ ಸೋಡಿಯಂ ಪಾತ್ರದ ಗುಂಪು ಶಾಟ್.","label_pic_na_3":"ಸೋಡಿಯಂನ ದೃಷ್ಟಿಕೋನದಿಂದ ಚಳಿಗಾಲದ ಆತ್ಮೀಯ ದೃಶ್ಯವೊಂದರ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ, ಇದರಲ್ಲಿ ಕಿಟಕಿಯ ಹೊರಗೆ ಹಿಮಪಾತವಾಗುತ್ತಿದೆ, ಒಂದು ಕ್ಯಾಂಡಲ್ ಮತ್ತು ಹಬೆಯಾಡುತ್ತಿರುವ ಮಗ್ ಇದೆ, ಸೋಡಿಯಂ ತನ್ನ ಕಾಲುಗಳನ್ನು ಮೇಲಿಟ್ಟುಕೊಂಡು ತೊಡೆಯ ಮೇಲೆ ಪುಸ್ತಕ ಇಟ್ಟುಕೊಂಡಿದೆ.","label_pic_o_1":"ಬೇಸ್‌ಬಾಲ್ ಟೋಪಿ ಧರಿಸಿ, ರೇಸ್‌ನಲ್ಲಿ ಓಡುತ್ತಿರುವ ಆಮ್ಲಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_o_2":"ಬೆರಳಿನಲ್ಲಿ ಗನ್ ಸಂಕೇತ ತೋರಿಸುತ್ತಾ ತನ್ನ ಬಾಯಲ್ಲಿ ಹೊಳೆಯುವ ಗುಲಾಬಿಯನ್ನು ತಮಾಷೆಯಾಗಿ ಹಿಡಿದುಕೊಂಡಿರುವ ಆಮ್ಲಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_pic_o_3":"ತನ್ನ ಹೂದೋಟದಲ್ಲಿ ಕೆಲಸ ಮಾಡುತ್ತಿರುವಾಗ ಮಂಡಿಯೂರಿ ಕುಳಿತಿರುವ ಆಮ್ಲಜನಕದ ಪಾತ್ರದ ಪ್ರೊಫೈಲ್ ಚಿತ್ರ.","label_progress_quiz":"5 ರಲ್ಲಿ [X] ನೇ ಪ್ರಶ್ನೆ","label_swipe":"ಲೈಕ್ ಮಾಡಲು ಹೃದಯದ ಬಟನ್‌ನತ್ತ ರೈಟ್ ಸ್ವೈಪ್ ಮಾಡುತ್ತಿರುವ ಮತ್ತು ನಿರಾಕರಿಸಲು X ಬಟನ್‌ನತ್ತ ಲೆಫ್ಟ್ ಸ್ವೈಪ್ ಮಾಡುತ್ತಿರುವ ಕೈ","label_unknown":"ಅಪರಿಚಿತ ಬಾಂಡ್","share_modal_button_close":"ಮುಚ್ಚಿರಿ","share_modal_button_copied":"ಲಿಂಕ್ ಕಾಪಿ ಮಾಡಲಾಗಿದೆ","share_modal_button_facebook":"Facebook ಮೂಲಕ ಹಂಚಿಕೊಳ್ಳಿ","share_modal_button_twitter":"X ಮೂಲಕ ಹಂಚಿಕೊಳ್ಳಿ","share_modal_click_link":"ಲಿಂಕ್ ಕಾಪಿ ಮಾಡಿ","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"ಹಂಚಿಕೊಳ್ಳಿ","share_text":"ನಿಮ್ಮ ಕೆಮಿಸ್ಟ್ರಿ ಚೆನ್ನಾಗಿದೆಯೇ? ಇಂದಿನ ಆವರ್ತ ಕೋಷ್ಟಕ ಸಂಚಾಲಿತ ಪ್ರೇಮಿಗಳ ದಿನದ #GoogleDoodle ನಲ್ಲಿ ನಿಮ್ಮ ಸಹಚರ ಮೂಲಧಾತುಗಳ ಜೊತೆ ಬೆರೆಯಲು ರೈಟ್ ಸ್ವೈಪ್ ಮಾಡಿ.","span_bond":"ನಿಮ್ಮ ಮತ್ತು [%s] ನಡುವೆ ಒಳ್ಳೆಯ ಕೆಮಿಸ್ಟ್ರಿಯಿದೆ","span_bond_arf":"ಸಾಕಷ್ಟು ಶಕ್ತಿ ಮತ್ತು ಒತ್ತಡವಿದ್ದಾಗ, ಈ ಬಾಂಡ್ ತೀಕ್ಷ್ಣವಾದ ಫೋಕಸ್ ಹೊಂದಿರುತ್ತದೆ. ನೀವು 20/20 ವಿಷನ್‌ನಲ್ಲಿ ನೋಡುತ್ತಲೇ ಇರುವಂತೆ ಮಾಡಲು ಕಣ್ಣಿನ ಶಸ್ತ್ರಚಿಕಿತ್ಸೆಗಾಗಿ [ArF] ಲೇಸರ್‌ಗಳನ್ನು ಬಳಸಬಹುದು.","span_bond_br2":"ನೀವು [Au] (ಬಂಗಾರ) ಗಳಿಸಿದ್ದೀರಿ! ಬಂಗಾರದ ಗಣಿಗಾರಿಕೆಯಲ್ಲಿ, ಅದಿರಿನಲ್ಲಿ ಸಿಗುವ ಬಂಗಾರವನ್ನು ಕರಗಿಸುವ ಪರ್ಯಾಯ ವಿಧಾನವಾಗಿ [Br<2>] ಅನ್ನು ಬಳಸಲಾಗುತ್ತದೆ, ಈ ಪ್ರಕ್ರಿಯೆಯನ್ನು ಬ್ರೋಮೀನ್ ಲೀಚಿಂಗ್ ಎಂದು ಕರೆಯಲಾಗುತ್ತದೆ.","span_bond_cl2":"[Cl<2>] ಮರದ ಪಲ್ಪ್‌ನಲ್ಲಿರುವ, ಮರಕ್ಕೆ ಕಂದು ಬಣ್ಣವನ್ನು ನೀಡುವ ಸಂಯುಕ್ತವಾದ ಲಿಗ್ನಿನ್ ಅನ್ನು ಒಡೆಯಬಲ್ಲದು, ಇದು ಕಾಗದ ತಯಾರಿಕೆಗಾಗಿ ಬಿಳಿ ಪಲ್ಪ್ ಅನ್ನು ಬಳಸಲು ನಮಗೆ ಅನುವು ಮಾಡಿಕೊಡುತ್ತದೆ.","span_bond_f2":"[F<2>] ಅನ್ನು ಫ್ಲೋರೋಕಾರ್ಬನ್‌ಗಳ ತಯಾರಿಕೆಯಲ್ಲಿ ಬಳಸಲಾಗುತ್ತದೆ, ಅವು ಆಹಾರವನ್ನು ತಣ್ಣಗಿಡಲು ಬಳಸಲಾಗುವ ರೆಫ್ರಿಜರೆಂಟ್‌ಗಳಾಗಿವೆ. ಐಸ್ ಕ್ರೀಂ ತಿನ್ನುತ್ತಾ ಪರಸ್ಪರ ಬೆರೆಯಲು ಅತ್ಯಂತ ಸೂಕ್ತ.","span_bond_h2":"ಈ ಪರಮಾಣುಗಳು ಆನಂದದಲ್ಲಿ ತೇಲುತ್ತಿವೆ. [H2] ಗಾಳಿಗಿಂತ ಹಗುರ, ಹಾಗಾಗಿ ನೀವೇನಾದರೂ ತೇಲತೊಡಗಿದರೆ ಆಶ್ಚರ್ಯ ಪಡಬೇಡಿ.","span_bond_hcl":"ಈ ಮಾಲಿಕ್ಯೂಲ್ ಖಾರವಾಗಿದೆ! [HCl] ಶಕ್ತಿಶಾಲಿ ಆಮ್ಲವಾಗಿದ್ದು ಆಹಾರವನ್ನು ಜೀರ್ಣಿಸಿಕೊಳ್ಳಲು ನಮಗೆ ಸಹಾಯ ಮಾಡುತ್ತದೆ. ಊಟ ಮಾಡುತ್ತ ಬಾಂಧವ್ಯ ಬೆಳೆಸಿಕೊಳ್ಳಲು ಇದು ಅತ್ಯುತ್ತಮವಾದದ್ದು.","span_bond_hf":"ಗಾಜಿನ ಮೇಲೆ ಎಚಿಂಗ್ ಮಾಡುವ ಜೋಡಿಯು, ಕಂಪ್ಯೂಟರ್ ಚಿಪ್‌ಗಳಲ್ಲಿ ಬಳಸಲಾಗುವ ಸಿಲಿಕಾನ್ ವೇಫರ್‌ಗಳ ಮೇಲೆ ವಿನ್ಯಾಸಗಳನ್ನು ಕೆತ್ತುವುದರಲ್ಲಿ ವ್ಯಸ್ತವಾಗಿದೆ.","span_bond_hi":"[HI] ಅವರಿಗೆ ಹಾಯ್ ಹೇಳಿ! ಸ್ವಚ್ಛತೆ ಬಹಳ ಮುಖ್ಯ, ವಿಶೇಷವಾಗಿ ಆಸ್ಪತ್ರೆಗಳಲ್ಲಿ. ಅಲ್ಲಿ ಈ ಮಾಲಿಕ್ಯೂಲ್ ವೈದ್ಯಕೀಯ ಟೂಲ್‌ಗಳ ಸೋಂಕು ನಿವಾರಣೆಯಲ್ಲಿ ನೆರವಾಗುತ್ತದೆ.","span_bond_i2":"[I<2>] ಒಂದು ಅದ್ಭುತ ಆ್ಯಂಟಿಸೆಪ್ಟಿಕ್ ಆಗಿದೆ, ಮತ್ತು ಪೊವಿಡೋನ್ ಎಂಬ ಮತ್ತೊಂದು ರಾಸಾಯನಿಕದ ಜೊತೆಗೂಡಿ ಸೀಳುಗಾಯ ಮತ್ತು ತರಚುಗಾಯಗಳಿಂದ ಸೂಕ್ಷ್ಮಾಣುಗಳನ್ನು ದೂರವಿಡಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ.","span_bond_ibr":"[IBr] ಒಬ್ಬ ಅನಾಲಿಟಿಕಲ್ ಕೆಮಿಸ್ಟ್‌ನ ಸ್ನೇಹಿತ. ಐಯೋಡೋಮೆಟ್ರಿಕ್ ಟೈಟ್ರೇಷನ್ ಎಂಬ ಪ್ರಕ್ರಿಯೆಯಲ್ಲಿ, ನಿರ್ದಿಷ್ಟ ರಾಸಾಯನಿಕವೊಂದರ ಸಾರತೆಯನ್ನು ಕಂಡುಹಿಡಿಯಲು ಬಣ್ಣ-ಬದಲಾಯಿಸುವ ರಾಸಾಯನಿಕ ಕ್ರಿಯೆಗಳಲ್ಲಿ ಅದನ್ನು ಬಳಸಲಾಗುತ್ತದೆ.","span_bond_n2":"ಬನ್ನಿ ಗಾಳಿಪಟ ಹಾರಿಸೋಣ! [N<2>] ಭೂಮಿಯ ವಾತಾವರಣದ 78% ರಷ್ಟನ್ನು ಆವರಿಸಿಕೊಂಡಿದೆ. ಸಂಬಂಧಗಳ ವಿಚಾರಕ್ಕೆ ಬಂದಾಗ, ಈ ಮೂರು ಬಾಂಡ್‌ಗಳುಳ್ಳ ಮಾಲಿಕ್ಯೂಲ್ ಸರಿಸಾಟಿಯಿಲ್ಲದ ನಂಟನ್ನು ಹೊಂದಿದೆ. ಸ್ವ-ಪ್ರೇಮದ ಗುರಿಗಳೆಂದರೆ ಹೀಗಿರಬೇಕು!","span_bond_nabr":"ಇಲ್ಲಿ ಸೆಖೆ ಇದೆಯೇ ಅಥವಾ ಈ ಟಬ್ ಬಿಸಿಯಾಗಿದೆಯೇ? ಉತ್ತಮ ಗುಣಮಟ್ಟದ ವಿರಾಮದ ಸಮಯವನ್ನು ಕಳೆಯುವುದಕ್ಕಾಗಿ [NaBr] ನೀರನ್ನು ಆಕರ್ಷಕ ಮತ್ತು ಸ್ವಚ್ಛವಾಗಿಡಲು ಬಯಸುತ್ತದೆ.","span_bond_nacl":"ವಿರುದ್ಧ ಅಂಶಗಳು ಪರಸ್ಪರ ಆಕರ್ಷಿತವಾಗುತ್ತವೆ. [Na+] ಮತ್ತು [Cl-] ಐಯಾನ್‌ಗಳು ಜೊತೆ ಸೇರುತ್ತವೆ ಮತ್ತು ಉಪ್ಪುಪ್ಪಾದ ತಿನಿಸುಗಳನ್ನು ಸವಿಯುವ ನಮ್ಮ ಕನಸನ್ನು ನನಸಾಗಿಸುತ್ತವೆ.","span_bond_naf":"ಮುತ್ತಿನಂತೆ ಬೆಳ್ಳಗೆ ಹೊಳೆಯುವ ಆ ನಿಮ್ಮ ಹಲ್ಲುಗಳಿಗಾಗಿ [NaF] ಗೆ ಧನ್ಯವಾದ ತಿಳಿಸಿ. ನಿಮ್ಮ ಹಲ್ಲುಗಳನ್ನು ಆರೋಗ್ಯವಾಗಿಡುವ ಸಲುವಾಗಿ ಈ ಮಾಲಿಕ್ಯೂಲ್ ಅನ್ನು ಕುಡಿಯುವ ನೀರು ಮತ್ತು ಟೂತ್‌ಪೇಸ್ಟ್‌ಗೆ ಸೇರಿಸಲಾಗುತ್ತದೆ.","span_bond_nai":"ಐಯೋಡೀನ್ ಕೊರತೆಗಳೇ ಎಚ್ಚರ, ನಿಮ್ಮ ಥೈರಾಯ್ಡ್ ಅನ್ನು ಖುಷಿಯಾಗಿಡಲು ಇದೋ ಇಲ್ಲಿದೆ [NaI]. ಎಲ್ಲಾ ಐಯೋಡೀನ್-ಭರಿತ ಆಹಾರಗಳ ಜೊತೆಗೆ, NaI ಸಪ್ಲಿಮೆಂಟ್‌ಗಳು ಆರೋಗ್ಯಕರ ಚಯಾಪಚಯ ಕ್ರಿಯೆಯನ್ನು ಬೆಂಬಲಿಸುತ್ತವೆ.","span_bond_nf":"ಕೆಲವು ಬಾಂಡ್‌ಗಳು ಶಾಶ್ವತವಾಗಿರುವುದಿಲ್ಲ. ಸರಿಯಾದ ಪರಿಸ್ಥಿತಿಗಳಲ್ಲಿ, [NF] ರಚನೆಯಾಗುತ್ತದೆ, ವಿಶಿಷ್ಟ ಹೊಳಪನ್ನು ಹೊರಸೂಸುತ್ತದೆ, ಆದರೆ ಉತ್ಸಾಹ ತಣ್ಣಗಾದ ನಂತರ ತ್ವರಿತವಾಗಿ ಪ್ರತ್ಯೇಕವಾಗುತ್ತದೆ.","span_bond_no":"ಮಿಂಚು ಹೊಳೆದಾಗ ಇವೆರಡೂ ಜೊತೆ ಸೇರುತ್ತವೆ! ಮಿಂಚಿನಲ್ಲಿ ಅನಿಲಗಳು ವೇಗವಾಗಿ ಬಿಸಿಯಾದಾಗ ಮತ್ತು ತಣ್ಣಗಾದಾಗ, [NO] ರಚನೆಯಾಗುತ್ತದೆ. ಇದು ಗಾಳಿಯ ಗುಣಮಟ್ಟಕ್ಕೆ ಒಳ್ಳೆಯದಲ್ಲ, ಆದರೂ ಬಹಳ ರೋಮಾಂಚಕಾರಿ.","span_bond_o2":"ಗರಿಷ್ಠ ಕಾರ್ಯಕ್ಷಮತೆಗಾಗಿ ಈ ಮಾಲಿಕ್ಯೂಲ್ ಅವಶ್ಯಕ. ಪರ್ವತಾರೋಹಿಗಳು [O<2>] ಟ್ಯಾಂಕ್‌ಗಳ ಸಹಾಯದೊಂದಿಗೆ ಅತ್ಯಂತ ಎತ್ತರದ ಶಿಖರಗಳನ್ನು ತಲುಪುತ್ತಾರೆ.","span_complete":"ನೀವು [%s] ಗಾಗಿ ಎಲ್ಲಾ ಲಭ್ಯವಿರುವ ಬಾಂಡ್‌ಗಳನ್ನು ಸಂಗ್ರಹಿಸಿದ್ದೀರಿ.","span_diatomic":"ಡಯಾಟಮಿಕ್ ಮಾಲಿಕ್ಯೂಲ್‌ಗಳು ಎರಡು ಪರಮಾಣುಗಳ ನಡುವಿನ ಬಾಂಡ್‌ನಿಂದ ರಚನೆಯಾಗುತ್ತವೆ. ಕೆಲವೊಮ್ಮೆ ಇದು ಒಂದೇ ಮೂಲಧಾತುವಿನ ನಡುವಿನ ಬಾಂಡ್ ಆಗಿರುತ್ತದೆ, ಉದಾಹರಣೆಗೆ [H<2>] (ಜಲಜನಕ ಅನಿಲ) ಮತ್ತು ಕೆಲವೊಮ್ಮೆ ಇದು ಎರಡು ವಿಭಿನ್ನ ಮೂಲಧಾತುಗಳ ನಡುವಿನ ಬಾಂಡ್ ಆಗಿರುತ್ತದೆ, ಉದಾಹರಣೆಗೆ [HCl] (ಜಲಜನಕ ಕ್ಲೋರೈಡ್).","span_missed_notification":"ಓಹ್, ನಿಮ್ಮಿಬ್ಬರ ಕೆಮಿಸ್ಟ್ರಿ ಚೆನ್ನಾಗಿತ್ತು.","span_no_match_notification":"ಕ್ಷಮಿಸಿ, ಹೊಂದಾಣಿಕೆಯಾಗುತ್ತಿಲ್ಲ","span_profile_ar":"ನಾನು ಅತ್ಯಂತ ಸ್ಥಿರ ಸ್ವಭಾವದ ವ್ಯಕ್ತಿ ಮತ್ತು ನಾನು ಏಕಾಂತವನ್ನು ಆನಂದಿಸುತ್ತೇನೆ. ಹಾಗಾಗಿ, ನಾನು ಸಂಗಾತಿಗಾಗಿ ಹುಡುಕುತ್ತಿದ್ದೇನೆ ಎಂದರೆ ಆ ಸಂಗಾತಿ ವಿಶೇಷ ವ್ಯಕ್ತಿಯೇ ಆಗಿರಬೇಕು. ನನಗೆ ಯಾರಾದರೂ ಇಷ್ಟವಾಗಲು ವಿದ್ಯುತ್‌ನಂತಹ ಆಕರ್ಷಣೆ ಇರಬೇಕಾಗುತ್ತದೆ, ಆದರೂ ನನಗೆ ದೀರ್ಘಕಾಲ ಜೊತೆಗಿರುವುದಕ್ಕಿಂತ, ಜೊತೆಗಿರುವಷ್ಟು ದಿನ ಖುಷಿಯಾಗಿ ಕಾಲ ಕಳೆಯುವುದು ಇಷ್ಟ.","span_profile_br":"ನನ್ನದು ಬಹುಮುಖಿ ವ್ಯಕ್ತಿತ್ವ! ನಾನು ಸಾಕಷ್ಟು ಚಂಚಲವಾಗಬಲ್ಲೆ, ಆದರೆ ಒಬ್ಬಂಟಿಯಾಗಿದ್ದಾಗ ನಾನು ಹರಿವಿನೊಂದಿಗೆ ಸಾಗಲು ಬಯಸುತ್ತೇನೆ. ನನಗೆ ಫೋಟೋಗ್ರಫಿಯ ಕುರಿತು ಒಲವಿದೆ ಮತ್ತು ನಾನು ಫೈರ್‌ಫೈಟರ್ ಸಹ ಆಗಿದ್ದೇನೆ. ಎಷ್ಟು ಕೂಲ್, ಅಲ್ಲವೇ?","span_profile_cl":"ನಿಮಗೆ ಸ್ವಚ್ಛತೆಯ ಕುರಿತು ಒಲವಿದ್ದರೆ ರೈಟ್ ಸ್ವೈಪ್ ಮಾಡಿ. ನನ್ನದು ಎಲ್ಲದಕ್ಕೂ ಪ್ರತಿಕ್ರಿಯಿಸುವ ವ್ಯಕ್ತಿತ್ವ, ಹಾಗಾಗಿ ನಮಗೆ ಯಾವುದಾದರೂ ವಿಚಾರದಲ್ಲಿ ಜೊತೆಗೆ ಬೆರೆಯುವ ಅವಕಾಶ ಖಂಡಿತ ದೊರೆಯುತ್ತದೆ, ಆದರೆ ಎಚ್ಚರವಿರಲಿ: ಒಳ್ಳೆಯ ವಸ್ತುಗಳನ್ನೂ ಮಿತಿಮೀರಿ ಬಳಸಬಾರದು (ನನ್ನನ್ನು ಚಿಕ್ಕ ಡೋಸ್‌ಗಳಲ್ಲಿ ಆನಂದಿಸಿದರೆ ಉತ್ತಮ).","span_profile_f":"ಎಲ್ಲರಿಗೂ ನಾನು ಬಹಳ ಆಕರ್ಷಕವಾಗಿ ಕಾಣುತ್ತೇನೆ. ಆಕರ್ಷಣೆಯ ವಿಚಾರಕ್ಕೆ ಬಂದರೆ, ಆರೋಗ್ಯಕರ ಮುಗುಳ್ನಗೆಯೆಂದರೆ ನನಗೆ ಅಚ್ಚುಮೆಚ್ಚು. ನನ್ನ ರೋಮಾಂಚಕ ಶಕ್ತಿ ಮತ್ತು ಯಾವುದಕ್ಕೂ ಜಗ್ಗದ ಸ್ವಭಾವ ನಾನು ಎದ್ದು ಕಾಣುವಂತೆ ಮಾಡುತ್ತವೆ ಮತ್ತು ಇತರರ ಜೊತೆ ಹೊಸ ಬಾಂಧವ್ಯ ಬೆಸೆಯಲು ಸಹಾಯ ಮಾಡುತ್ತವೆ.","span_profile_h":"ನಾನು ನಿಮ್ಮ ನಂಬರ್ ಒನ್ ಆಗಲು ಬಯಸುತ್ತೇನೆ. ನಾನು ಬಹಳ ಸರಳ, ಆದರೆ ಜೀವನಕ್ಕೆ ಅವಶ್ಯಕ. ವಾಸ್ತವದಲ್ಲಿ, ನಾನು ಅತ್ಯಂತ ಬಹುಮುಖಿ ಪರಮಾಣುವೆಂದು ಹೇಳುತ್ತಾರೆ. ನಾನು ಕ್ಷಾರ ಲೋಹದ ಗೆಳೆಯರ ಗುಂಪಿನ ಜೊತೆ ತಿರುಗಾಡುತ್ತಿರುತ್ತೇನೆ. ವಿಶ್ವದ ಬಹುತೇಕ ಎಲ್ಲ ಕಡೆಗಳಲ್ಲೂ ನಾನಿರುತ್ತೇನೆ.","span_profile_i":"ನನ್ನದು ಸದೃಢ, ನಂಬಿಕಸ್ಥ ಮತ್ತು ಸಮಚಿತ್ತವುಳ್ಳ ವ್ಯಕ್ತಿತ್ವ. ನಾನು ಎಲ್ಲವನ್ನೂ ಹೆಚ್ಚಿನ ಕಾಂಟ್ರಾಸ್ಟ್‌ನಲ್ಲಿ ನೋಡುವ ಕಾರಣ ಮುಖ್ಯ ವಿಚಾರಗಳನ್ನು ಹೈಲೈಟ್ ಮಾಡುವ ಪ್ರತಿಭೆ ನನ್ನಲ್ಲಿದೆ ಮತ್ತು ನನಗೆ ಎಲ್ಲವೂ ಸ್ವಚ್ಛವಾಗಿರಬೇಕು.","span_profile_n":"ನಿಮ್ಮ ರೆಕ್ಕೆಗಳಿಗೆ ವೇಗ ನೀಡುವ ಗಾಳಿಯಲ್ಲಿ 78% ರಷ್ಟು ನಾನೇ ಇರಲು ಅವಕಾಶ ನೀಡಿ. ನೀವು ಸಸ್ಯಗಳನ್ನು ಪೋಷಿಸಲು ಜೊತೆಗಾರರಿಗಾಗಿ ಹುಡುಕುತ್ತಿದ್ದರೆ, ನೀವು ಸರಿಯಾದ ಜಾಗದಲ್ಲಿದ್ದೀರಿ! ನನ್ನ ಮೇಲೆ ಭರವಸೆ ಇಡಿ. ನಾನು ತಂಪಾಗಿ, ಶಾಂತವಾಗಿ ಮತ್ತು ಸಮಾಧಾನದಿಂದಿರುತ್ತೇನೆ. ಆದರೆ ಚಿಂತಿಸದಿರಿ, ನಾನು ನಿಮ್ಮನ್ನು ಎಂದಿಗೂ ನಿರ್ಲಕ್ಷಿಸುವುದಿಲ್ಲ.","span_profile_na":"ನಾನೊಬ್ಬ ಸರಣಿ ಬಾಂಡರ್. ನಾನು ಒಬ್ಬಂಟಿಯಾಗಿರಲಾರೆ, ಆದರೆ ಪರವಾಗಿಲ್ಲ, ಏಕೆಂದರೆ ನಿಮಗೆ ನನ್ನನ್ನು ಬಿಟ್ಟಿರಲು ಸಾಧ್ಯವಾಗುವುದಿಲ್ಲ (ಯಾರಿಗೂ ಸಾಧ್ಯವಾಗುವುದಿಲ್ಲ). ನನಗೆ ವರ್ಕ್‌ಔಟ್ ಮಾಡುವುದು ಮತ್ತು ಸ್ನಾಯುಗಳನ್ನು ಹುರಿಗೊಳಿಸುವುದು ಅಚ್ಚುಮೆಚ್ಚು. ನಾನು ಎಲ್ಲದಕ್ಕೂ ಪ್ರತಿಕ್ರಿಯಿಸುತ್ತೇನಾದರೂ, ನನಗೆ ಅರ್ಥಪೂರ್ಣ ಸಂಬಂಧಗಳನ್ನು ಬೆಳೆಸಿಕೊಳ್ಳುವ ಕುರಿತು ಒಲವಿದೆ.","span_profile_notification":"ನಮಸ್ಕಾರ, [%s]! ನಿಮಗೆ ಹೊಂದಾಣಿಕೆಯಾಗುವವರನ್ನು ಹುಡುಕಲು ಬೆರೆಯಲು ಪ್ರಾರಂಭಿಸಿ.","span_profile_o":"ಒಪ್ಪಿಕೊಳ್ಳಿ, ನಿಮಗೆ ನಾನು ಬೇಕು. ನೀವು ಉಸಿರಾಡುವ ಗಾಳಿ ನಾನು. ನನ್ನ ಸುತ್ತ ಇರುವವರಿಗಾಗಿ ನಾನು ಹೊಸ ಗಾಳಿ ತರುತ್ತೇನೆ. ನನ್ನಲ್ಲಿ ಹೊಂದಿಕೊಳ್ಳುವ ಮತ್ತು ಬೆಳವಣಿಗೆಯನ್ನು ಉತ್ತೇಜಿಸುವ ಅದ್ಭುತ ಸಾಮರ್ಥ್ಯವಿದೆ, ಈ ಮೂಲಕ ನಾನಿರುವ ವಾತಾವರಣ ಸಮೃದ್ಧವಾಗಿರುವಂತೆ ನಾನು ನೋಡಿಕೊಳ್ಳುತ್ತೇನೆ.","span_q1":"ಪ್ರಮಾಣಿತ ತಾಪಮಾನ ಮತ್ತು ಒತ್ತಡದಲ್ಲಿ ದ್ರವ್ಯವು ಮೂರು ಸ್ಥಿತಿಗಳಲ್ಲಿರುತ್ತದೆ: ಅನಿಲ, ದ್ರವ ಮತ್ತು ಘನ.","span_q2":"ನಕ್ಷತ್ರಗಳಲ್ಲಿ ಕಾಣಸಿಗುವಂತಹ ಕೆಲವು ಮೂಲಧಾತುಗಳು ಇಡೀ ಬ್ರಹ್ಮಾಂಡದಲ್ಲಿ ಹೇರಳವಾಗಿವೆ, ಅದೇ ವೇಳೆ ಇತರ ಮೂಲಧಾತುಗಳು ತೀರಾ ಅಪರೂಪ ಮತ್ತು ದುರ್ಲಭವಾಗಿರುತ್ತವೆ.","span_q3":"ಒಂದು ಪರಮಾಣುವಿನ ಪ್ರೋಟಾನ್‌ಗಳು, ನ್ಯೂಟ್ರಾನ್‌ಗಳು ಮತ್ತು ಎಲೆಕ್ಟ್ರಾನ್‌ಗಳ ರಾಶಿಗಳನ್ನು ಕೂಡಿಸುವ ಮೂಲಕ ಆ ಪರಮಾಣುವಿನ ರಾಶಿಯನ್ನು ಕಂಡುಹಿಡಿಯಲಾಗುತ್ತದೆ.","span_q4":"ಒಂದು ಪರಮಾಣು ಬಳಸಿಕೊಳ್ಳುವ ಸ್ಥಳದ ಕಾಲ್ಪನಿಕ ಗೋಳವನ್ನು ವ್ಯಾನ್ ಡೆರ್ ವಾಲ್ಸ್ ತ್ರಿಜ್ಯ ಎಂಬ ಮೌಲ್ಯದ ಮೂಲಕ ವಿವರಿಸಲಾಗುತ್ತದೆ.","span_q5":"ರಾಸಾಯನಿಕ ಬಾಂಡ್ ಅನ್ನು ರಚಿಸುವಾಗ ಹಂಚಿಕೊಂಡ ಎಲೆಕ್ಟ್ರಾನ್‌ಗಳನ್ನು ಆಕರ್ಷಿಸುವ ಪರಮಾಣುವಿನ ಪ್ರವೃತ್ತಿಯನ್ನು ಎಲೆಕ್ಟ್ರೋನೆಗೆಟಿವಿಟಿ ಎನ್ನಲಾಗುತ್ತದೆ.","span_swipe":"ನೀವು ಬೆರೆಯಬಹುದು ಎನಿಸುವ ಮೂಲಧಾತುಗಳನ್ನು ರೈಟ್ ಸ್ವೈಪ್ ಮಾಡಿ, ನಿಮಗೆ ಆಸಕ್ತಿಯಿಲ್ಲದಿದ್ದರೆ ಲೆಫ್ಟ್ ಸ್ವೈಪ್ ಮಾಡಿ."}