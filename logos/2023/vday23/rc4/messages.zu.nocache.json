ip_interest_06":"Ama-cryogenic","chip_interest_07":"Ukujima","chip_interest_08":"Isendlalelo se-ozone","chip_interest_09":"Izibiliboco eziqandisiwe","chip_interest_10":"Ezamazinyo","chip_interest_11":"Iziphephetha-moya","chip_interest_12":"Amaphuli okubhukuda","chip_interest_13":"Ukudla","chip_interest_14":"Ukuhlanza","chip_interest_15":"Ama-snack anosawoti","chip_interest_16":"Ukuthwebula izithombe","chip_interest_17":"Ukuphepha komlilo","chip_interest_18":"Ukulima","chip_interest_19":"Ukudla okunomsoco","chip_interest_20":"Imithi","chip_interest_21":"Ukwenza ukuphrinta","chip_interest_22":"Ukukhanyisa okufudumele","chip_interest_23":"Ukwakhiwa komzimba","chip_interest_24":"Ukushisela","chip_interest_25":"Izinhlelo zokukhanya kwe-laser","chip_interest_26":"Ubuchwephese","header_about":"Mayelana nami","header_bond":"Kuyisibopho!","header_bond_arf":"I-argon fluoride","header_bond_br2":"I-diatomic bromine","header_bond_cl2":"Igesi ye-chlorine","header_bond_f2":"Igesi ye-fluorine","header_bond_h2":"Igesi ye-Hdrogen","header_bond_hcl":"I-Hydrogen chloride","header_bond_hf":"I-fluoride ye-hdrogen","header_bond_hi":"I-Hydrogen iodide","header_bond_i2":"I-Diatomic iodine","header_bond_ibr":"I-iodine monobromide","header_bond_n2":"Igesi ye-Nitrogen","header_bond_nabr":"I-sodium bromide","header_bond_nacl":"I-Sodium chloride","header_bond_naf":"I-sodium fluoride","header_bond_nai":"I-Sodium iodide","header_bond_nf":"I-nitrogen monofluoride","header_bond_no":"I-nitric oxide","header_bond_o2":"Igesi Yomoya-mpilo","header_complete":"Umsebenzi omuhle!","header_diatomic":"Ukwenza amabhondi e-diatomic Osuku lwe-Valentine","header_gallery_complete":"Halala, uqoqe konke okungu-18!","header_gallery_incomplete":"Qoqa konke okuyi-18 ukuze uveze isithombe","header_interests":"Ongaba nentshisekelo kukho","header_loader":"Iyalayisha","header_mystery":"Isibopho esiyimpicabadala","header_pick":"Khetha isakhi esihambelanayo","header_q1":"Ungazichaza kanjani?","header_q2":"Ingabe kulula ukukuthola?","header_q3":"Ingabe uyaziphakamisa izinsimbi?","header_q4":"Lithini ikhaya lamaphupho akho?","header_q5":"Ingabe abanye badonselekela kuwe?","header_quiz":"Imibuzo yobuntu besakhi","header_select":"Khetha isakhi sakho","header_splash":"Hlanganyela nezakhi zakho","header_tap":"Thepha futhi ubambe ukuze uhlanganise","label_ar":"I-argon","label_bond_arf":"Abalingisi be-Argon ne-Fluorine futhi bahlezi endaweni yamakati, lapho u-Argon edlala ngesikhombi se-laser kuyilapho u-Fluorine ehlezi nekati emathangeni akhe, amakati ahlakazekile yonke indawo.","label_bond_br2":"Kuwukuphangwa kwebhange njengoba abalingiswa ababili be-Bromine behlwitha amabha egolide ku-vault yasebhange.","label_bond_cl2":"Umzuzwana phakathi kwabalingisi ababili be-Chlorine, lapho omunye enamahloni njengoba omunye ebasiza ngamaphepha abawawise phansi.","label_bond_f2":"Abalingiswa ababili be-Fluorine bayaphuma beyofuna u-ayisikhilimu, lapho omunye ewise owakhe, kodwa ungakhathazeki, omunye uzimisele ukwaba.","label_bond_h2":"Abalingiswa ababili be-Hydrogen babambene ngezandla njengoba bebuka izinkanyezi ezidubulayo zidlula esibhakabhakeni.","label_bond_hcl":"Abalingisi be-Hydrogen ne-Chlorine babelana ngesidlo sothando ndawonye endaweni yokudlela.","label_bond_hf":"Izinhlamvu ze-Hydrogen ne-Fluorine zibekwe ngapha nangapha ebhodini lesekethe njengama-chip ekhompyutha amasekhethi phakathi kwawo enza inhliziyo.","label_bond_hi":"Umlingiswa we-Hydrogen ogqoke ikepisi ye-baseball enenqwaba yezimbali uvakashela umlingiswa we-Iodine esibhedlela onebhandeshi ekhanda.","label_bond_i2":"Izinhlamvu ezimbili ze-Iodine zikudokhu yokudoba, omunye esiza ukubopha umlenze olimele womunye njengoba inhlanzi ibaleka.","label_bond_ibr":"Umlingiswa we-Iodine uphophoma njengomlingiswa we-Bromine ogqoke ikepisi le-baseball emnikeza imbali evela ku-bouquet yakhe.","label_bond_n2":"Isigcawu esingaphezulu sezinhlamvu ezimbili ze-Nitrojeni endizisa amakhayithi amise okwenhliziyo ndawonye endaweni enotshani.","label_bond_nabr":"Abalingiswa be-Sodium ne-Bromide baziphumulele kushubhu eshisayo kukhabhinethi yasebusika njengoba inja yabo isondeza ngemuva.","label_bond_nacl":"Abalingisi be-Sodium ne-Chlorine babukele i-movie ndawonye ekhaya, babelana ngama-popcorn futhi bazungezwe amanye ama-snack.","label_bond_naf":"Abalingisi be-sodium ne-Fluorine babelana ngesiphuzo ndawonye, ngasinye sinotshani obugotshiwe obumise okwenhliziyo.","label_bond_nai":"Abalingiswa be-Sodium ne-Iodine babelana ngepikiniki ndawonye endaweni enotshani eduze nenqwaba yamanzi njengoba i-Iodine izophakela i-Sodium i-chip.","label_bond_nf":"Isigcawu somlilo wokukhempa esinabalingiswa be-Nitrogen ne-Fluorine behlezi ezingodweni ndawonye emlilweni.","label_bond_no":"Umlingiswa we-Nitrogen wabelana ngesambulela sakhe nomlingiswa Womoya-mpilo ngesikhathi kunemvula njengoba laba ababili bewela umgwaqo ndawonye.","label_bond_o2":"Abalingiswa ababili Bomoya-mpilo bahamba ndawonye ohambweni lokuqwala izintaba, bebambene amahlombe intaba iyibanga, omunye uphethe induku yokuhamba ebeke izibuko zelanga ekhanda, omunye ufake i-beanie, bobabili bagqoke izikhafu.","label_br":"I-bromine","label_carousel_indicator":"Isithombe [X] kwezingu-3","label_cl":"I-chlorine","label_f":"I-fluorine","label_h":"I-hydrogen","label_header_logo":"Ilogo ye-Google","label_i":"I-iodine","label_logo_big":"Ilogo ye-[CuPd] ye-chemistry","label_mystery":"Isici esiyimpicabadala","label_n":"I-nitrogen","label_na":"I-sodium","label_o":"Umoya-mpilo","label_pic_ar_1":"Isithombe sephrofayela somlingiswa we-Argon onemaski yokushisela lapho eshisela njengoba izinhlansi zindiza esithombeni esibaziwe senhliziyo yensimbi.","label_pic_ar_2":"Isithombe sephrofayela somlingiswa we-Argon kufoni yakhe nekati lakhe lizigoqile lilele emathangeni akhe.","label_pic_ar_3":"Isithombe sephrofayela somlingiswa we-argon egqoke ama-headphone njengoba edlala amageyimu aku-inthanethi nge-mouse yakhe nekhibhodi kuyilapho ikati lakhe lihlezi emathangeni akhe.","label_pic_br_1":"Isithombe sephrofayela somlingiswa we-Bromine ehlezi kubhampa engaphambili yenjini yokucima umlilo egqoke isigqoko sakhe sesicishamlilo.","label_pic_br_2":"Isithombe Sokudumele esimnyama nesimhlophe sembali enamazolo, esithinta imizwa kakhulu.","label_pic_br_3":"Isithombe sephrofayela sika-Bromine ethwebula isithombe ozishuthe sona nenja yakhe ekhiphele ikhanda ngaphambili.","label_pic_cl_1":"Isithombe sephrofayela yomlingiswa we-Chlorine elele kulawunji ngohlangothi esihlalweni esisesitezi eduze nechibi nezibuko zelanga ekhanda.","label_pic_cl_2":"Isithombe sephrofayela somlingiswa we-Chlorine ngokuziqhenya ebonisa ibhodi lakhe le-charcuterie.","label_pic_cl_3":"Isithombe sephrofayela somlingiswa we-Chlorine ezithwebula isithombe ozishuthe sona phambi kwamashalofu acwebezelayo agcwele imikhiqizo yokuhlanza.","label_pic_f_1":"Isithombe sephrofayela somlingiswa we-Fluorine egqoke ijazi likadokotela wamazinyo ehlezi edeskini lakhe izinyawo zakhe zibheke phezulu, udonga ngemuva kwakhe lumbozwe yizitifiketi.","label_pic_f_2":"Isithombe sephrofayela yomlingiswa we-Fluorine ogqoke isudi yebhizinisi ehlezi etafuleni lakhe izinyawo zakhe zibheke phezulu, udonga ngemuva kwakhe lumbozwe yizitifiketi.","label_pic_f_3":"Isithombe sephrofayela somlingiswa we-Fluorine ehlezi phambi kweyunithi yakhe ye-AC nenja yakhe ijabulela umoya opholile.","label_pic_h_1":"Isithombe sephrofayela somlingiswa we-Hydrogen ephakamisa isandla ngenkathi egibele ibhaluni yomoya oshisayo.","label_pic_h_2":"Isithombe sephrofayili somlingiswa we-Hydrogen ebukele ukwethulwa kwerokhethi buqamama njengoba ephakamise isandla ukuze ayincinze kancane.","label_pic_h_3":"Isithombe sephrofayili somlingiswa we-Hydrogen ebheke phezulu ezinkanyezini ngesibonakude sazo.","label_pic_i_1":"Isithombe sephrofayela yomlingiswa we-Iodine emi kudokhi yemikhumbi ngokuziqhenya ephethe inhlanzi abasanda kuyibamba, yinto enkulu leyo.","label_pic_i_2":"Isithombe sephrofayela somlingiswa we-Iodine enza amaphrinti njengoba egingqa uyinki esitembini.","label_pic_i_3":"Isithombe esingaphezulu sesitsha se-ramen, mmmm.","label_pic_n_1":"Isithombe sephrofayela somlingiswa we-Nitrogen endaweni ebamba ukushisa ezungezwe yizitshalo.","label_pic_n_2":"Isithombe sephrofayela somlingiswa we-Nitrogen egqoke isikhafu njengoba benza izingelosi zeqhwa phansi.","label_pic_n_3":"Isithombe sephrofayela somlingiswa we-Nitrogen esibonisa ibhokisi lokudla abalipakishe ngobunono nangothando.","label_pic_na_1":"Isithombe sephrofayela somlingiswa we-Sodium ethatha isithombe ozishuthe sona ejimini ekhombisa i-abs yakhe ngenkathi enza ama-curls nge-dumbell","label_pic_na_2":"Isithombe seqembu somlingiswa we-Sodium nabangane babo.","label_pic_na_3":"Isithombe sephrofayela yesigcawu esithokomele sasebusika ngokombono womlingiswa we-Sodium eneqhwa efasiteleni, ikhandlela, inkomishi eshisayo, kanye ne-Sodium enemilenze ephakanyisiwe kanye nencwadi emathangeni akhe.","label_pic_o_1":"Isithombe sephrofayela somlingiswa Womoya-mpilo ogqoke ikepisi le-baseball futhi ogijima emjahweni.","label_pic_o_2":"Isithombe sephrofayela somlingiswa Womoya-mpilo obambe imbali ecwebezelayo emlonyeni ngenkathi enza izibhamu ngeminwe.","label_pic_o_3":"Isithombe sephrofayela somlingiswa Womoya-mpilo oguqayo njengoba usebenza engadini yawo.","label_progress_quiz":"Umbuzo ongu-[X] kwengu-5","label_swipe":"Isandla esiswayiphela kwesokudla siye enkinobheni yenhliziyo ukuze uthande futhi kwesokunxele ubheke inkinobho ethi X ukuze udlule","label_unknown":"Isibopho esingaziwa","share_modal_button_close":"Vala","share_modal_button_copied":"Ilinki ikopishiwe","share_modal_button_facebook":"Yabelana nge-Facebook","share_modal_button_twitter":"Yabelana nge-X","share_modal_click_link":"Kopisha ilinki","share_modal_label_facebook":"I-Facebook","share_modal_label_twitter":"X","share_modal_share":"Yabelana","share_text":"Ingabe unayo i-chemistry enhle? Swayiphela kwesokudla ukuze usondelane nozakwenu Ngosuku lwe-Valentine olunamandla ethebula lanamuhla #GoogleDoodle.","span_bond":"Wena no-[%s] futhi ube ne-chemistry enhle","span_bond_arf":"Ngamandla anele nokucindezela, lesi sibopho sigxile ku-laser. Aama-laser e-[ArF] angasetshenziselwa ukuhlinzwa kwamehlo ukuze uhlale ubona ngo-20/20.","span_bond_br2":"Uzitholelel u-[Au] (igolide)! I-[Br<2>] isetshenziswa ezimayini zegolide njengenye indlela yokuncibilikisa igolide ensimbini, ebizwa nangokuthi ukuvuza kwe-bromine.","span_bond_cl2":"I-[Cl<2>] ingakwazi ukudiliza i-lignin ku-pulp yokhuni, inhlanganisela eyenza ukhuni lube nombala walo onsundu, okube sekusivumela ukuba sisebenzise i-pulp emhlophe ukwenza iphepha.","span_bond_f2":"I-[F<2>] isetshenziswa ekukhiqizeni ama-fluorocarbon, okuyiziqandisi ezingasetshenziswa ukugcina ukudla kubanda. Ilungele ukuhlangana ngo-ayisikhilimu.","span_bond_h2":"Lawa ma-atom aphezu kwe-cloud 9. I-[H2] ilula kunomoya, ngakho ungamangali lapho ikwenza uyithande ngokuphelele.","span_bond_hcl":"Le molecule iyababa! I-[HCl] iyi-asidi enamandla esisiza ukugaya ukudla. Iphelele ekuxhumaneni phezu kwesidlo sakusihlwa.","span_bond_hf":"Le duo eqopha ingilazi imatasa iqopha amaphethini kuma-wafer e-silicon asetshenziselwa ama-chip ekhompyutha.","span_bond_hi":"Bingelela u-[HI]! Inhlanzeko ibalulekile, ikakhulukazi ezibhedlela, lapho le molecule isiza ukubulala amathuluzi ezokwelapha.","span_bond_i2":"I-[I<2>] iyisibulala-magciwane esikhulu, futhi kanye nelinye ikhemikhali elibizwa ngokuthi yi-povidone, isiza ekugcineni ukusikeka nokukhuhla amagciwane.","span_bond_ibr":"I-[IBr] ingumngani wosokhemisi ohlaziyayo. Isetshenziswa ekuphenduleni okushintsha umbala ukuze kunqunywe ukuhlangana kwekhemikhali ethile kunqubo ebizwa ngokuthi i-iodometric titration.","span_bond_n2":"Masihambe siyondizisa amakhayithi! I-[N<2>] yenza u-78% womkhathi Womhlaba. Uma kukhulunywa ngobudlelwano, le molecule enamabhondi amathathu inokuxhumana okungena kufaniswa. Khuluma ngemigomo yokuzithanda!","span_bond_nabr":"Ingabe kuyashisa lapha, noma yilo bhavu nje? U-[NaBr] uthanda ukugcina lawo manzi emahle futhi ehlanzekile ukuze abe nesikhathi sekhwalithi yokuphumula.","span_bond_nacl":"Abantu abangafani bayahehana. I-[Na+] kanye nama-ion e-[Cl-] ahlangana ndawonye ukuze enze wonke amaphupho ethu okudla okulula okunosawoti abe yiqiniso.","span_bond_naf":"Ungakwazi ukubaniza ukubonga okumhlophe okwama-pearl ku-[NaF]. Le molecule yengezwa emanzini okuphuza kanye nomuthi wokuxubha ukuze ugcine amazinyo akho enempilo.","span_bond_nai":"Qaphela ukuntuleka kwe-iodine, i-[NaI] ilapha ukuze ugcine indlala yegilo yakho ijabule. Kanye nakho konke ukudla okugcwele i-iodine, izithasiselo ze-NaI zisekela i-metabolism enempilo.","span_bond_nf":"Ezinye izibopho azihlali unomphela. Ngaphansi kwezimo ezifanele, amafomu e-[NF], enikeza ukukhanya kwesici, kodwa ahlukanise ngokushesha lapho injabulo isiphelile.","span_bond_no":"Laba ababili bahlangana NGOKUPHAZIMA kweso! Njengoba amagesi emibani eshisa ngokushesha futhi epholile, amafomu e-[NO]. Ayilungele ikhwalithi yomoya, kodwa isajabulisa kakhulu.","span_bond_o2":"Le molecule iyadingeka ekusebenzeni okuphezulu. Abaqwali bezintaba bafinyelela ezindaweni eziphakeme kakhulu ngosizo lwamathangi e-[O<2>].","span_complete":"Uqoqe wonke amabhondi atholakalayo e-[%s].","span_diatomic":"Ama-molecule e-diatomic enziwa ngesibopho phakathi kwama-atom amabili. Kwesinye isikhathi kuba yisibopho phakathi kwesakhi esifanayo, njenge-[H<2>] (igesi ye-hydrogen), futhi ngezinye izikhathi izakhi ezimbili ezihlukene, njenge-[HCl] (i-hydrogen chloride).","span_missed_notification":"Eshu, bewune-chemistry ekahle.","span_no_match_notification":"Uxolo, akufani","span_profile_ar":"Ngizinzile futhi ngijabulela isikhathi sami ngedwa. Uma ngithi ngifuna umaqondana, ngiqonde lokho kanye. Kudingeka ugesi omningi ukuze ngizwe izinhlansi zindiza, kodwa noma kunjalo, ngilapha ukuze ngijabule, hhayi isikhathi eside.","span_profile_br":"Ngiqukethe inqwaba! Ngingakwazi ukuguquguquka, kodwa uma ngingedwa ngithanda ukuhambisana nokwenzekayo. Nginothando lokuthwebula izithombe futhi ngiyisicishamlilo. Kuhle lokho, akunjalo?","span_profile_cl":"Swayiphela kwesokudla uma uthanda inhlanzeko. Nginobuntu obusebenzayo, ngakho-ke maningi amathuba okuthi nakanjani sithole okuthile esingasondelana ngakho, kodwa qaphela: ungaba nokuhle okudlulele okungaba yingozi (ngijatshulelwa kangcono okwesikhashana).","span_profile_f":"Wonke umuntu ungibona ngikhanga ngokwedlulele. Ngikhuluma ngokukhangayo, ngingumuntu othanda ukumamatheka okunempilo. Amandla ami aqhakazile nokuqiniseka kungenza ngigqame futhi kungisize ngakhe ukuxhumana okusha nabanye.","span_profile_h":"Ngifuna ukuba ngowokuqala kuwe. Ngigcina izinto zilula, kodwa ngibalulekile ekuphileni. Eqinisweni, ngiye ngatshelwa ukuthi ngiyi-atom eguquguqukayo kakhulu ekhona. Ungangithola ngihlanganyela neqembu (i-alkali) labalandeli bomculo onesigqi esinamandla, noma kuphi endaweni yonke.","span_profile_i":"Ngiqinile, ngithembekile, futhi ngizinzile. Nginekhono lokugqamisa izinto ezibalulekile, njengoba ngibona yonke into ihluke kakhulu, futhi ngingumthandi wenhlanzeko omkhulu.","span_profile_n":"Ngivumele ngibe ngu-78% womoya ngaphansi kwamaphiko akho. Uma ufuna umzali otshala ndawonye, usendaweni efanele! Ungangethemba ukuthi ngizohlala ngipholile, ngizolile, futhi ngiqoqiwe, kodwa ungakhathazeki, angisoze ngakunika ihlombe elibandayo.","span_profile_na":"Nayi ingxenye yokuhlanganisa lapha. Ngiyakuzonda ukuba ngedwa, kodwa kulungile, ngoba awukwazi ukuphila ngaphandle kwami (akukho ongakwenza, ngokwethembeka). Ngiyathanda ukujima nokugcina leyo misipha ihamba. Nakuba ngisebenza kanzima, ngiphinde ngibe nobudlelwane bokwakha ubudlelwano obunenjongo.","span_profile_notification":"Sawubona, [%s]! Qala ukuhlanganisa ukuze uthole ukufana kwakho.","span_profile_o":"Vuma, uyangidinga. Ngingumoya owuphefumulayo. Ngiletha umoya omusha kulabo abaseduze kwami. Nginekhono elimangalisayo lokuzivumelanisa nezimo futhi ngikhuthaze ukukhula, ngiqinisekisa ukuthi indawo engikuyo iyachuma.","span_q1":"Kunezimo ezintathu zendaba ezingeni lokushisa elijwayelekile nokucindezela: igesi, uketshezi, nokuqinile.","span_q2":"Ezinye izakhi, njengalezo ezitholakala ezinkanyezini, ziningi endaweni yonke, kuyilapho ezinye ziyivelakancane futhi kunzima ukuzithola.","span_q3":"Isisindo se-athomu sinqunywa ngokwengeza inqwaba yamaphrothoni e-atom, ama-neutron, nama-electron.","span_q4":"Indawo ecatshangelwayo yesikhala i-atom eyithathayo ichazwa ngokuthi yinani elibizwa ngesilinganiso se-Van der Waals.","span_q5":"I-electronegativity iwukuthambekela kwe-athomu ukuheha ama-electron abiwe lapho enza isibopho samakhemikhali.","span_swipe":"Swayiphela kwesokudla ezintweni ocabanga ukuthi ungahlangana nazo, bese kwesokunxele uma ungenantshisekelo."}