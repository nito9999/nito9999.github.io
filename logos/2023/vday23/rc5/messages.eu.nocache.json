)]}'
{"btn_about":"Google-ren doodle honi buruz","btn_back":"Atzera","btn_close":"Itxi","btn_combine":"Sortu lotura bat","btn_complete":"Hautatu beste elementu bat","btn_gallery":"Nire loturak","btn_got_it":"Ados","btn_home":"Hasierako pantaila","btn_info":"Ikusi profil osoa","btn_keep_swiping":"Jarraitu hatza pasatzen","btn_like":"Gustatzen zait","btn_more":"Doodle gehiago","btn_more_query":"Google-ren doodle-ak","btn_pass":"Ez zait interesatzen","btn_q1_a":"Espiritu libre bat","btn_q1_b":"Moldakorra","btn_q1_c":"Irmoa eta zentzuduna","btn_q2_a":"Toki guztietan nago, ezinezkoa da nitaz libratzea","btn_q2_b":"Ez da oso zaila ni aurkitzea","btn_q2_c":"Ezinezkoa da ni aurkitzea","btn_q3_a":"Ez dut sekula altxatu pisurik","btn_q3_b":"Burdinazko pisuak altxatzen ditut noizean behin ([Fe])","btn_q3_c":"MUSKULUAK garatzea ezinbestekoa da niretzat","btn_q4_a":"Basetxe eroso bat","btn_q4_b":"Etxe handi bat","btn_q4_c":"Luxuzko etxe ikaragarri bat","btn_q5_a":"Oso erakargarria naiz","btn_q5_b":"Jaiaren arima naiz","btn_q5_c":"Jende gutxi dut nire inguruan","btn_quiz":"Erantzun galdeketari","btn_search":"Bilatu","btn_select":"Hautatu dagokizun elementua","btn_share":"Partekatu","btn_start":"Hasi lotzen","chip_about_01":"Gasa","chip_about_02":"Ugariena","chip_about_03":"Arinena","chip_about_04":"Koloregabea","chip_about_05":"Zazpigarren ugariena","chip_about_06":"Pniktogenoa","chip_about_07":"Hirugarren ugariena","chip_about_08":"Kalkogenoa","chip_about_09":"Halogenoa","chip_about_10":"Hori argia","chip_about_11":"Hori berdexka","chip_about_12":"Likidoa","chip_about_13":"Gorri marroixka","chip_about_14":"Solidoa","chip_about_15":"Metal alkalinoa","chip_about_16":"Zilarra","chip_about_17":"Gas noblea","chip_about_18":"Beltza","chip_interest_01":"Astronomia","chip_interest_02":"Suziriak","chip_interest_03":"Globo aerostatikoan ibiltzea","chip_interest_04":"Lorezaintza","chip_interest_05":"Elikagaien bilgarriak","chip_interest_06":"Kriogenia","chip_interest_07":"Ariketa","chip_interest_08":"Ozono-geruza","chip_interest_09":"Gozoki izoztuak","chip_interest_10":"Odontologia","chip_interest_11":"Aire girotua","chip_interest_12":"Igerilekuak","chip_interest_13":"Jatea","chip_interest_14":"Garbitzea","chip_interest_15":"Mokadu gaziak","chip_interest_16":"Argazkilaritza","chip_interest_17":"Suteak itzaltzea","chip_interest_18":"Nekazaritza","chip_interest_19":"Elikadura","chip_interest_20":"Medikuntza","chip_interest_21":"Estanpatzea","chip_interest_22":"Argi epela","chip_interest_23":"Kulturismoa","chip_interest_24":"Soldatzea","chip_interest_25":"Laser-argien ikuskizunak","chip_interest_26":"Teknologia","header_about":"Niri buruz","header_bond":"Lotura bat osatu duzue!","header_bond_arf":"Argon fluoruroa","header_bond_br2":"Bromo diatomikoa","header_bond_cl2":"Kloro-gasa","header_bond_f2":"Fluor-gasa","header_bond_h2":"Hidrogeno-gasa","header_bond_hcl":"Hidrogeno kloruroa","header_bond_hf":"Hidrogeno fluoruroa","header_bond_hi":"Hidrogeno ioduroa","header_bond_i2":"Iodo diatomikoa","header_bond_ibr":"Iodo monobromuroa","header_bond_n2":"Nitrogeno-gasa","header_bond_nabr":"Sodio bromuroa","header_bond_nacl":"Sodio kloruroa","header_bond_naf":"Sodio fluoruroa","header_bond_nai":"Sodio ioduroa","header_bond_nf":"Nitrogeno monofluoruroa","header_bond_no":"Oxido nitrikoa","header_bond_o2":"Oxigeno-gasa","header_complete":"Oso ongi!","header_diatomic":"San Valentin egunean lotura diatomikoak sortzea","header_gallery_complete":"Zorionak, 18 lauzak bildu dituzu!","header_gallery_incomplete":"Bildu 18 lauzak argazkia ikusteko","header_interests":"Interesak","header_loader":"Kargatzen","header_mystery":"Lotura misteriotsua","header_pick":"Hautatu zurekin bateragarria den elementu bat","header_q1":"Nola deskribatuko zenuke zeure burua?","header_q2":"Erraza al da zu aurkitzea?","header_q3":"Pisurik altxatzen duzu?","header_q4":"Zein da zure ametsetako etxea?","header_q5":"Jendea erakartzen al duzu?","header_quiz":"Izaeraren araberako elementua ezagutzeko galdeketa","header_select":"Hautatu dagokizun elementua","header_splash":"Elkartu beste elementu batzuekin","header_tap":"Bateratzeko, eduki sakatuta","label_ar":"Argona","label_bond_arf":"Argonaren eta fluorraren pertsonaiak katu-kafetegi batean daude, sakabanatutako katuak daudela. Argonaren pertsonaia laser-erakusle batekin jolasten ari da, eta fluorraren pertsonaiak katu bat du magalean.","label_bond_br2":"Banku-lapurreta batean, bromoaren bi pertsonaiak urrezko barrak lapurtzen dituzte banku baten ganbera korazatutik.","label_bond_cl2":"Kloroaren bi pertsonaiaren arteko momentu bat. Bat lotsaz gorrituta dago, eta besteak lehenengoari lurrera erori zaizkion paperak jasotzen laguntzen dio.","label_bond_f2":"Fluorraren bi pertsonaia izozki bat jatera joan dira. Bati izozkia erori zaio, baina bestea berea partekatzeko prest dago.","label_bond_h2":"Hidrogenoaren bi pertsonaia, bata bestearen eskuari heltzen, zeruan dauden izar iheskor pare bati begira daudela.","label_bond_hcl":"Hidrogenoaren eta kloroaren pertsonaiak otordu erromantiko batean, jatetxe batean.","label_bond_hf":"Zirkuitu inprimatu batean bata bestearen alboan kokatutako hidrogenoaren eta fluorraren pertsonaiak, ordenagailu-txipen moduan; haien arteko zirkuituek bihotz bat eratzen dute.","label_bond_hi":"Lore sorta bat duen hidrogenoaren pertsonaiak, beisboleko bisera bat jantzita daukala, ospitalean dagoen eta buruan hesgailu bat duen iodoaren pertsonaiari bisita egiten dio.","label_bond_i2":"Iodoaren bi pertsonaia kai batean arrantzan ari dira. Arrainak ihes egiten duen bitartean, batak besteari laguntzen dio hanka zaurituan hesgailu bat jartzen.","label_bond_ibr":"Iodoaren pertsonaia bat lotsaz gorritu da beisboleko bisera bat jantzita daukan bromoaren pertsonaia batek lore sorta batetik atera duen lore bat eman diolako.","label_bond_n2":"Belarrez betetako zelai batean bihotz-formako kometak hegaldatzen dituzten nitrogenoaren bi pertsonaiaren goitiko ikuspegia.","label_bond_nabr":"Sodioaren eta bromoaren pertsonaiak ur beroa duen bainuontzi batean erlaxatzen ari dira, negu-etxola batean. Haien txakurra alde batetik bestera lasterka ari da atzeko planoan.","label_bond_nacl":"Sodioaren eta kloroaren pertsonaiak elkarrekin film bat ikusten ari dira etxean. Krispetak partekatzen dituzte eta beste mokadu batzuez inguratuta daude.","label_bond_naf":"Sodioaren eta fluorraren pertsonaiek edari bat partekatzen dute, bakoitzak bihotz-formako tutu bat duela.","label_bond_nai":"Sodioaren eta iodoaren pertsonaiak piknik bat egiten ari dira belarrez betetako zelai batean, ur-masa baten ondoan. Iodoaren pertsonaiak patata frijitu bat ematen dio sodioaren pertsonaiari.","label_bond_nf":"Nitrogenoaren eta fluorraren pertsonaiak su baten ondoan, egur puska batzuetan eserita.","label_bond_no":"Euri-ekaitz batean kalea elkarrekin gurutzatzen duten bitartean, nitrogenoaren pertsonaiak euritakoa partekatzen du oxigenoaren pertsonaiarekin.","label_bond_o2":"Oxigenoaren bi pertsonaia mendira joan dira elkarrekin. Beso bat bata bestearen sorbalda gainean dute jarrita, eta urrutian mendi bat ikusten da. Batek makila bat darama eta buruan eguzkitako betaurrekoak ditu, eta besteak artilezko txano bat du. Biek bufandak dauzkate.","label_br":"Bromoa","label_carousel_indicator":"Hiru argazkitatik [X]garrena","label_cl":"Kloroa","label_f":"Fluorra","label_h":"Hidrogenoa","label_header_logo":"Google-ren logotipoa","label_i":"Iodoa","label_logo_big":"Chemistry [CuPd] logotipoa","label_mystery":"Elementu misteriotsua","label_n":"Nitrogenoa","label_na":"Sodioa","label_o":"Oxigenoa","label_pic_ar_1":"Argonaren pertsonaiaren profileko argazkia. Soldadura-maskara bat jantzita duela, soldadura-lan bat egiten ari da txinpartak mosaiko-formako bihotz-eskultura baten gainean erortzen diren bitartean.","label_pic_ar_2":"Argonaren pertsonaiaren profileko argazkia. Telefonoari begira dago, kiribildutako katua magalean lotan daukala.","label_pic_ar_3":"Argonaren pertsonaiaren profileko argazkia. Entzungailuak jarrita dauzka eta sarean bideojokoetan ari da sagua eta teklatua erabilita, katua magalean eserita daukala.","label_pic_br_1":"Bromoaren pertsonaiaren profileko argazkia. Suhiltzaileen kamioi baten aurreko kolpe-leungailuan eserita dago, suhiltzaile-kapela jantzita daukala.","label_pic_br_2":"Ihintza duen lore baten lehen planoko argazki zuri-beltz goibela eta oso hunkigarria.","label_pic_br_3":"Bromoaren pertsonaiaren profileko argazkia. Autoargazki bat ateratzen ari da, eta, aurreko planoan, haren txakurraren burua ikusten da.","label_pic_cl_1":"Kloroaren pertsonaiaren profileko argazkia. Igerilekuaren ondoko etzaulki batean etzanda dago, buruan eguzkitako betaurrekoak jarrita dauzkala.","label_pic_cl_2":"Kloroaren pertsonaiaren profileko argazkia. Hestebete-ohol bat erakusten ari da harro.","label_pic_cl_3":"Kloroaren pertsonaiaren profileko argazkia. Autoargazki bat ateratzen ari da garbiketa-produktuak dituzten apal distiratsu batzuen aurrean.","label_pic_f_1":"Fluorraren pertsonaiaren profileko argazkia. Dentista-mantal bat jantzita dauka eta mahaigainaren atzean eserita dago, oinak mahaigainaren gainean dauzkala. Atzeko horma ziurtagiriz beteta dago.","label_pic_f_2":"Fluorraren pertsonaiaren profileko argazkia. Janzki bat darama eta mahaigainaren atzean eserita dago, oinak mahaigainaren gainean dauzkala. Atzeko horma ziurtagiriz beteta dago.","label_pic_f_3":"Fluorraren pertsonaiaren profileko argazkia. Aire-girogailuaren aurrean eserita dago bere txakurrarekin, aire hotzaz gozatzen.","label_pic_h_1":"Hidrogenoaren pertsonaiaren profileko argazkia. Eskuaz agurtzen du globo aerostatiko batean dabilen bitartean.","label_pic_h_2":"Hidrogenoaren pertsonaiaren profileko argazkia. Urrunean jaurti den suziri bati begiratzen dio eta, bitartean, eskua altxatuta dauka suziria atximurkatzeko.","label_pic_h_3":"Hidrogenoaren pertsonaiaren profileko argazkia. Teleskopio batekin izarrei begiratzen die.","label_pic_i_1":"Iodoaren pertsonaiaren profileko argazkia. Kai batean zutik dago eta harrapatu berri duen arrain handiari eusten dio harro.","label_pic_i_2":"Iodoaren pertsonaiaren profileko argazkia. Zigilu batean tinta jartzen ari da arrabol batekin, estanpatuak egiteko.","label_pic_i_3":"Ramen katilu baten goitiko argazkia. Goxo-goxo.","label_pic_n_1":"Nitrogenoaren pertsonaiaren profileko argazkia. Berotegi batean dago, landarez inguratuta.","label_pic_n_2":"Nitrogenoaren pertsonaiaren profileko argazkia. Bufanda bat jantzita dauka eta lurrean elurrezko aingeruak egiten ari da.","label_pic_n_3":"Nitrogenoaren pertsonaiaren profileko argazkia. Kontu handiz eta maitasunez prestatu duen zakote-ontzia erakusten ari da.","label_pic_na_1":"Sodioaren pertsonaiaren profileko argazkia. Gimnasioan autoargazki bat ateratzen ari da, abdominalak erakusten eta besoa lantzen duen haltera-ariketa bat egiten.","label_pic_na_2":"Sodioaren pertsonaiaren eta haren lagunen talde-argazki bat.","label_pic_na_3":"Sodioaren pertsonaiaren ikuspegitik ateratako negu-paisaia goxo baten profileko argazkia. Hauek ikusten dira: elurra kalean, kandela bat, lurruna darion kikara bat eta sodioaren pertsonaia, hankak altxatuta dauzkala eta magalean liburu bat duela.","label_pic_o_1":"Oxigenoaren pertsonaiaren profileko argazkia. Beisboleko bisera bat jantzita dauka eta lasterketa batean korrika egiten ari da.","label_pic_o_2":"Oxigenoaren pertsonaiaren profileko argazkia. Modu limurtzailean arrosa bati eusten dio ahoan eta hatzekin pistolen keinuak egiten ari da.","label_pic_o_3":"Oxigenoaren pertsonaiaren profileko argazkia. Makurtuta dago lorategian lan egiten duen bitartean.","label_progress_quiz":"Bost galderatatik [X]garrena","label_swipe":"Hatza pasatzen duen esku bat. Gustatzen zaizula adierazteko, eskuinera (bihotz baten botoi baterantz) pasatzen da hatza eta, hurrengo profilera pasatzeko, ezkerrera (X botoi baterantz).","label_unknown":"Lotura ezezaguna","share_modal_button_close":"Itxi","share_modal_button_copied":"Kopiatu da esteka","share_modal_button_facebook":"Partekatu Facebook bidez","share_modal_button_twitter":"Partekatu X bidez","share_modal_click_link":"Kopiatu esteka","share_modal_label_facebook":"Facebook","share_modal_label_twitter":"X","share_modal_share":"Partekatu","share_text":"Kimika ona duzue? Pasatu hatza eskuinera beste elementu batzuekin elkartzeko, taula periodikoan oinarritutako San Valentin egunerako gaurko Google-ren doodle-an. #GoogleDoodle","span_bond":"Zuk eta [%s] elementuak kimika ona duzue","span_bond_arf":"Energia eta presio nahikoa badaude, lotura hau laserrak bezain fokuratuta egongo da. [ArF] erabilita egiten diren laserrak begi-ebakuntzetarako erabil daitezke, ezin hobeto ikusten jarrai dezazun.","span_bond_br2":"Zu bai arrakastatsua, [Au] (urrea) lortu duzu! Urre-meatzeetan erabiltzen da [Br<2>], mean dagoen urrea disolbatzeko ordezko metodo gisa (bromo bidezko lixibiazio ere baderitzo metodo horri).","span_bond_cl2":"Paper-orearen lignina (egurrari kolore marroia ematen dion konposatua) hausteko gai da [Cl<2>]. Ondoren, ore zuriarekin papera sor dezakegu.","span_bond_f2":"[F<2>] fluorokarbonoak sortzeko erabiltzen da. Janaria hotz mantentzeko erabiltzen diren hozgarriak dira fluorokarbonoak. Ezin hobea izozki bat jan bitartean lotura bat ezartzeko.","span_bond_h2":"Ezti-mamitan daude atomo hauek. [H2] airea baino arinagoa da. Beraz, ez zaitez harritu itxuragabe maitemintzen bazara.","span_bond_hcl":"Molekula hau mina da oso! Janaria digeritzen laguntzen digun azido gogor bat da [HCl]. Ezin hobea afariaren ostean lotura bat ezartzeko.","span_bond_hf":"Bikote banaezin hau lanpetuta dago ordenagailu-txipetarako erabiltzen diren silikonazko plaketan diseinuak grabatzen.","span_bond_hi":"Agurtu [HI]. Garbitasuna ezinbestekoa da, batez ere ospitaleetan. Han, molekula honek tresna medikoak desinfektatzen ditu.","span_bond_i2":"[I<2>] primerako antiseptikoa da. Pobidona izeneko beste gai kimiko batekin nahastean, ebaki eta atzamarketan germenak sartzea saihesten du.","span_bond_ibr":"Kimikari analitiko baten laguna da [IBr]. Kolorea aldatzen duten erreakzioetan erabiltzen da, gai kimiko jakin baten kontzentrazioa zehazteko. Prozesu horri iodometria deritzo.","span_bond_n2":"Hegalda ditzagun kometak! [N<2>] elementuak Lurraren atmosferaren % 78 hartzen du. Harremanei dagokienez, lotura hirukoitzeko molekula honek konexio paregabe bat du. Hori bai hori amodio propioa!","span_bond_nabr":"Beroa egiten du edo bainuontziaren kontua da? [NaBr] ura garbi mantentzeaz arduratzen da, lasai-lasai erlaxa daitezen.","span_bond_nacl":"Kontrako poloak erakartzen dira. [Na+]- eta [Cl-]-ioiak elkartzen direnean, hainbeste gustatzen zaizkigun mokadu gazi horiek mamitzen dira.","span_bond_naf":"Perla-itxura duten hortzak harro erakutsi ahal izanaren erantzulea da [NaF]. Molekula hori edateko uretan eta hortzetako pastan gehitzen da hortzak osasuntsu mantentzeko.","span_bond_nai":"[NaI] erabilita, tiroidea poz-pozik egongo da. Ez duzu sekula iodo-eskasiarik izango! Iodo asko duten elikagaiekin batera, sodio ioduroa duten osagarriek metabolismoa osasuntsu mantentzen dute.","span_bond_nf":"Lotura batzuek ez dute betiko irauten. Baldintza egokiekin, [NF] eratzen da, eta horrek distira bereizgarri bat igortzen du. Gero, zirrara desagertzen denean, bizkor desegiten da.","span_bond_no":"Tximista batean aurki ditzakezu bi elementu horiek. Tximistetako gasak bizkor berotu eta hoztu ahala, [NO] eratzen da. Ez da gauza ona airearen kalitaterako, baina nahiko zirraragarria da, hala ere.","span_bond_o2":"Errendimendurik onena lortzeko behar da molekula hori. Alpinistak tontor garaienetara iristen dira [O<2>] duten botilen laguntzarekin.","span_complete":"[%s] elementurako erabilgarri dauden lotura guztiak bildu dituzu.","span_diatomic":"Molekula diatomikoak bi atomoren loturek osatzen dituztenak dira. Batzuetan, elementu beraren loturek osatzen dituzte; adibidez, [H<2>] (hidrogeno-gasa). Beste batzuetan, berriz, bi elementuren loturek osatzen dituzte; esaterako, [HCl] (hidrogeno kloruroa).","span_missed_notification":"Zer pena, kimika ona zeneukaten.","span_no_match_notification":"Sentitzen dugu, hori ez da bat-etortze bat","span_profile_ar":"Oso egonkorra naiz, eta denbora bakarrik ematea gustatzen zait. Niretzat egokia den pertsonaren bila nabilela esaten dudanean, ez naiz txantxetan ari. Elektrizitate asko behar dut txinpartak nabaritzeko, baina, hala bada ere, ez naiz luze geratuko; ondo pasatzeko nago hemen.","span_profile_br":"Askotariko formetan aurkituko nauzu. Nahiko ezegonkorra naiz, baina bakarrik nagoenean moldakorra izatea gustatzen zait. Argazkilaritza gustuko dut eta suhiltzailea ere banaiz. Zer ondo, ezta?","span_profile_cl":"Pasatu hatza eskuinera garbitasuna zure grinetako bat bada. Nire izaera oso erreaktiboa da. Beraz, litekeena da elkarrekin lotzeko puntu amankomun bat aurkitzea, baina kontuz: gauza onek ere badituzte beren mugak. Nitaz gozatzeko, hobe da dosi txikiak hartzea.","span_profile_f":"Izugarri erakargarria naiz guztientzat. Horiek horrela, irribarre osasuntsuak gustuko ditut. Nire energia sutsuari eta irmotasunari esker, besteen gainetik nabarmentzen naiz eta besteekin konexio berriak ezartzen ditut.","span_profile_h":"Zuretzako atomorik garrantzitsuena izan nahi dut. Gauza sinpleak atsegin ditut, baina bizitzeko oinarrizkoa naiz. Izan ere, atomorik moldakorrena naizela diote. Metal musika entzuten (metal alkalinoekin) edo, oro har, unibertsoan aurkituko nauzu.","span_profile_i":"Irmoa, fidagarria eta zentzuduna naiz. Garrantzitsuak diren gauzak nabarmentzeko talentua dut, dena kontraste handian ikusten dut eta. Gainera, ordenarekin maniatikoa naiz.","span_profile_n":"Utz iezadazu zure hegalen azpiko airearen % 78 izaten. Landareak hazteko lagun baten bila bazabiltza, hemen nauzu. Nitaz fida zaitezke fresko eta lasai egoteko, baina ez kezkatu: ez zaitut inoiz utziko bakarrik.","span_profile_na":"Serieko lotzaile nauzu. Gorroto dut bakarrik egotea, baina ez da ezer gertatzen: ezin zara ni gabe bizi (inor ezin da ni gabe bizi, egia esan). Entrenatzea eta muskuluak garatzea gogoko dut. Nahiz eta erreaktiboa izan, harreman sakonak sortzea gustatzen zait.","span_profile_notification":"Kaixo, [%s]! Hasi beste batzuekin lotzen zure bat-etortzea aurkitzeko.","span_profile_o":"Onar ezazu: ezin zara ni gabe bizi. Hartzen duzun airea naiz. Nire ingurukoei aire freskoa ematen diet. Egokitzeko eta hazkundea bultzatzeko gaitasun paregabea dut, eta bizitoki naukaten inguruneak hazten direla ziurtatzen dut.","span_q1":"Tenperatura eta presio arruntekin, hiru materia-egoera daude: gaseosoa, likidoa eta solidoa.","span_q2":"Elementu batzuk (adibidez, izarretan daudenak) unibertsoan oparoak dira, eta beste batzuk, ordea, urriak eta aurkitzen zailak dira.","span_q3":"Masa atomikoa zehazteko, atomo baten protoien, neutroien eta elektroien masak gehitzen dira.","span_q4":"Atomo batek hartzen duen alegiazko esfera Van der Waals erradioa izeneko balio batekin deskribatzen da.","span_q5":"Lotura kimiko bat osatzean atomo batek elektroi partekatuak erakartzeko joerari elektronegatibotasuna deritzo.","span_swipe":"Elementu batekin lotzea interesatzen bazaizu, pasatu hatza eskuinera. Interesatzen ez bazaizu, berriz, pasatu hatza ezkerrera."}