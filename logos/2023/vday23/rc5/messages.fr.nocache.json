)]}'
{"btn_about":"À propos de ce doodle Google","btn_back":"Retour","btn_close":"Fermer","btn_combine":"Combinons-nous !","btn_complete":"Sélectionner un autre élément","btn_gallery":"Mes liens","btn_got_it":"OK","btn_home":"Accueil","btn_info":"Voir le profil complet","btn_keep_swiping":"Continuer à balayer l'écran","btn_like":"J'aime","btn_more":"Plus de doodles","btn_more_query":"Doodles Google","btn_pass":"Ignorer","btn_q1_a":"Un esprit libre","btn_q1_b":"Facile à vivre","btn_q1_c":"Stable et terre-à-terre","btn_q2_a":"Je suis partout, on ne peut pas se débarrasser de moi","btn_q2_b":"Je ne suis pas trop difficile à trouver","btn_q2_c":"C'est impossible de mettre la main sur moi","btn_q3_a":"Je n'ai jamais touché un haltère de ma vie","btn_q3_b":"Je fais parfois des bras de fer ([Fe])","btn_q3_c":"Je suis accro à la salle de muscu","btn_q4_a":"Un chalet douillet","btn_q4_b":"Une maison spacieuse","btn_q4_c":"Un immense manoir","btn_q5_a":"Personne ne peut me résister","btn_q5_b":"Je suis le centre de la fête","btn_q5_c":"J'ai un petit cercle d'amis","btn_quiz":"Répondre au quiz","btn_search":"Rechercher","btn_select":"Sélectionner votre élément","btn_share":"Partager","btn_start":"Créer des liens","chip_about_01":"Gaz","chip_about_02":"Le plus abondant","chip_about_03":"Le plus léger","chip_about_04":"Incolore","chip_about_05":"7e plus abondant","chip_about_06":"Pnictogène","chip_about_07":"3e plus abondant","chip_about_08":"Chalcogène","chip_about_09":"Halogène","chip_about_10":"Jaune pâle","chip_about_11":"Jaune-vert","chip_about_12":"Liquide","chip_about_13":"Rouge-brun","chip_about_14":"Solide","chip_about_15":"Métal alcalin","chip_about_16":"Argenté","chip_about_17":"Gaz noble","chip_about_18":"Noir","chip_interest_01":"Observation des étoiles","chip_interest_02":"Fusées","chip_interest_03":"Tours en montgolfière","chip_interest_04":"Jardinage","chip_interest_05":"Emballages alimentaires","chip_interest_06":"Cryogénie","chip_interest_07":"Sport","chip_interest_